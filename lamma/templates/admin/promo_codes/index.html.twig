{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des Codes Promo - LAMMA{% endblock %}
{% block admin_title %}Gestion des Codes Promo{% endblock %}

{% block admin_content %}
<style>
    :root {
        --scout-navy: #1a1f2c;
        --scout-blue: #2d3648;
        --scout-orange: #ff7a1a;
        --scout-orange-hover: #e66a15;
        --scout-red: #ff3e3e;
        --scout-glass: rgba(255, 255, 255, 0.05);
    }

    .promo-container {
        display: flex;
        gap: 20px;
        height: calc(100vh - 200px);
        background: var(--scout-navy);
        padding: 20px;
        border-radius: 15px;
    }

    .promo-list-panel {
        flex: 2;
        background: var(--scout-blue);
        border-radius: 12px;
        overflow-y: auto;
        border: 1px solid rgba(255,255,255,0.05);
        padding: 0;
    }

    .promo-editor-panel {
        flex: 1;
        background: var(--scout-blue);
        border-radius: 12px;
        padding: 25px;
        border: 1px solid rgba(255,255,255,0.05);
        display: flex;
        flex-direction: column;
    }

    .scout-table {
        width: 100%;
        color: #fff;
        border-collapse: separate;
        border-spacing: 0;
    }

    .scout-table th {
        background: rgba(255,255,255,0.05);
        padding: 15px;
        text-transform: uppercase;
        font-size: 0.8rem;
        color: #aab1b7;
        position: sticky;
        top: 0;
    }

    .scout-table td {
        padding: 15px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        font-size: 0.9rem;
    }

    .scout-table tr:hover {
        background: rgba(255,255,255,0.02);
        cursor: pointer;
    }

    .scout-table tr.active-promo {
        background: rgba(255, 122, 26, 0.1);
    }

    .badge-status {
        padding: 5px 10px;
        border-radius: 5px;
        font-size: 0.75rem;
        font-weight: bold;
    }

    .badge-active { background: #28a745; color: #fff; }
    .badge-inactive { background: #dc3545; color: #fff; }

    .form-scout label {
        color: #aab1b7;
        font-size: 0.9rem;
        margin-bottom: 8px;
        display: block;
    }

    .form-scout .form-control {
        background: var(--scout-navy);
        border: 1px solid rgba(255,255,255,0.1);
        color: #fff;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 20px;
    }

    .form-scout .form-control:focus {
        border-color: var(--scout-orange);
        box-shadow: none;
    }

    .btn-save {
        background: var(--scout-orange);
        color: #fff;
        border: none;
        padding: 15px;
        border-radius: 10px;
        font-weight: bold;
        width: 100%;
        margin-top: 10px;
        font-size: 1.1rem;
    }

    .btn-new {
        background: rgba(255,255,255,0.1);
        color: #fff;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    .btn-delete {
        background: var(--scout-red);
        color: #fff;
        border: none;
        padding: 12px;
        border-radius: 10px;
        font-weight: bold;
        width: 100%;
        margin-top: 20px;
        opacity: 0.8;
    }

    .btn-delete:hover {
        opacity: 1;
    }

    .usage-bar {
        height: 6px;
        background: #333;
        border-radius: 3px;
        margin-top: 5px;
        overflow: hidden;
    }

    .usage-fill {
        height: 100%;
        background: var(--scout-orange);
    }
</style>

<div class="row mb-3">
    <div class="col-6">
        <a href="{{ path('app_restauration_dashboard') }}" class="btn btn-outline-light btn-sm">
            <i class="fas fa-arrow-left"></i> Retour au Dashboard
        </a>
    </div>
    <div class="col-6 text-end">
        <button class="btn btn-outline-light btn-sm" onclick="location.reload()">Actualiser</button>
    </div>
</div>

<div class="promo-container">
    <!-- List Side -->
    <div class="promo-list-panel">
        <table class="scout-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Remise (%)</th>
                    <th>Expiration</th>
                    <th>Actif</th>
                    <th>Usage</th>
                </tr>
            </thead>
            <tbody>
                {% for code in codes %}
                <tr onclick="window.location.href='?id={{ code.id }}'" class="{{ currentPromo.id == code.id ? 'active-promo' : '' }}">
                    <td style="font-weight: bold; color: var(--scout-orange);">{{ code.code }}</td>
                    <td>{{ code.remise }}%</td>
                    <td>{{ code.dateExpiration|date('Y-m-d') }}</td>
                    <td>
                        <span class="badge-status {{ code.isActive ? 'badge-active' : 'badge-inactive' }}">
                            {{ code.isActive ? 'true' : 'false' }}
                        </span>
                    </td>
                    <td>
                        {{ code.usageCount }} / {{ code.usageLimit }}
                        <div class="usage-bar">
                            {% set pct = (code.usageCount / code.usageLimit * 100)|round %}
                            <div class="usage-fill" style="width: {{ pct }}%"></div>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Edit Side -->
    <div class="promo-editor-panel">
        <h4 style="color: #fff; margin-bottom: 25px;">Édition du Code</h4>
        
        <a href="{{ path('app_admin_promo_codes_index') }}" class="btn-new text-center w-100 mb-4">
            <i class="fas fa-plus"></i> Nouveau Code
        </a>

        {{ form_start(form, {'attr': {'class': 'form-scout'}}) }}
            {{ form_row(form.code) }}
            {{ form_row(form.remise) }}
            {{ form_row(form.dateExpiration) }}
            {{ form_row(form.usageLimit) }}
            
            <div class="mb-4 d-flex align-items-center gap-3">
                {{ form_widget(form.isActive) }}
                {{ form_label(form.isActive) }}
            </div>

            <button type="submit" class="btn-save">Enregistrer</button>
        {{ form_end(form) }}

        {% if currentPromo.id %}
            <form method="post" action="{{ path('app_admin_promo_codes_delete', {'id': currentPromo.id}) }}" onsubmit="return confirm('Confirmer la suppression ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ currentPromo.id) }}">
                <button class="btn-delete">Supprimer</button>
            </form>
        {% endif %}
    </div>
</div>
{% endblock %}
