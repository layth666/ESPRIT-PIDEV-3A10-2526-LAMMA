{% extends 'admin/base_admin.html.twig' %}
{% import '_macros.html.twig' as macros %}

{% block title %}Activités - LAMMA{% endblock %}
{% block admin_title %}Intelligence d'Événements{% endblock %}

{% block admin_content %}
<section class="crud-section">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 style="font-family:'Anton',sans-serif;color:var(--scout-navy); margin: 0;">Cartographie des Missions</h2>
            <div style="font-size: 0.85rem; color: var(--text-dim); font-weight: 700;">Déploiement stratégique et gestion des activités en cours</div>
        </div>
        <div class="col-md-6 text-right">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_evenement_new') }}" class="btn-scout-confirm" style="padding: 10px 25px;"><i class="fa fa-plus"></i> NOUVELLE MISSION</a>
            {% endif %}
        </div>
    </div>

    <div class="scout-card" style="padding: 0;">
        {% set columns = {
            'titre': 'Mission',
            'type': 'Type',
            'lieu': 'Localisation',
            'dateDebut': 'Déploiement',
            'dateFin': 'Extraction'
        } %}
        {{ macros.crud_table(items, columns, 'app_evenement_edit', 'app_evenement_show', 'evenement') }}
    </div>
</section>
{% endblock %}
