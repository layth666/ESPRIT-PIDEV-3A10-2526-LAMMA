{% extends 'base.html.twig' %}

{% block title %}Nouvel Événement - LAMMA{% endblock %}
{% block page_title %}Créer un Événement{% endblock %}
{% block page_subtitle %}Planifier un nouvel événement LAMMA{% endblock %}

{% block body %}
<section class="crud-section" style="padding: 60px 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                <div class="glass-panel" style="padding: 40px; background: #fff; border-radius: 15px;">
                    <!-- Header Section -->
                    <div class="scout-header" style="border-bottom: 3px solid var(--scout-blue);">
                        <div class="scout-icon-stack" style="background: var(--scout-navy);">📍</div>
                        <div class="scout-title-group">
                            <h2>Intelligence d'Événement • <span style="color: var(--scout-blue);">Mission Map</span></h2>
                            <div class="scout-subtitle">EventCon Professional System • Strategic deployment</div>
                        </div>
                        <div class="ml-auto">
                            <span class="scout-badge" style="background: var(--scout-orange);">VALIDATION ACTIVE</span>
                        </div>
                    </div>

                    <!-- Global Error Display (Contrôle de saisie) -->
                    {% if not form.vars.valid %}
                    <div class="alert alert-danger mb-4" style="border-left: 5px solid var(--scout-orange); background: #fff5f5;">
                        <h5 style="color: var(--scout-orange); font-weight: 900;"><i class="fa fa-exclamation-triangle"></i> ERREUR DE SAISIE</h5>
                        <p style="color: #666; font-size: 0.9rem;">Veuillez corriger les erreurs ci-dessous pour valider la mission.</p>
                        {{ form_errors(form) }}
                    </div>
                    {% endif %}

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    <div class="row mt-4">
                        <!-- LEFT CORE FORM -->
                        <div class="col-lg-8">
                            <!-- Mission Identity -->
                            <div class="scout-card mb-4" style="background: #f8fbff;">
                                <div class="scout-input-label" style="color: var(--scout-blue); font-size: 0.9rem;">🛡️ Mission Identification</div>
                                <div class="row mt-3">
                                    <div class="col-12 mb-3">
                                        {{ form_label(form.titre, null, {'label_attr': {'class': 'scout-input-label'}}) }}
                                        {{ form_widget(form.titre, {'attr': {'placeholder': 'Titre de l\'événement...', 'class': 'form-control ' ~ (form.titre.vars.errors|length > 0 ? 'is-invalid' : '')}}) }}
                                        {{ form_errors(form.titre) }}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_label(form.type, null, {'label_attr': {'class': 'scout-input-label'}}) }}
                                        {{ form_widget(form.type, {'attr': {'class': 'form-control ' ~ (form.type.vars.errors|length > 0 ? 'is-invalid' : '')}}) }}
                                        {{ form_errors(form.type) }}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_label(form.lieu, null, {'label_attr': {'class': 'scout-input-label'}}) }}
                                        {{ form_widget(form.lieu, {'attr': {'placeholder': 'Salle / Localisation', 'class': 'form-control ' ~ (form.lieu.vars.errors|length > 0 ? 'is-invalid' : '')}}) }}
                                        {{ form_errors(form.lieu) }}
                                    </div>
                                </div>
                            </div>

                            <!-- Mission Temporality -->
                            <div class="scout-card mb-4" style="background: #fffcf8;">
                                <div class="scout-input-label" style="color: var(--scout-orange); font-size: 0.9rem;">⏳ Mission Temporality</div>
                                <div class="row mt-3">
                                    <div class="col-md-6">
                                        {{ form_label(form.dateDebut, null, {'label_attr': {'class': 'scout-input-label'}}) }}
                                        {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control ' ~ (form.dateDebut.vars.errors|length > 0 ? 'is-invalid' : '')}}) }}
                                        {{ form_errors(form.dateDebut) }}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_label(form.dateFin, null, {'label_attr': {'class': 'scout-input-label'}}) }}
                                        {{ form_widget(form.dateFin, {'attr': {'class': 'form-control ' ~ (form.dateFin.vars.errors|length > 0 ? 'is-invalid' : '')}}) }}
                                        {{ form_errors(form.dateFin) }}
                                    </div>
                                </div>
                            </div>

                            <!-- Visual Asset -->
                            <div class="scout-card mb-4" style="background: #f0faf4;">
                                <div class="scout-input-label" style="color: var(--scout-green); font-size: 0.9rem;">🖼️ Visual Asset</div>
                                <div class="mt-3">
                                    {{ form_label(form.image, null, {'label_attr': {'class': 'scout-input-label'}}) }}
                                    {{ form_widget(form.image, {'attr': {'placeholder': 'URL de l\'image (Thumbnail)', 'class': 'form-control ' ~ (form.image.vars.errors|length > 0 ? 'is-invalid' : '')}}) }}
                                    {{ form_errors(form.image) }}
                                </div>
                            </div>

                            <div class="mt-5 d-flex align-items-center gap-3">
                                <button type="submit" class="btn btn-scout-confirm">💾 SAVE MISSION</button>
                                <a href="{{ path('app_evenement_index') }}" class="btn btn-scout-abort">❌ ABORT</a>
                            </div>
                        </div>

                        <!-- RIGHT SIDEBAR -->
                        <div class="col-lg-4">
                            <div class="scout-card mb-4" style="background: var(--scout-navy); color: #fff;">
                                <div class="scout-input-label" style="color: #fff;">Description Brief</div>
                                <div class="mt-3">
                                    {{ form_widget(form.description, {'attr': {'style': 'height: 180px;', 'class': 'form-control ' ~ (form.description.vars.errors|length > 0 ? 'is-invalid' : '')}}) }}
                                    {{ form_errors(form.description) }}
                                </div>
                            </div>

                            <div class="metric-card" style="background: #fff; border: 1px solid var(--scout-orange); color: var(--scout-navy);">
                                <div class="scout-input-label" style="color: var(--scout-orange);">Mission Priority</div>
                                <div class="mt-2 row">
                                    <div class="col-6">
                                        <div class="scout-subtitle">LEVEL</div>
                                        <div style="font-weight: 900; font-size: 1.2rem; color: var(--scout-navy);">OMEGA</div>
                                    </div>
                                    <div class="col-6">
                                        <div class="scout-subtitle">STATUS</div>
                                        <div style="font-weight: 900; font-size: 1.2rem; color: var(--scout-orange);">CORE</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
