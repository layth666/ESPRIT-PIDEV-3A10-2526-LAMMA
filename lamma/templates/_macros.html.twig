{# Macro for rendering a CRUD index table with inline delete #}
{% macro crud_table(entities, columns, edit_path, show_path, delete_path) %}
    <div class="row mt-4" style="gap: 20px 0;">
        {% for entity in entities %}
            <div class="col-md-6 col-lg-4 d-flex align-items-stretch">
                <div class="card w-100 scout-crud-card" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 15px; backdrop-filter: blur(10px); color: #fff; box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: transform 0.3s ease;">
                    <div class="card-body" style="padding: 20px;">
                        <h4 style="font-family: 'Anton', sans-serif; color: #3b82f6; border-bottom: 1px dashed rgba(255,255,255,0.1); padding-bottom: 10px; margin-bottom: 15px; text-transform: uppercase;">
                            {% set first_col = columns|keys|first %}
                            {{ attribute(entity, first_col) }}
                        </h4>
                        
                        <div class="entity-details" style="font-size: 0.9rem; line-height: 1.6;">
                            {% for field, label in columns %}
                                {% if field != first_col %}
                                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px; border-bottom: 1px dashed rgba(255,255,255,0.05); padding-bottom: 4px; align-items: center;">
                                        <span style="color: #aab1b7; font-weight: 600; font-size: 0.8rem; text-transform: uppercase;">{{ label }}</span>
                                        <span style="text-align: right; font-weight: bold; font-size: 0.95rem;">
                                            {% set value = attribute(entity, field) %}
                                            {% if value is null %}
                                                <span class="text-muted">-</span>
                                            {% elseif value is same as(true) %}
                                                <span class="badge" style="background:#28a745; color: white;">OUI</span>
                                            {% elseif value is same as(false) %}
                                                <span class="badge" style="background:#dc3545; color: white;">NON</span>
                                            {% elseif value is iterable %}
                                                <span class="badge" style="background-color: #3b82f6;">Collection ({{ value|length }})</span>
                                            {% elseif value is not same as(null) and value is not same as(true) and value is not same as(false) %}
                                                {% if value.__toString is defined %}
                                                    {{ value }}
                                                {% elseif value.format is defined %}
                                                    <i class="fa fa-calendar-o mr-1" style="color: #3b82f6;"></i> {{ value|date('d/m/Y') }}
                                                {% else %}
                                                    {{ value }}
                                                {% endif %}
                                            {% endif %}
                                        </span>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="card-footer" style="background: transparent; border-top: 1px solid rgba(255,255,255,0.1); padding: 15px; display: flex; justify-content: space-between; align-items: center;">
                        <a href="{{ path(show_path, {'id': entity.id}) }}" class="btn btn-sm btn-outline-light" style="border-radius: 20px; font-size: 11px; padding: 5px 15px; border-color: rgba(255,255,255,0.2);">VOIR DÉTAILS</a>
                        
                        {% if is_granted('ROLE_ADMIN') %}
                            <div class="d-flex gap-2">
                                <a href="{{ path(edit_path, {'id': entity.id}) }}" class="btn btn-sm" style="background: rgba(255,193,7,0.8); color: #000; border-radius: 20px; font-size: 11px; font-weight: bold;"><i class="fa fa-pen"></i></a>
                                {% if delete_path %}
                                    <form method="post" action="{{ path('app_' ~ delete_path ~ '_delete', {'id': entity.id}) }}" onsubmit="return confirm('Êtes-vous sûr ?');" style="display:inline; margin:0;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entity.id) }}">
                                        <button type="submit" class="btn btn-sm" style="background: rgba(220,53,69,0.8); color: #fff; border-radius: 20px; font-size: 11px;"><i class="fa fa-trash"></i></button>
                                    </form>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center" style="padding: 40px; color: #aab1b7;">
                <i class="fa fa-folder-open mb-3" style="font-size: 3rem; color: #3b82f6; opacity: 0.5;"></i>
                <h4>Aucune donnée disponible</h4>
            </div>
        {% endfor %}
    </div>
    
    <style>
    .scout-crud-card:hover { transform: translateY(-5px) !important; box-shadow: 0 10px 25px rgba(59,130,246,0.15) !important; border-color: rgba(59,130,246,0.3) !important; }
    </style>
{% endmacro %}
