{% extends 'base.html.twig' %}

{% block title %}Nouvel Ingrédient - LAMMA{% endblock %}
{% block page_title %}Ajouter un Ingrédient{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="fiche-card">
                    <div class="fiche-header text-uppercase">
                        <i class="fa fa-flask mr-2"></i> FICHE D'INFORMATION INGRÉDIENT
                    </div>
                    <div class="fiche-body">
                        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="row mt-3">
                            <div class="col-12">
                                {{ form_widget(form) }}
                            </div>
                        </div>
                        <div class="mt-5 text-center">
                            <button type="submit" class="btn btn-publier">Enregistrer Ingrédient</button>
                            <a href="{{ path('app_ingredient_index') }}" class="btn btn-annuler">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
