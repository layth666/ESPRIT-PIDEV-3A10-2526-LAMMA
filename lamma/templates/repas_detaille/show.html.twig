{% extends 'base.html.twig' %}

{% block title %}Détails Repas Détaille - LAMMA{% endblock %}
{% block page_title %}{{ item.nom }}{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-10 mx-auto">
                <div class="card card-detail overflow-hidden mb-4">
                    {% if item.imageUrl %}
                        <img src="{{ item.imageUrl }}" class="card-img-top" alt="{{ item.nom }}" style="max-height: 350px; object-fit: cover;">
                    {% endif %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fa fa-info"></i> Fiche Technique</span>
                        <span class="badge badge-status badge-{{ item.actif ? 'actif' : 'expire' }}">{{ item.actif ? 'ACTIF' : 'INACTIF' }}</span>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <h3>{{ item.nom }}</h3>
                                <p class="text-pink h4" style="color:#fb246a;">{{ item.prix }} €</p>
                                <div class="mt-2 text-muted">
                                    <span class="badge badge-info">{{ item.typeRepas }}</span>
                                    <span class="badge badge-secondary ml-1">{{ item.calories }} kcal</span>
                                </div>
                            </div>
                            <div class="col-md-4 text-right">
                                <p class="text-muted"><i class="fa fa-calendar"></i> {{ item.date ? item.date|date('d/m/Y') : '-' }}</p>
                            </div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="col-md-6">
                                <h6>Attributs diététiques :</h6>
                                <p>Végétarien : {{ item.vegetarien ? 'Oui' : 'Non' }}</p>
                                <p>Vegan : {{ item.vegan ? 'Oui' : 'Non' }}</p>
                                <p>Sans Gluten : {{ item.sansGluten ? 'Oui' : 'Non' }}</p>
                                <p>Halal : {{ item.halal ? 'Oui' : 'Non' }}</p>
                            </div>
                            <div class="col-md-6">
                                <h6>Relations :</h6>
                                <p>Participant ID : {{ item.participantId ?? '-' }}</p>
                                <p>Événement ID : {{ item.evenementId ?? '-' }}</p>
                                <p>Restaurant ID : {{ item.restaurantId ?? '-' }}</p>
                            </div>
                        </div>
                        <hr>
                        <div class="mb-4">
                            <h5>Description</h5>
                            <p>{{ item.description ?? 'Pas de description.' }}</p>
                        </div>
                        <div class="mb-4">
                            <h5>Notes Interne</h5>
                            <p class="p-3 bg-light rounded">{{ item.notes ?? 'Pas de notes.' }}</p>
                        </div>
                        <div class="mt-4 text-center">
                            <a href="{{ path('app_repas_detaille_edit', {id: item.id}) }}" class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">Modifier</a>
                            <a href="{{ path('app_repas_detaille_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Retour</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
