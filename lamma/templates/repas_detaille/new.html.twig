{% extends 'base.html.twig' %}

{% block title %}Nouveau Repas Détaille - LAMMA{% endblock %}
{% block page_title %}Ajout de Repas Détaille{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="fiche-card">
                    <div class="fiche-header text-uppercase">
                        <i class="fa fa-cutlery mr-2"></i> FICHE D'INFORMATION PLAT DÉTAILLÉ
                    </div>
                    <div class="fiche-body">
                        {{ form_start(form) }}
                            <div class="col-12">{{ form_row(form.notes) }}</div>
                            <div class="col-md-3" style="padding-top:30px;">{{ form_row(form.actif) }}</div>
                        </div>
                        <div class="mt-4 text-center">
                            <button class="btn btn-add">Enregistrer</button>
                            <a href="{{ path('app_repas_detaille_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
