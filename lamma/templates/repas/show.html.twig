{% extends 'base.html.twig' %}

{% block title %}Détails Repas - LAMMA{% endblock %}
{% block page_title %}{{ item.nom }}{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card card-detail overflow-hidden mb-4">
                    {% if item.imageUrl %}
                        <img src="{{ item.imageUrl }}" class="card-img-top" alt="{{ item.nom }}" style="max-height: 350px; object-fit: cover;">
                    {% endif %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fa fa-cutlery"></i> Fiche Plat</span>
                        <span class="badge badge-status badge-{{ item.disponible ? 'actif' : 'expire' }}">{{ item.disponible ? 'DISPONIBLE' : 'EPUISE' }}</span>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-8">
                                <h3>{{ item.nom }}</h3>
                                <p class="text-pink h4" style="color:#fb246a;">{{ item.prix }} €</p>
                                <div class="mt-2 text-muted">
                                    <span class="badge badge-info">{{ item.categorie }}</span>
                                    <span class="badge badge-secondary ml-1">{{ item.typePlat }}</span>
                                </div>
                            </div>
                            <div class="col-md-4 text-right">
                                <p class="text-muted"><i class="fa fa-clock-o"></i> {{ item.tempsPreparation }} min</p>
                                <p class="small text-muted">Resto ID: {{ item.restaurantId }}</p>
                            </div>
                        </div>
                        <div class="mb-4">
                            <h5>Description</h5>
                            <p>{{ item.description ?? 'Pas de description.' }}</p>
                        </div>
                        <div class="mb-4">
                            <h5>Ingrédients</h5>
                            <p>
                                {% if item.ingredients is iterable and item.ingredients|length > 0 %}
                                    <span class="badge badge-light" style="font-size: 1rem; border: 1px solid #ddd; padding: 5px 12px; border-radius: 15px;">
                                        {{ item.ingredients|join('</span> <span class="badge badge-light" style="font-size: 1rem; border: 1px solid #ddd; padding: 5px 12px; border-radius: 15px;">')|raw }}
                                    </span>
                                {% else %}
                                    <span class="text-muted italic">Aucun ingrédient sélectionné.</span>
                                {% endif %}
                            </p>
                        </div>
                        <div class="mt-4 text-center">
                            <a href="{{ path('app_repas_edit', {id: item.id}) }}" class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">Modifier</a>
                            <a href="{{ path('app_repas_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Retour</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
