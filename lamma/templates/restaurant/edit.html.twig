{% extends 'base.html.twig' %}

{% block title %}Modifier Restaurant - LAMMA{% endblock %}
{% block page_title %}Modifier Établissement{% endblock %}

{% block body %}
<section class="crud-section" style="padding: 60px 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="glass-panel" style="padding: 40px; background: #fff; border-radius: 15px;">
                    <div class="scout-header" style="border-bottom: 3px solid var(--scout-blue);">
                        <div class="scout-icon-stack" style="background: var(--scout-navy);">🍽️</div>
                        <div class="scout-title-group">
                            <h2>Planification de Restauration • <span style="color: var(--scout-blue);">Édition</span></h2>
                            <div class="scout-subtitle">LAMMA System • Modification de l'établissement</div>
                        </div>
                        <div class="ml-auto">
                            <span class="scout-badge" style="background: var(--scout-orange);">MISE À JOUR</span>
                        </div>
                    </div>

                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} mt-3">{{ message }}</div>
                        {% endfor %}
                    {% endfor %}

                    {% if not form.vars.valid %}
                    <div class="alert alert-danger mb-4 mt-3" style="border-left: 5px solid var(--scout-orange); background: #fff5f5;">
                        <h5 style="color: var(--scout-orange); font-weight: 900;"><i class="fa fa-exclamation-triangle"></i> ERREUR DE SAISIE</h5>
                        <p style="color: #666; font-size: 0.9rem;">Veuillez renseigner correctement les informations du restaurant.</p>
                        {{ form_errors(form) }}
                    </div>
                    {% endif %}

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    <div class="row mt-4">
                        <div class="col-lg-12">
                            <div class="scout-card mb-4" style="background: #f8fbff; padding: 30px;">
                                <div class="scout-input-label mb-4" style="color: var(--scout-blue); font-size: 1.1rem; border-bottom: 2px solid var(--scout-blue); padding-bottom: 10px;">🛡️ Profil de l'Établissement</div>

                                <div class="row">
                                    <div class="col-md-6">{{ form_row(form.nom) }}</div>
                                    <div class="col-md-6">{{ form_row(form.email) }}</div>
                                    <div class="col-12">{{ form_row(form.adresse) }}</div>
                                    <div class="col-md-6">{{ form_row(form.telephone) }}</div>
                                    <div class="col-md-6">{{ form_row(form.imageUrl) }}</div>
                                    <div class="col-12">{{ form_row(form.description) }}</div>
                                    <div class="col-md-3">{{ form_row(form.rating) }}</div>
                                    <div class="col-md-3">{{ form_row(form.nombrePlaces) }}</div>
                                    <div class="col-md-3">{{ form_row(form.latitude) }}</div>
                                    <div class="col-md-3">{{ form_row(form.longitude) }}</div>
                                    <div class="col-md-6" style="padding-top: 10px;">{{ form_row(form.isOpen) }}</div>
                                    <div class="col-md-6" style="padding-top: 10px;">{{ form_row(form.actif) }}</div>
                                </div>

                                <div class="mt-4 pt-3 d-flex align-items-center gap-3" style="border-top: 1px solid #ddd;">
                                    <button type="submit" class="btn btn-scout-confirm" style="padding: 12px 30px; font-weight: bold; background: var(--scout-navy); color: white; border-radius: 5px;">💾 METTRE À JOUR</button>
                                    <a href="{{ path('app_restaurant_index') }}" class="btn btn-scout-abort" style="padding: 12px 30px; color: #666; margin-left: 15px;">❌ ANNULER</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
