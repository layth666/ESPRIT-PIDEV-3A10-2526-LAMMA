{% extends 'admin/base_admin.html.twig' %}
{% import '_macros.html.twig' as macros %}

{% block title %}Restaurants - LAMMA{% endblock %}
{% block admin_title %}Logistique Culinaire{% endblock %}

{% block admin_content %}
<section class="crud-section">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 style="font-family:'Anton',sans-serif;color:var(--scout-navy); margin: 0;">Réseau des Établissements Partner</h2>
            <div style="font-size: 0.85rem; color: var(--text-dim); font-weight: 700;">Gestion du ravitaillement et des points de restauration</div>
        </div>
        <div class="col-md-6 text-right">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_restaurant_new') }}" class="btn-scout-confirm" style="padding: 10px 25px;"><i class="fa fa-plus"></i> NOUVEAU RESTAURANT</a>
            {% endif %}
        </div>
    </div>

    <div class="scout-card" style="padding: 0;">
        {% set columns = {
            'nom': 'Restaurant',
            'email': 'Contact',
            'telephone': 'Support',
            'rating': 'Qualité',
            'actif': 'Actif'
        } %}
        {{ macros.crud_table(items, columns, 'app_restaurant_edit', 'app_restaurant_show', 'restaurant') }}
    </div>
</section>
{% endblock %}
