                    <div class="section_title mb-80">
                        <h3 class="wow fadeInRight" data-wow-duration="1s" data-wow-delay=".3s">Nos Sponsors</h3>
                    </div>
                </div>
            </div>
            <div class="row">
                {% if sponsors is defined and sponsors|length > 0 %}
                    {% for sponsor in sponsors %}
                        <div class="col-lg-3 col-md-4 col-sm-6 mb-30">
                            <div class="single_performer wow fadeInUp" data-wow-duration="1s" data-wow-delay=".3s">
