                                    {% if sponsor.logo %}
                                        <img src="{{ asset('uploads/logos/' ~ sponsor.logo) }}"
                                             alt="{{ sponsor.nom }}"
                                             style="width:100%; height:260px; object-fit:contain; padding:20px;">
                                    {% else %}
                                        <div style="color:#aaa; font-size:50px; text-align:center;">
                                            <i class="fa fa-image"></i>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="performer_heading">
                                    <h4>{{ sponsor.nom }}</h4>
                                    <span>{{ sponsor.niveau is defined and sponsor.niveau ? sponsor.niveau : 'Sponsor' }}</span>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>

            {# ============================================================
               SPONSOR FEEDBACK / REPORT BOX
               ============================================================ #}
            <div class="row mt-80">
                <div class="col-lg-12">
                    <div class="section_title mb-40">
                        <h3 class="wow fadeInRight" data-wow-duration="1s" data-wow-delay=".3s">Espace Sponsors</h3>
                        <p style="color:#aaa;">Vous êtes sponsor ? Identifiez-vous pour laisser un feedback ou signaler un problème.</p>
                    </div>
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-lg-8">

                    {# --- PUBLIC FEEDBACKS DISPLAY --- #}
                    {% if feedbacks is defined and feedbacks|length > 0 %}
                    <div class="mb-50" id="feedbacks-display">
                        <h5 style="color:#e8c74a; margin-bottom:20px;"><i class="fa fa-comments"></i> Ce que disent nos sponsors</h5>
                        {% for fb in feedbacks %}
                        <div style="background:#1a1a1a; border-left:3px solid #e8c74a; padding:15px 20px; margin-bottom:15px; border-radius:4px;">
                            <p style="color:#fff; margin-bottom:5px;">{{ fb.contenu }}</p>
                            <small style="color:#888;">— {{ fb.nom }} · {{ fb.createdAt|date('d/m/Y') }}</small>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                    {# --- STEP 1: Identity verification --- #}
                    <div id="step-verify" style="background:#1a1a1a; border:1px solid #333; border-radius:8px; padding:35px;">
                        <h5 style="color:#fff; margin-bottom:25px;"><i class="fa fa-lock" style="color:#e8c74a;"></i> Vérification Sponsor</h5>
                        <div class="form-group mb-20">
                            <label style="color:#aaa; font-size:13px;">Votre Nom (tel qu'enregistré)</label>
                            <input type="text" id="verify-nom" placeholder="Nom du sponsor"
                                   style="width:100%; padding:12px 15px; background:#111; border:1px solid #333; color:#fff; border-radius:4px; margin-top:6px; outline:none;">
                        </div>
                        <div class="form-group mb-25">
                            <label style="color:#aaa; font-size:13px;">Votre Email</label>
                            <input type="email" id="verify-email" placeholder="email@sponsor.com"
                                   style="width:100%; padding:12px 15px; background:#111; border:1px solid #333; color:#fff; border-radius:4px; margin-top:6px; outline:none;">
                        </div>
                        <div id="verify-error" style="color:#e74c3c; font-size:13px; margin-bottom:15px; display:none;"></div>
                        <button onclick="verifySponsor()"
                                style="background:#e8c74a; color:#000; border:none; padding:12px 30px; border-radius:4px; font-weight:bold; cursor:pointer; width:100%;">
                            Vérifier mon identité
                        </button>
                    </div>

                    {# --- STEP 2: Choose feedback or report --- #}
                    <div id="step-choice" style="display:none; background:#1a1a1a; border:1px solid #333; border-radius:8px; padding:35px;">
                        <h5 style="color:#fff; margin-bottom:10px;"><i class="fa fa-check-circle" style="color:#27ae60;"></i> Identité vérifiée !</h5>
                        <p style="color:#aaa; margin-bottom:25px;">Que souhaitez-vous faire ?</p>
                        <div class="row">
                            <div class="col-md-6 mb-15">
                                <button onclick="showForm('feedback')"
                                        style="width:100%; padding:20px; background:#27ae60; color:#fff; border:none; border-radius:6px; font-size:15px; cursor:pointer;">
                                    <i class="fa fa-comment" style="font-size:24px; display:block; margin-bottom:8px;"></i>
                                    Laisser un Feedback
                                </button>
                            </div>
                            <div class="col-md-6 mb-15">
                                <button onclick="showForm('report')"
                                        style="width:100%; padding:20px; background:#c0392b; color:#fff; border:none; border-radius:6px; font-size:15px; cursor:pointer;">
                                    <i class="fa fa-flag" style="font-size:24px; display:block; margin-bottom:8px;"></i>
                                    Signaler un problème
                                </button>
                            </div>
                        </div>
                    </div>

                    {# --- STEP 3: Write feedback or report --- #}
                    <div id="step-form" style="display:none; background:#1a1a1a; border:1px solid #333; border-radius:8px; padding:35px;">
                        <h5 id="form-title" style="color:#fff; margin-bottom:20px;"></h5>
                        <textarea id="form-contenu" rows="5" placeholder="Écrivez ici..."
                                  style="width:100%; padding:12px 15px; background:#111; border:1px solid #333; color:#fff; border-radius:4px; outline:none; resize:vertical;"></textarea>
                        <div id="form-error" style="color:#e74c3c; font-size:13px; margin-top:10px; display:none;"></div>
                        <div style="display:flex; gap:10px; margin-top:15px;">
                            <button onclick="submitForm()"
                                    style="background:#e8c74a; color:#000; border:none; padding:12px 30px; border-radius:4px; font-weight:bold; cursor:pointer; flex:1;">
                                Envoyer
                            </button>
                            <button onclick="goBack()"
                                    style="background:#333; color:#fff; border:none; padding:12px 20px; border-radius:4px; cursor:pointer;">
                                Retour
                            </button>
                        </div>
                    </div>

                    {# --- STEP 4: Success message --- #}
                    <div id="step-success" style="display:none; background:#1a1a1a; border:1px solid #27ae60; border-radius:8px; padding:35px; text-align:center;">
                        <i class="fa fa-check-circle" style="color:#27ae60; font-size:50px; margin-bottom:15px;"></i>
                        <h5 id="success-message" style="color:#fff;"></h5>
                    </div>

                </div>
            </div>
        </div>
    </div>
    <!-- sponsors_area_end -->

{% endblock %}

{% block javascripts %}
<script>
    // State
    var currentSponsorId  = null;
    var currentNom        = null;
    var currentEmail      = null;
    var currentType       = null;

    var checkUrl    = "{{ path('front_sponsor_check') }}";
    var submitUrl   = "{{ path('front_sponsor_feedback') }}";

    function show(id)   { document.getElementById(id).style.display = 'block'; }
    function hide(id)   { document.getElementById(id).style.display = 'none'; }
    function err(id, msg) {
        var el = document.getElementById(id);
        el.textContent = msg;
        el.style.display = msg ? 'block' : 'none';
    }

    function verifySponsor() {
        var nom   = document.getElementById('verify-nom').value.trim();
        var email = document.getElementById('verify-email').value.trim();

        if (!nom || !email) {
            err('verify-error', 'Veuillez remplir les deux champs.');
            return;
        }

        var formData = new FormData();
        formData.append('nom', nom);
        formData.append('email', email);

        fetch(checkUrl, { method: 'POST', body: formData })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    currentSponsorId = data.sponsorId;
                    currentNom       = nom;
                    currentEmail     = email;
                    hide('step-verify');
                    show('step-choice');
                    err('verify-error', '');
                } else {
                    err('verify-error', data.message);
                }
            })
            .catch(() => err('verify-error', 'Erreur de connexion, réessayez.'));
    }

    function showForm(type) {
        currentType = type;
        hide('step-choice');
        var title = type === 'feedback'
            ? '💬 Votre Feedback'
            : '🚨 Signaler un problème';
        document.getElementById('form-title').textContent = title;
        document.getElementById('form-contenu').value = '';
        err('form-error', '');
        show('step-form');
    }

    function goBack() {
        hide('step-form');
        show('step-choice');
    }

    function submitForm() {
        var contenu = document.getElementById('form-contenu').value.trim();
        if (!contenu) {
            err('form-error', 'Veuillez écrire quelque chose.');
            return;
        }

        var formData = new FormData();
        formData.append('sponsorId', currentSponsorId);
        formData.append('type', currentType);
        formData.append('contenu', contenu);
        formData.append('nom', currentNom);
        formData.append('email', currentEmail);

        fetch(submitUrl, { method: 'POST', body: formData })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    hide('step-form');
                    document.getElementById('success-message').textContent = data.message;
                    show('step-success');

                    // If feedback: add it live to the display without page reload
                    if (data.type === 'feedback') {
                        var display = document.getElementById('feedbacks-display');
                        if (!display) {
                            display = document.createElement('div');
                            display.id = 'feedbacks-display';
                            display.innerHTML = '<h5 style="color:#e8c74a; margin-bottom:20px;"><i class="fa fa-comments"></i> Ce que disent nos sponsors</h5>';
                            document.getElementById('step-verify').parentNode.insertBefore(display, document.getElementById('step-verify'));
                        }
                        var today = new Date();
                        var dateStr = today.getDate().toString().padStart(2,'0') + '/' +
                                      (today.getMonth()+1).toString().padStart(2,'0') + '/' +
                                      today.getFullYear();
                        var card = document.createElement('div');
                        card.style.cssText = 'background:#1a1a1a; border-left:3px solid #e8c74a; padding:15px 20px; margin-bottom:15px; border-radius:4px;';
                        card.innerHTML = '<p style="color:#fff; margin-bottom:5px;">' + contenu + '</p>' +
                                         '<small style="color:#888;">— ' + currentNom + ' · ' + dateStr + '</small>';
                        display.appendChild(card);
                    }
                } else {
                    err('form-error', data.message);
                }
            })
            .catch(() => err('form-error', 'Erreur de connexion, réessayez.'));
    }
</script>
{% endblock %}
