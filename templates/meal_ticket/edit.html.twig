{% extends 'base.html.twig' %}

{% block title %}Modifier Ticket - LAMMA{% endblock %}
{% block page_title %}Mise à jour du Ticket{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card card-detail">
                    <div class="card-header">Édition du ticket </div>
                    <div class="card-body form-section">
                        {{ form_start(form) }}
                        {{ form_row(form.userId) }}
                        {{ form_row(form.participationId) }}
                        {{ form_row(form.timeSlot) }}
                        {{ form_row(form.qrCode) }}
                        <div class="my-3">{{ form_row(form.used) }}</div>
                        <div class="mt-4 text-center">
                            <button class="btn btn-add">Enregistrer</button>
                            <a href="{{ path('app_meal_ticket_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
