{% extends 'base.html.twig' %}

{% block title %}Nouveau Meal Ticket - LAMMA{% endblock %}
{% block page_title %}Émission de Ticket Repas{% endblock %}
{% block page_subtitle %}Générer un ticket repas pour un participant{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="fiche-card">
                    <div class="fiche-header text-uppercase">
                        <i class="fa fa-ticket mr-2"></i> FICHE D'INFORMATION TICKET REPAS
                    </div>
                    <div class="fiche-body">
                        {{ form_start(form) }}
                        
                        <div class="fiche-row">
                            <div class="fiche-col">{{ form_row(form.ticketCode) }}</div>
                            <div class="fiche-col">{{ form_row(form.prix) }}</div>
                        </div>
                        
                        <div class="fiche-row">
                            <div class="fiche-col">{{ form_row(form.status) }}</div>
                            <div class="fiche-col">{{ form_row(form.timeSlot) }}</div>
                        </div>

                        <div class="mt-5 text-center">
                            <button type="submit" class="btn btn-publier">Générer le Ticket Repas</button>
                            <a href="{{ path('app_meal_ticket_index') }}" class="btn btn-annuler">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
