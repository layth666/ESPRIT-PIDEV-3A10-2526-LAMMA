{% extends 'base.html.twig' %}

{% block title %}Détails Meal Ticket - LAMMA{% endblock %}
{% block page_title %}Meal Ticket {% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card card-detail text-center">
                    <div class="card-header">Ticket Repas Officiel</div>
                    <div class="card-body">
                        <div class="my-4">
                            {% if item.qrCode %}
                                <div class="p-3 bg-white d-inline-block border rounded">
                                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={{ item.qrCode|url_encode }}" alt="QR Code">
                                </div>
                                <p class="mt-2 text-muted small">CODE: {{ item.qrCode }}</p>
                            {% else %}
                                <div class="p-5 bg-light text-muted border rounded">
                                    <i class="fa fa-qrcode fa-5x"></i>
                                    <p>Pas de QR code généré</p>
                                </div>
                            {% endif %}
                        </div>
                        <h4 class="mb-3">Créneau : {{ item.timeSlot ? item.timeSlot|date('H:i') : 'Non défini' }}</h4>
                        <div class="mb-4">
                             Statut : <span class="badge badge-status badge-{{ item.used ? 'expire' : 'actif' }}">{{ item.used ? 'UTILISÉ' : 'VALIDE' }}</span>
                        </div>
                        <table class="table table-sm text-left">
                            <tr><th>Utilisateur</th><td>{{ item.userId }}</td></tr>
                            <tr><th>Participation</th><td>{{ item.participationId }}</td></tr>
                            <tr><th>Date Utilisation</th><td>{{ item.usedAt ? item.usedAt|date('d/m/Y H:i') : '-' }}</td></tr>
                        </table>
                        <div class="mt-4">
                            <a href="{{ path('app_meal_ticket_edit', {id: item.id}) }}" class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">Modifier</a>
                            <a href="{{ path('app_meal_ticket_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Retour</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
