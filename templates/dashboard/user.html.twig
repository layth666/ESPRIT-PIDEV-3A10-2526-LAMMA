{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord - LAMMA{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Anton&display=swap" rel="stylesheet">
<style>
    :root {
        --glass-bg: rgba(15, 23, 42, 0.6);
        --glass-border: rgba(255, 255, 255, 0.1);
        --accent-pink: #ff005a;
        --accent-pink-glow: rgba(255, 0, 90, 0.4);
        --accent-blue: #3b82f6;
        --accent-orange: #f97316;
        --accent-green: #10b981;
        --text-muted: #94a3b8;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: #020617; /* Even darker background for more contrast */
        color: #f8fafc;
    }

    .dashboard-container {
        padding-top: 50px;
        padding-bottom: 50px;
    }

    /* PREMIUM GLASS PANEL */
    .premium-panel {
        background: var(--glass-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        position: relative;
    }

    .premium-panel::before {
        content: "";
        position: absolute;
        top: 0; left: 0; right: 0; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    }

    .premium-panel:hover {
        border-color: rgba(255,255,255,0.2);
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    /* PROFILE HEADER WRAPPER */
    .profile-banner {
        height: 100px;
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        position: relative;
    }
    
    .profile-avatar-wrapper {
        position: relative;
        margin-top: -50px;
        margin-bottom: 15px;
    }

    .profile-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent-blue), #1e40af);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: white;
        border: 4px solid #020617;
        box-shadow: 0 0 20px rgba(59, 130, 246, 0.4);
    }

    /* BUTTON GLOW */
    .btn-glow-pink {
        background: linear-gradient(135deg, var(--accent-pink), #ec4899);
        color: white;
        border: none;
        border-radius: 14px;
        font-weight: 800;
        letter-spacing: 0.5px;
        box-shadow: 0 4px 15px var(--accent-pink-glow);
        transition: 0.3s;
    }

    .btn-glow-pink:hover {
        transform: scale(1.02);
        box-shadow: 0 8px 25px var(--accent-pink-glow);
        color: white;
    }

    /* STAT CARD */
    .stat-row {
        background: rgba(255,255,255,0.03);
        padding: 15px;
        border-radius: 16px;
        margin-bottom: 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid transparent;
        transition: 0.3s;
    }

    .stat-row:hover {
        border-color: rgba(255,255,255,0.05);
        background: rgba(255,255,255,0.05);
    }

    .stat-label { color: var(--text-muted); font-size: 0.9rem; }
    .stat-value { font-weight: 800; color: #fff; font-size: 1.1rem; }

    /* TIMELINE */
    .timeline {
        position: relative;
        padding-left: 30px;
    }

    .timeline::before {
        content: "";
        position: absolute;
        left: 7px; top: 0; bottom: 0;
        width: 2px;
        background: rgba(255,255,255,0.05);
    }

    .timeline-item {
        position: relative;
        margin-bottom: 25px;
        animation: fadeInRight 0.5s ease-out forwards;
        opacity: 0;
    }

    .timeline-dot {
        position: absolute;
        left: -30px;
        width: 16px; height: 16px;
        border-radius: 50%;
        background: var(--accent-blue);
        border: 4px solid #020617;
        box-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
        z-index: 2;
    }

    .timeline-content {
        background: rgba(255,255,255,0.02);
        padding: 12px 18px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    /* FAVORITE MINI CARDS */
    .fav-mini-card {
        background: rgba(15, 23, 42, 0.8);
        border-radius: 20px;
        padding: 12px;
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 15px;
        border: 1px solid rgba(255,255,255,0.03);
        transition: 0.3s;
    }

    .fav-mini-card:hover {
        border-color: rgba(255,255,255,0.1);
        background: rgba(30, 41, 59, 0.8);
    }

    .fav-img {
        width: 60px; height: 60px;
        border-radius: 14px;
        object-fit: cover;
    }

    .fav-icon-box {
        width: 60px; height: 60px;
        border-radius: 14px;
        background: #1e293b;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem; color: var(--accent-orange);
    }

    .section-title {
        font-family: 'Anton', sans-serif;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    @keyframes fadeInRight {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard-container">
    <div class="row">
        {# LEFT COLUMN #}
        <div class="col-lg-4">
            {# Profile Card #}
            <div class="premium-panel mb-4">
                <div class="profile-banner"></div>
                <div class="px-4 pb-4 text-center">
                    <div class="d-flex justify-content-center">
                        <div class="profile-avatar-wrapper">
                            <div class="profile-avatar">
                                <i class="fa fa-user"></i>
                            </div>
                        </div>
                    </div>
                    
                    <h2 style="font-family: 'Anton', sans-serif; font-size: 1.8rem; margin-bottom: 5px;">{{ app.user.userIdentifier }}</h2>
                    <div class="mb-4">
                         <span style="color: var(--accent-blue); font-weight: 600; font-size: 0.9rem;">
                            <i class="fa fa-shield mr-1"></i> Explorateur LAMMA
                         </span>
                    </div>

                    <a href="{{ path('app_favori_index') }}" class="btn btn-glow-pink w-100 py-3 mb-4">
                        <i class="fa fa-heart mr-2"></i> MES FAVORIS
                    </a>

                    <div class="text-left mt-4 pt-4" style="border-top: 1px solid rgba(255,255,255,0.05);">
                        <p class="stat-label mb-3" style="font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">STATISTIQUES</p>
                        <div class="stat-row">
                            <span class="stat-label">Participations</span>
                            <span class="stat-value">{{ participations|length }}</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Restaurants</span>
                            <span class="stat-value">{{ restaurantsFavoris|length }}</span>
                        </div>
                        <div class="stat-row">
                            <span class="stat-label">Plats Préférés</span>
                            <span class="stat-value">{{ repasFavoris|length }}</span>
                        </div>
                    </div>
                </div>
            </div>

            {# Recent Activity #}
            <div class="premium-panel p-4">
                <h4 class="section-title mb-4" style="font-size: 1.1rem;">
                    <i class="fa fa-bolt" style="color: var(--accent-blue);"></i> Activité
                </h4>
                <div class="timeline">
                    {% for part in participations %}
                        <div class="timeline-item" style="animation-delay: {{ loop.index0 * 0.1 }}s">
                            <div class="timeline-dot"></div>
                            <div class="timeline-content">
                                <div style="font-size: 0.85rem; font-weight: 700; color: #fff;">Inscription évènement</div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">{{ part.dateInscription|date('d F Y') }}</div>
                            </div>
                        </div>
                    {% else %}
                        <p style="color: var(--text-muted); font-size: 0.85rem;">Aucune activité récente détectée.</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# RIGHT COLUMN #}
        <div class="col-lg-8">
            {# Restaurants Panel #}
            <div class="premium-panel p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="section-title" style="color: var(--accent-orange); margin: 0; font-size: 1.3rem;">
                        <i class="fa fa-heart" style="color: var(--accent-pink);"></i> Mes Restaurants
                    </h3>
                    <a href="{{ path('app_favori_restaurants') }}" class="btn btn-sm" style="background: rgba(249, 115, 22, 0.1); color: var(--accent-orange); border-radius: 12px; font-weight: 700; font-size: 0.75rem; padding: 6px 15px;">
                        VOIR TOUT <i class="fa fa-chevron-right ml-1"></i>
                    </a>
                </div>

                <div class="row">
                    {% for rest in restaurantsFavoris|slice(0, 4) %}
                        <div class="col-md-6">
                            <div class="fav-mini-card">
                                <div class="fav-icon-box">
                                    <i class="fa fa-cutlery"></i>
                                </div>
                                <div style="flex-grow: 1;">
                                    <h5 style="margin: 0; font-weight: 700; font-size: 0.95rem;">{{ rest.nom }}</h5>
                                    <div style="font-size: 0.75rem; color: var(--text-muted);">{{ rest.adresse|length > 30 ? rest.adresse|slice(0, 30) ~ '...' : rest.adresse }}</div>
                                </div>
                                <a href="{{ path('app_restaurant_show', {id: rest.id}) }}" style="color: var(--accent-blue);"><i class="fa fa-arrow-right"></i></a>
                            </div>
                        </div>
                    {% else %}
                        <div class="col-12 text-center py-5">
                            <i class="fa fa-map-o mb-3" style="font-size: 2rem; color: rgba(255,255,255,0.05);"></i>
                            <p style="color: var(--text-muted);">Explorez de nouveaux lieux culinaires !</p>
                            <a href="{{ path('app_restaurant_index') }}" style="color: var(--accent-orange); font-weight: 700; font-size: 0.9rem;">Parcourir <i class="fa fa-external-link ml-1"></i></a>
                        </div>
                    {% endfor %}
                </div>
            </div>

            {# Meals Panel #}
            <div class="premium-panel p-4">
                 <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="section-title" style="color: var(--accent-green); margin: 0; font-size: 1.3rem;">
                        <i class="fa fa-star" style="color: #f59e0b;"></i> Plats Préférés
                    </h3>
                    <a href="{{ path('app_favori_repas') }}" class="btn btn-sm" style="background: rgba(16, 185, 129, 0.1); color: var(--accent-green); border-radius: 12px; font-weight: 700; font-size: 0.75rem; padding: 6px 15px;">
                        VOIR TOUT <i class="fa fa-chevron-right ml-1"></i>
                    </a>
                </div>

                <div class="row">
                    {% for repas in repasFavoris|slice(0, 4) %}
                        <div class="col-md-6">
                            <div class="fav-mini-card">
                                <img src="{{ repas.imageUrl ? repas.imageUrl : 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=100' }}" class="fav-img">
                                <div style="flex-grow: 1;">
                                    <h5 style="margin: 0; font-weight: 700; font-size: 0.95rem;">{{ repas.nom }}</h5>
                                    <div style="font-size: 0.75rem; color: var(--accent-green); font-weight: 600;">{{ repas.prix }} €</div>
                                </div>
                                <a href="{{ path('app_repas_detaille_show', {id: repas.id}) }}" style="color: var(--accent-blue);"><i class="fa fa-arrow-right"></i></a>
                            </div>
                        </div>
                    {% else %}
                        <div class="col-12 text-center py-5">
                             <i class="fa fa-coffee mb-3" style="font-size: 2rem; color: rgba(255,255,255,0.05);"></i>
                            <p style="color: var(--text-muted);">Découvrez des saveurs exceptionnelles.</p>
                            <a href="{{ path('app_repas_catalogue') }}" style="color: var(--accent-green); font-weight: 700; font-size: 0.9rem;">Voir le menu <i class="fa fa-external-link ml-1"></i></a>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
