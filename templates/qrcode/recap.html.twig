{% extends is_pdf|default(false) ? 'qrcode/pdf_base.html.twig' : 'base.html.twig' %}

{% block title %}Bordereau Logistique : {{ equipement.nom }}{% endblock %}

{% block stylesheets %}
{% if not is_pdf|default(false) %}
    {{ parent() }}
{% endif %}
<style>
    .recap-wrapper { background: #fff; color: #1e293b; padding: 2rem; border-radius: 8px; max-width: 800px; margin: 2rem auto; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); }
    .recap-header { border-bottom: 2px solid #F97316; padding-bottom: 1.5rem; margin-bottom: 2rem; }
    .header-table { width: 100%; }
    .header-table td { vertical-align: middle; }
    .recap-header h1 { margin: 0; font-family: 'Anton', sans-serif; font-size: 1.75rem; color: #1e3c72; }
    .section-title { font-size: 0.9rem; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; margin: 2rem 0 1rem; }
    .data-table { width: 100%; border-collapse: separate; border-spacing: 0 1rem; }
    .data-table td { padding: 0.5rem; border-bottom: 1px solid #f1f5f9; width: 50%; vertical-align: top; }
    .data-label { font-size: 0.8rem; color: #94a3b8; margin-bottom: 0.2rem; }
    .data-val { font-weight: 700; color: #1e293b; font-size: 0.95rem; }
    .status-badge-pdf { background: #f8fafc; border: 1px solid #e2e8f0; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 700; }
</style>
{% endblock %}

{% block body %}

<div class="container py-4">
    <div class="recap-wrapper">
        <div class="recap-header">
            <table class="header-table">
                <tr>
                    <td>
                        <h1>BORDEREAU D'EXPÉDITION</h1>
                        <div style="font-size: 0.8rem; color: #64748b;">Généré par LAMMA AI Logistics le {{ 'now'|date('d/m/Y H:i') }}</div>
                    </td>
                    <td style="text-align: right;">
                        <div style="color: #F97316; font-weight: 900; font-size: 1.2rem;">#{{ equipement.id }}</div>
                        <div style="font-size: 0.7rem; color: #94a3b8;">RÉFÉRENCE UNIQUE</div>
                    </td>
                </tr>
            </table>
        </div>

        <div class="section-title">📦 Informations Matériel</div>
        <table class="data-table">
            <tr>
                <td><div class="data-label">Nom de l'article</div><div class="data-val">{{ equipement.nom }}</div></td>
                <td><div class="data-label">Catégorie</div><div class="data-val">{{ equipement.categorie|default('—') }}</div></td>
            </tr>
            <tr>
                <td><div class="data-label">Prix unitaire</div><div class="data-val">{{ equipement.prix|number_format(2, ',', ' ') }} TND</div></td>
                <td><div class="data-label">Vendeur</div><div class="data-val">{{ equipement.owner.name|default(equipement.owner.email) }}</div></td>
            </tr>
        </table>

        <div class="section-title">💳 Transaction Financière</div>
        {% if transaction %}
            <table class="data-table">
                <tr>
                    <td><div class="data-label">Montant Payé</div><div class="data-val" style="color:#10b981;">{{ transaction.price }} TND</div></td>
                    <td><div class="data-label">Date de paiement</div><div class="data-val">{{ transaction.createdAt|date('d/m/Y H:i') }}</div></td>
                </tr>
                <tr>
                    <td><div class="data-label">ID Transaction (Stripe)</div><div class="data-val" style="font-family: monospace; font-size:0.75rem;">{{ transaction.stripeToken|slice(0, 20) }}...</div></td>
                    <td><div class="data-label">Acheteur</div><div class="data-val">{{ transaction.buyer.name|default(transaction.buyer.email) }}</div></td>
                </tr>
            </table>
        {% else %}
            <p style="color: #ef4444; font-weight: 700; font-size: 0.85rem;">En attente de règlement bancaire.</p>
        {% endif %}

        <div class="section-title">🚚 Détails Logistiques</div>
        {% if delivery %}
            <table class="data-table">
                <tr>
                    <td><div class="data-label">Statut Actuel</div><div class="data-val"><span class="status-badge-pdf">{{ delivery.statut|replace({'en_attente':'Attente','confirmee':'Confirmé','preparation':'Préparation','expediee':'Expédié','en_cours':'Transit','livree':'Livré'}) }}</span></div></td>
                    <td><div class="data-label">Estimation Arrivée (IA)</div><div class="data-val">{{ delivery.estimation ? delivery.estimation|date('d/m/Y') : '—' }}</div></td>
                </tr>
                <tr>
                    <td colspan="2">
                        <div class="data-label">Adresse de livraison</div>
                        <div class="data-val">{{ [delivery.rue, delivery.ville, delivery.codePostal]|filter(v => v)|join(', ') }}</div>
                    </td>
                </tr>
            </table>
        {% else %}
            <p style="color: #64748b; font-size: 0.85rem;">Aucune demande de livraison active.</p>
        {% endif %}

        <div style="margin-top: 3rem; text-align: center; border-top: 1px dotted #cbd5e1; padding-top: 1rem; color: #94a3b8; font-size: 0.75rem;">
            LAMMA - Plateforme Collaborative d'Équipements de Camping
        </div>

        {% if not is_pdf|default(false) %}
            <div class="text-center mt-5">
                <a href="{{ path('app_qrcode_recap_pdf', {id: equipement.id}) }}" class="btn btn-dark rounded-pill px-4">
                    <i class="fa fa-file-pdf me-2"></i>Télécharger en PDF
                </a>
            </div>
        {% endif %}
    </div>
</div>


{% endblock %}
