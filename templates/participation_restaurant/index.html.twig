{% extends 'base.html.twig' %}
{% import '_macros.html.twig' as macros %}

{% block title %}Part. Restaurant - LAMMA{% endblock %}
{% block page_title %}Participations Restaurant{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 style="font-family:'Anton',sans-serif;">Suivi Restauration</h2>
            <a href="{{ path('app_participation_restaurant_new') }}" class="btn btn-add"><i class="fa fa-plus"></i> Nouveau Suivi</a>
        </div>
        <div class="card card-detail">
            <div class="card-body p-0">
                {% set columns = [
                    {label: 'ID', field: 'id'},
                    {label: 'Participant', field: 'participantId'},
                    {label: 'Besoin', field: 'besoinLibelle'},
                    {label: 'Restriction', field: 'restrictionLibelle'},
                    {label: 'Gravité', field: 'niveauGravite', badge: true},
                    {label: 'Annulé', field: 'annule', bool: true}
                ] %}
                {{ macros.crud_table(items, columns, 'ParticipationRestaurant', 'app_participation_restaurant') }}
            </div>
        </div>
    </div>
</section>
{% endblock %}
