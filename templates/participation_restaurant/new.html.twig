{% extends 'base.html.twig' %}

{% block title %}Nouveau Suivi Restaurant - LAMMA{% endblock %}
{% block page_title %}Ajouter une Participation Restaurant{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="fiche-card">
                    <div class="fiche-header text-uppercase">
                        <i class="fa fa-users mr-2"></i> FICHE D'INFORMATION RESTRICTION RESTAURANT
                    </div>
                    <div class="fiche-body">
                        {{ form_start(form) }}
                            <button class="btn btn-add">Enregistrer</button>
                            <a href="{{ path('app_participation_restaurant_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
