{% extends 'base.html.twig' %}

{% block title %}Détails Suivi - LAMMA{% endblock %}
{% block page_title %}Consultation Restauration{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card card-detail">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fa fa-cutlery"></i> Besoins Participant #{{ item.participantId }}</span>
                        <span class="badge badge-status badge-{{ item.annule ? 'expire' : 'actif' }}">{{ item.annule ? 'ANNULÉ' : 'CONFIRMÉ' }}</span>
                    </div>
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <h6>Besoin : {{ item.besoinLibelle }}</h6>
                                <p class="text-muted">{{ item.besoinDescription ?? 'Sans description.' }}</p>
                            </div>
                            <div class="col-md-6">
                                <h6>Restriction : {{ item.restrictionLibelle }} <span class="badge badge-{{ item.niveauGravite == 'SEVERE' ? 'danger' : 'warning' }}">{{ item.niveauGravite }}</span></h6>
                                <p class="text-muted">{{ item.restrictionDescription ?? '-' }}</p>
                            </div>
                        </div>
                        <table class="table table-sm">
                            <tr><th>Événement ID</th><td>{{ item.evenementId }}</td></tr>
                            <tr><th>Menu Proposé ID</th><td>{{ item.menuPropositionId ?? 'Aucun' }}</td></tr>
                            <tr><th>Restriction Active</th><td>{{ item.restrictionActive ? 'Oui' : 'Non' }}</td></tr>
                            <tr><th>Dernière Maj</th><td>{{ item.dateMiseAJour|date('d/m/Y H:i') }}</td></tr>
                        </table>
                        <div class="mt-4">
                            <strong>Commentaire :</strong>
                            <p class="p-3 bg-light rounded">{{ item.commentaire ?? 'Aucun commentaire.' }}</p>
                        </div>
                        <div class="mt-4 text-center">
                            <a href="{{ path('app_participation_restaurant_edit', {id: item.id}) }}" class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">Modifier</a>
                            <a href="{{ path('app_participation_restaurant_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Retour</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
