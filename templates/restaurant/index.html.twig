{% extends 'admin/base_admin.html.twig' %}
{% import '_macros.html.twig' as macros %}

{% block title %}Restaurants - LAMMA{% endblock %}
{% block admin_title %}Logistique Culinaire{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        #global-map {
            height: 450px;
            width: 100%;
            border-radius: 20px;
            margin-bottom: 40px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 15px 45px rgba(0,0,0,0.5);
            z-index: 10;
        }

        .restaurant-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 25px;
        }

        .restaurant-card {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 20px;
            transition: 0.3s;
            color: #fff;
        }

        .restaurant-card:hover {
            transform: translateY(-5px);
            background: rgba(30, 41, 59, 0.6);
            border-color: #3b82f6;
        }

        .card-title {
            font-family: 'Anton', sans-serif;
            font-size: 1.25rem;
            color: #f97316;
            margin-bottom: 12px;
            text-transform: uppercase;
        }

        .card-meta {
            font-size: 0.85rem;
            color: #94a3b8;
            margin-bottom: 15px;
        }

        .card-meta span { display: block; margin-bottom: 5px; }
        .card-meta i { color: #3b82f6; width: 22px; } /* Blue location icon */

        .btn-view-map {
            background: rgba(59, 130, 246, 0.1);
            color: #3b82f6;
            border: 1px solid #3b82f6;
            padding: 10px;
            border-radius: 12px;
            font-weight: 800;
            width: 100%;
            text-transform: uppercase;
            font-size: 0.75rem;
            transition: 0.3s;
        }
        .btn-view-map:hover { background: #3b82f6; color: #fff; }
    </style>
{% endblock %}

{% block admin_content %}
<section class="crud-section">
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h2 style="font-family:'Anton',sans-serif;color: #fff; margin: 0;">Réseau des Établissements</h2>
            <div style="font-size: 0.85rem; color: #94a3b8; font-weight: 700;">Localisation stratégique des points de ravitaillement</div>
        </div>
        <div class="col-md-6 text-right">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_restaurant_new') }}" class="btn-scout-confirm" style="padding: 10px 25px;"><i class="fa fa-plus"></i> NOUVEAU RESTAURANT</a>
            {% endif %}
        </div>
    </div>

    {# Single Global Map #}
    <div id="global-map"></div>

    <div class="restaurant-grid">
        {% for entity in items %}
            <div class="restaurant-card">
                <div class="d-flex justify-content-between align-items-start">
                    <h3 class="card-title">{{ entity.nom }}</h3>
                    <div style="color: #f1c40f;"><i class="fa fa-star"></i> {{ entity.rating }}</div>
                </div>
                
                <div class="card-meta">
                    <span><i class="fa fa-map-marker"></i> {{ entity.adresse|default('Position non certifiée') }}</span>
                    <span><i class="fa fa-phone"></i> {{ entity.telephone|default('N/A') }}</span>
                    <span><i class="fa fa-users"></i> {{ entity.nombrePlaces }} places</span>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn-view-map" onclick="focusOnMap({{ entity.latitude|default(0) }}, {{ entity.longitude|default(0) }}, '{{ entity.nom|escape('js') }}')">
                        <i class="fa fa-crosshairs"></i> Localiser
                    </button>
                    <a href="{{ path('app_restaurant_show', {id: entity.id}) }}" class="btn-view-map" style="border-color: #94a3b8; color: #94a3b8;">
                        Profil
                    </a>
                    {% if is_granted('ROLE_USER') %}
                        {% set isFavorite = entity.id in (favorite_ids|default([])) %}
                        <button class="btn-favorite" data-type="RESTAURANT" data-id="{{ entity.id }}" 
                                style="background: {{ isFavorite ? 'rgba(255,0,90,0.3)' : 'rgba(255,0,90,0.1)' }}; border: 1px solid rgba(255,0,90,0.3); color: #ff005a; border-radius: 12px; padding: 10px; transition: 0.3s; width: 45px; cursor: pointer;">
                            <i class="fa {{ isFavorite ? 'fa-heart' : 'fa-heart-o' }}"></i>
                        </button>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    console.log("Favorite buttons initialized");
    const favoriteBtns = document.querySelectorAll('.btn-favorite');
    favoriteBtns.forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            const type = this.getAttribute('data-type');
            const id = this.getAttribute('data-id');
            const icon = this.querySelector('i');
            
            fetch("{{ path('app_favori_toggle') }}", {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ type: type, id: id })
            })
            .then(res => res.json())
            .then(data => {
                if (data.active) {
                    icon.classList.remove('fa-heart-o');
                    icon.classList.add('fa-heart');
                    this.style.background = 'rgba(255,0,90,0.3)';
                } else {
                    icon.classList.remove('fa-heart');
                    icon.classList.add('fa-heart-o');
                    this.style.background = 'rgba(255,0,90,0.1)';
                }
            })
            .catch(err => console.error("Error toggling favorite:", err));
        });
    });
});
</script>
{% endblock %}

{% block javascripts %}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        let map;
        const markers = {};

        document.addEventListener('DOMContentLoaded', function() {
            // Initialize Map
            map = L.map('global-map').setView([36.8065, 10.1815], 12);

            // Dark Theme Tiles
            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap',
                maxZoom: 20
            }).addTo(map);

            // Blue Marker Icon
            const blueIcon = L.icon({
                iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-blue.png',
                shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
                iconSize: [25, 41],
                iconAnchor: [12, 41],
                popupAnchor: [1, -34],
                shadowSize: [41, 41]
            });

            const bounds = [];
            {% for rest in items %}
                {% if rest.latitude and rest.longitude %}
                    const m = L.marker([{{ rest.latitude }}, {{ rest.longitude }}], {icon: blueIcon})
                        .addTo(map)
                        .bindPopup('<b style="color:#000;">{{ rest.nom|escape('js') }}</b>');
                    
                    markers["{{ rest.id }}"] = m;
                    bounds.push([{{ rest.latitude }}, {{ rest.longitude }}]);
                {% endif %}
            {% endfor %}

            if (bounds.length > 0) {
                map.fitBounds(bounds, { padding: [50, 50] });
            }
        });

        function focusOnMap(lat, lng, name) {
            if (lat === 0 || lng === 0) return;
            map.setView([lat, lng], 16);
            window.scrollTo({ top: document.getElementById('global-map').offsetTop - 100, behavior: 'smooth' });
            
            // Open popup
            for(let id in markers) {
                if(markers[id].getLatLng().lat === lat && markers[id].getLatLng().lng === lng) {
                    markers[id].openPopup();
                }
            }
        }
    </script>
{% endblock %}
