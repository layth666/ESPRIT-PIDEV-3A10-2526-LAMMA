{% extends 'base.html.twig' %}

{% block title %}Détails Restaurant - LAMMA{% endblock %}
{% block page_title %}{{ item.nom }}{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card card-detail overflow-hidden mb-4">
                    {% if item.imageUrl %}
                        <img src="{{ item.imageUrl }}" class="card-img-top" alt="{{ item.nom }}" style="max-height: 350px; object-fit: cover;">
                    {% endif %}
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fa fa-cutlery"></i> Fiche Restaurant</span>
                        <div>
                            <span class="badge badge-status badge-{{ item.isOpen ? 'actif' : 'expire' }}">{{ item.isOpen ? 'OUVERT' : 'FERMÉ' }}</span>
                            <span class="badge badge-status badge-{{ item.actif ? 'actif' : 'expire' }} ml-2">{{ item.actif ? 'ACTIF' : 'INACTIF' }}</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-8">
                                <h3>{{ item.nom }}</h3>
                                <p class="text-muted"><i class="fa fa-map-marker"></i> {{ item.adresse }}</p>
                                <p class="text-warning"><i class="fa fa-star"></i> {{ item.rating }}/5.0 (Note globale)</p>
                            </div>
                            <div class="col-md-4 text-right">
                                <h4 class="text-info">{{ item.nombrePlaces }} places</h4>
                                <p class="small text-muted">Créé le {{ item.dateCreation|date('d/m/Y') }}</p>
                            </div>
                        </div>
                        <div class="mb-4">
                            <h5>Description</h5>
                            <p>{{ item.description ?? 'Pas de description fournie.' }}</p>
                        </div>
                        <div class="row">
                            <div class="col-md-6"><p><strong>Téléphone :</strong> {{ item.telephone ?? 'N/A' }}</p></div>
                            <div class="col-md-6"><p><strong>Email :</strong> <a href="mailto:{{ item.email }}">{{ item.email ?? 'N/A' }}</a></p></div>
                        </div>
                        <div class="mt-4 text-center">
                            <a href="{{ path('app_restaurant_edit', {id: item.id}) }}" class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">Modifier</a>
                            <a href="{{ path('app_restaurant_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Retour</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
