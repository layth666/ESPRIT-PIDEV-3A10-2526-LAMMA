{% extends 'base.html.twig' %}

{% block title %}Détails Restaurant - LAMMA{% endblock %}
{% block page_title %}{{ item.nom }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    .card-detail { background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 20px; color: #fff; }
    #show-map { height: 350px; width: 100%; border-radius: 15px; margin-top: 25px; border: 2px solid #3b82f6; }
    .badge-status.badge-actif { background: #10b981; color: white; }
    .badge-status.badge-expire { background: #ef4444; color: white; }
</style>
{% endblock %}

{% block body %}
<section class="crud-section pt-5 pb-5" style="background: #0b0f1a; min-height: 100vh;">
    <div class="container">
        <div class="row">
            <div class="col-lg-9 mx-auto">
                <div class="card card-detail overflow-hidden shadow-lg">
                    <div class="row no-gutters">
                        <div class="col-md-5">
                            {% if item.imageUrl %}
                                <img src="{{ item.imageUrl }}" class="h-100 w-100" alt="{{ item.nom }}" style="object-fit: cover; min-height: 400px;">
                            {% else %}
                                <div class="h-100 w-100 d-flex align-items-center justify-content-center bg-dark text-muted">
                                    <i class="fa fa-image fa-4x"></i>
                                </div>
                            {% endif %}
                        </div>
                        <div class="col-md-7">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="text-blue font-weight-bold"><i class="fa fa-compass"></i> ÉTABLISSEMENT CERTIFIÉ</span>
                                    <span class="badge badge-status badge-{{ item.actif ? 'actif' : 'expire' }}">{{ item.actif ? 'ACTIF' : 'INACTIF' }}</span>
                                </div>
                                <h1 style="font-family: 'Anton', sans-serif; color: #f97316; font-size: 2.5rem;">{{ item.nom }}</h1>
                                <p class="text-muted mb-4"><i class="fa fa-map-marker text-blue"></i> {{ item.adresse }}</p>
                                
                                <div class="row mb-4">
                                    <div class="col-6">
                                        <div class="small text-muted uppercase">Qualité</div>
                                        <div class="h4 text-warning"><i class="fa fa-star"></i> {{ item.rating }}/5</div>
                                    </div>
                                    <div class="col-6">
                                        <div class="small text-muted uppercase">Capacité</div>
                                        <div class="h4 text-info"><i class="fa fa-users"></i> {{ item.nombrePlaces }} places</div>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <h5 class="text-blue">Description de la Mission</h5>
                                    <p class="text-secondary" style="font-size: 0.95rem;">{{ item.description ?? 'Aucune description stratégique fournie.' }}</p>
                                </div>

                                <div class="row mb-4">
                                    <div class="col-sm-6"><i class="fa fa-phone text-blue mr-2"></i> {{ item.telephone ?? 'N/A' }}</div>
                                    <div class="col-sm-6"><i class="fa fa-envelope text-blue mr-2"></i> {{ item.email ?? 'N/A' }}</div>
                                </div>

                                {% if item.latitude and item.longitude %}
                                    <h5 class="text-blue mt-4"><i class="fa fa-map"></i> Localisation Précise (Bleu)</h5>
                                    <div id="show-map" 
                                         data-lat="{{ item.latitude }}" 
                                         data-lng="{{ item.longitude }}"
                                         data-name="{{ item.nom|escape('js') }}"></div>
                                {% endif %}

                                <div class="mt-5 d-flex gap-3">
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <a href="{{ path('app_restaurant_edit', {id: item.id}) }}" class="btn btn-warning px-4">Modifier</a>
                                    {% endif %}
                                    <a href="{{ path('app_restaurant_index') }}" class="btn btn-outline-light px-4">Retour au Réseau</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% if item.latitude and item.longitude %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const el = document.getElementById('show-map');
        const lat = parseFloat(el.getAttribute('data-lat'));
        const lng = parseFloat(el.getAttribute('data-lng'));
        
        const map = L.map('show-map').setView([lat, lng], 15);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { maxZoom: 20 }).addTo(map);

        const blueIcon = L.icon({
            iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-blue.png',
            shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
            iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], shadowSize: [41, 41]
        });

        L.marker([lat, lng], {icon: blueIcon}).addTo(map).bindPopup('<b>{{ item.nom|escape('js') }}</b><br>Emplacement certifié.');
    });
</script>
{% endif %}
{% endblock %}
