{% extends 'base.html.twig' %}
{% import '_macros.html.twig' as macros %}

{% block title %}Restauration - LAMMA{% endblock %}
{% block page_title %}Gestion Restauration Globale{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 style="font-family:'Anton',sans-serif;">Toutes les Opérations</h2>
            <a href="{{ path('app_restauration_new') }}" class="btn btn-add"><i class="fa fa-plus"></i> Nouvelle Opération</a>
        </div>
        <div class="card card-detail">
            <div class="card-body p-0">
                {% set columns = [
                    {label: 'ID', field: 'id'},
                    {label: 'Type', field: 'type', badge: true},
                    {label: 'Nom', field: 'nom'},
                    {label: 'Prix', field: 'prix'},
                    {label: 'Date', field: 'date', date: true},
                    {label: 'Actif', field: 'actif', bool: true}
                ] %}
                {{ macros.crud_table(items, columns, 'Restauration', 'app_restauration') }}
            </div>
        </div>
    </div>
</section>
{% endblock %}
