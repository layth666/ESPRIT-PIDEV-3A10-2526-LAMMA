{% extends 'base.html.twig' %}

{% block title %}Détails Restauration - LAMMA{% endblock %}
{% block page_title %}Consultation Opération{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card card-detail">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fa fa-info-circle"></i> Fiche Opération </span>
                        <span class="badge badge-status badge-{{ item.actif ? 'actif' : 'expire' }}">{{ item.actif ? 'ACTIF' : 'INACTIF' }}</span>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h3>{{ item.nom ?? 'N/A' }}</h3>
                                <p class="text-pink h4" style="color:#fb246a;">{{ item.prix ?? '0' }} €</p>
                                <span class="badge badge-info">{{ item.type }}</span>
                            </div>
                            <div class="col-md-6 text-right">
                                <p><strong>Date :</strong> {{ item.date ? item.date|date('d/m/Y') : '-' }}</p>
                                <p><strong>Présence :</strong> {{ item.datePresence ? item.datePresence|date('d/m/Y') : '-' }}</p>
                            </div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Libellé :</strong> {{ item.libelle ?? '-' }}</p>
                                <p><strong>Type Événement :</strong> {{ item.typeEvenement ?? '-' }}</p>
                                <p><strong>Nom Repas :</strong> {{ item.nomRepas ?? '-' }}</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Participant ID :</strong> {{ item.participantId ?? '-' }}</p>
                                <p><strong>Événement ID :</strong> {{ item.evenementId ?? '-' }}</p>
                                <p><strong>Abonnement :</strong> {{ item.abonnementActif ? 'Actif' : 'Non' }}</p>
                            </div>
                        </div>
                        <hr>
                        <div class="mb-4">
                            <h5>Restriction : {{ item.restrictionLibelle ?? 'Aucune' }}</h5>
                            <p class="p-3 bg-light rounded">{{ item.restrictionDescription ?? '-' }}</p>
                        </div>
                        <div class="mt-4 text-center">
                            <a href="{{ path('app_restauration_edit', {id: item.id}) }}" class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">Modifier</a>
                            <a href="{{ path('app_restauration_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Retour</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
