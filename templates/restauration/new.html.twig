{% extends 'base.html.twig' %}

{% block title %}Nouvelle Opération Restauration - LAMMA{% endblock %}
{% block page_title %}Ajouter une Restauration{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="fiche-card">
                    <div class="fiche-header text-uppercase">
                        <i class="fa fa-truck mr-2"></i> FICHE D'INFORMATION RESTAURATION
                    </div>
                    <div class="fiche-body">
                        {{ form_start(form) }}
                        <div class="mt-4 text-center">
                            <button class="btn btn-add">Enregistrer l'Opération</button>
                            <a href="{{ path('app_restauration_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
