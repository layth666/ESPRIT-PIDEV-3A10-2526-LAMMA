{% extends 'base.html.twig' %}

{% block title %}Modifier Restauration - LAMMA{% endblock %}
{% block page_title %}Édition Restauration{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card card-detail">
                    <div class="card-header">Mise à jour Dossier </div>
                    <div class="card-body form-section">
                        {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.type) }}</div>
                            <div class="col-md-6">{{ form_row(form.nom) }}</div>
                            <div class="col-md-6">{{ form_row(form.prix) }}</div>
                            <div class="col-md-6">{{ form_row(form.date) }}</div>
                            <div class="col-md-6">{{ form_row(form.libelle) }}</div>
                            <div class="col-md-6">{{ form_row(form.typeEvenement) }}</div>
                            <div class="col-12">{{ form_row(form.nomRepas) }}</div>
                            <div class="col-md-6">{{ form_row(form.restrictionLibelle) }}</div>
                            <div class="col-md-6">{{ form_row(form.datePresence) }}</div>
                            <div class="col-md-4">{{ form_row(form.participantId) }}</div>
                            <div class="col-md-4">{{ form_row(form.evenementId) }}</div>
                            <div class="col-md-4" style="padding-top:30px;">{{ form_row(form.actif) }}</div>
                            <div class="col-md-6" style="padding-top:30px;">{{ form_row(form.abonnementActif) }}</div>
                            <div class="col-12">{{ form_row(form.restrictionDescription) }}</div>
                        </div>
                        <div class="mt-4 text-center">
                            <button class="btn btn-add">Mettre à jour</button>
                            <a href="{{ path('app_restauration_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
