{% extends 'base.html.twig' %}

{% block title %}Modifier Ingrédient - LAMMA{% endblock %}
{% block page_title %}Modifier {{ item.nom }}{% endblock %}
{% block page_subtitle %}Modifier les paramètres de l'ingrédient{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card card-detail">
                    <div class="card-header"><i class="fa fa-edit"></i> Modification d'Ingrédient</div>
                    <div class="card-body form-section">
                        {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.nom) }}</div>
                            <div class="col-md-6">{{ form_row(form.categorie) }}</div>
                            <div class="col-md-6">{{ form_row(form.prixSupplement) }}</div>
                            <div class="col-md-6">{{ form_row(form.calories) }}</div>
                            <div class="col-md-6">{{ form_row(form.stockQuantite) }}</div>
                            <div class="col-md-6">{{ form_row(form.stockSeuilAlerte) }}</div>
                            <div class="col-md-6">{{ form_row(form.iconUrl) }}</div>
                            <div class="col-md-6" style="padding-top: 30px;">{{ form_row(form.actif) }}</div>
                        </div>
                        <div class="mt-4 text-center">
                            <button class="btn btn-add">Mettre à jour</button>
                            <a href="{{ path('app_ingredient_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
