{% extends 'base.html.twig' %}

{% block title %}Modifier Post — Blog{% endblock %}

{% block hero %}
<div class="bradcam_area">
    <div class="single_bradcam d-flex align-items-center bradcam_bg_1 overlay">
        <div class="container">
            <div class="row align-items-center justify-content-center">
                <div class="col-xl-12">
                    <div class="bradcam_text text-center">
                        <h3>Modifier le Post</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
    .error-message { color:#dc3545; font-size:13px; margin-top:4px; }
    .has-error input, .has-error textarea { border-color:#dc3545 !important; }
</style>
{% endblock %}

{% block body %}
<section class="blog_area section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div style="background:white; padding:35px; border-radius:8px; box-shadow:0 2px 15px rgba(0,0,0,0.05);">

                    <h4 style="color:#1a2f45; font-weight:700; margin-bottom:20px;">
                        <i class="fa fa-pencil" style="color:#f09000;"></i> Éditer le post
                    </h4>

                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger" style="margin-bottom:15px;">{{ message }}</div>
                    {% endfor %}
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success" style="margin-bottom:15px;">{{ message }}</div>
                    {% endfor %}

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="form-group mb-3 {% if form.title.vars.errors|length > 0 %}has-error{% endif %}">
                        <label style="font-weight:700; color:#1a2f45; margin-bottom:6px; display:block;">Titre</label>
                        {{ form_widget(form.title, {'attr': {
                            'class': 'form-control',
                            'style': 'border-radius:4px; padding:10px; border:1px solid #ddd;'
                        }}) }}
                        {% if form.title.vars.errors|length > 0 %}
                            <div class="error-message">{{ form_errors(form.title) }}</div>
                        {% endif %}
                    </div>

                    <div class="form-group mb-4 {% if form.content.vars.errors|length > 0 %}has-error{% endif %}">
                        <label style="font-weight:700; color:#1a2f45; margin-bottom:6px; display:block;">Contenu</label>
                        {{ form_widget(form.content, {'attr': {
                            'class': 'form-control',
                            'rows': 10,
                            'style': 'border-radius:4px; padding:10px; border:1px solid #ddd;'
                        }}) }}
                        {% if form.content.vars.errors|length > 0 %}
                            <div class="error-message">{{ form_errors(form.content) }}</div>
                        {% endif %}
                    </div>

                    <div style="display:flex; gap:12px; align-items:center;">
                        <button type="submit" class="boxed-btn3">Mettre à jour</button>
                        <a href="{{ path('app_post_index') }}" style="color:#888; font-size:14px;">← Retour au Blog</a>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
{% include 'partials/word_predictor.html.twig' %}
{% endblock %}
