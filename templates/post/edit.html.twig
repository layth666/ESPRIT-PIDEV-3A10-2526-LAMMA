<!doctype html>
<html class="no-js" lang="zxx">
<head>
    <meta charset="utf-8">
    <title>Edit Post</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="{{ asset('css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('css/font-awesome.min.css') }}">
    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
     <link rel="stylesheet" href="{{ asset('css/word-predictor.css') }}">
     {{ include('partials/word_predictor.html.twig') }}
    <style>
        .error-message { color: #dc3545; font-size: 14px; margin-top: 5px; }
        .alert-error { background-color: #f8d7da; color: #721c24; padding: 12px; border-radius: 4px; margin-bottom: 20px; border: 1px solid #f5c6cb; }
        .form-group.has-error input, .form-group.has-error textarea { border-color: #dc3545; }
    </style>
</head>
<body>

<header>
    <div class="header-area">
        <div id="sticky-header" class="main-header-area">
            <div class="container">
                <div class="header_bottom_border">
                    <div class="row align-items-center">
                        <div class="col-xl-3 col-lg-3">
                            <div class="logo">
                                <a href="/post"><img src="{{ asset('img/logo.png') }}" alt="logo"></a>
                            </div>
                        </div>
                        <div class="col-xl-6 col-lg-6">
                            <div class="main-menu d-none d-lg-block">
                                <nav>
                                    <ul id="navigation">
                                        <li><a href="/post">Posts</a></li>
                                    </ul>
                                </nav>
                            </div>
                        </div>
                        <div class="col-xl-3 col-lg-3 d-none d-lg-block">
                            <div class="buy_tkt">
                                <div class="book_btn d-none d-lg-block">
                                    <a href="{{ path('app_post_new') }}">New Post</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<div class="bradcam_area">
    <div class="single_bradcam d-flex align-items-center bradcam_bg_1 overlay">
        <div class="container">
            <div class="row align-items-center justify-content-center">
                <div class="col-xl-12">
                    <div class="bradcam_text text-center">
                        <h3>Edit Post</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="blog_area section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="blog_left_sidebar" style="background:white;padding:30px;border-radius:6px;">

                    <!-- Display flash messages -->
                    {% for message in app.flashes('error') %}
                        <div class="alert-error">{{ message }}</div>
                    {% endfor %}

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="form-group mb-3 {% if form.title.vars.errors|length > 0 %}has-error{% endif %}">
                        <label style="font-weight:bold;color:#1a2f45;">Title</label>
                        {{ form_widget(form.title, {'attr': {'class': 'form-control', 'style': 'border-radius:4px;padding:10px;'}}) }}
                        {% if form.title.vars.errors|length > 0 %}
                            <div class="error-message">
                                {{ form_errors(form.title) }}
                            </div>
                        {% endif %}
                    </div>

                    <div class="form-group mb-4 {% if form.content.vars.errors|length > 0 %}has-error{% endif %}">
                        <label style="font-weight:bold;color:#1a2f45;">Content</label>
                        {{ form_widget(form.content, {'attr': {'class': 'form-control', 'rows': 6, 'style': 'border-radius:4px;padding:10px;'}}) }}
                        {% if form.content.vars.errors|length > 0 %}
                            <div class="error-message">
                                {{ form_errors(form.content) }}
                            </div>
                        {% endif %}
                    </div>

                    <button type="submit" class="boxed-btn3">Update Post</button>
                    <a href="{{ path('app_post_index') }}" style="margin-left:15px;color:#888;">Cancel</a>

                    {{ form_end(form) }}

                </div>
            </div>
        </div>
    </div>
</section>

<footer class="footer">
    <div class="copy-right_text">
        <div class="container">
            <div class="row">
                <div class="col-xl-12">
                    <p class="copy_right text-center">Copyright &copy; 2026 All rights reserved</p>
                </div>
            </div>
        </div>
    </div>
</footer>

<script src="{{ asset('js/vendor/jquery-1.12.4.min.js') }}"></script>
<script src="{{ asset('js/bootstrap.min.css') }}"></script>
<script src="{{ asset('js/main.js') }}"></script>
<script src="{{ asset('js/word-predictor.js') }}"></script>

</body>
</html>