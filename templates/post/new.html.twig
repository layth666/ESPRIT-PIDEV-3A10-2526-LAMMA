{% extends 'base.html.twig' %}

{% block title %}Nouveau Post — Blog{% endblock %}

{% block hero %}
<div class="bradcam_area">
    <div class="single_bradcam d-flex align-items-center bradcam_bg_1 overlay">
        <div class="container">
            <div class="row align-items-center justify-content-center">
                <div class="col-xl-12">
                    <div class="bradcam_text text-center">
                        <h3>Créer un Post</h3>
                        <p>Partagez vos idées avec la communauté</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
    .ai-badge { background:linear-gradient(135deg,#667eea,#764ba2); color:white; padding:4px 14px; border-radius:20px; font-size:12px; display:inline-flex; align-items:center; gap:5px; margin-bottom:12px; }
    .suggestion-hint { background:#f8f9fa; padding:8px 12px; border-radius:6px; font-size:12px; color:#666; margin-top:8px; display:flex; gap:15px; flex-wrap:wrap; }
    .suggestion-hint kbd { background:#f0f0f0; padding:2px 6px; border-radius:4px; font-family:monospace; font-size:11px; }
</style>
{% endblock %}

{% block body %}
<section class="blog_area section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div style="background:white; padding:35px; border-radius:8px; box-shadow:0 2px 15px rgba(0,0,0,0.05);">

                    <div class="ai-badge"><i class="fa fa-magic"></i> AI Word Predictor Actif</div>

                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger" style="margin-bottom:15px;">{{ message }}</div>
                    {% endfor %}
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success" style="margin-bottom:15px;">{{ message }}</div>
                    {% endfor %}

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="form-group mb-3">
                        <label style="font-weight:700; color:#1a2f45; margin-bottom:6px; display:block;">Titre du post</label>
                        {{ form_widget(form.title, {'attr': {'class': 'form-control', 'style': 'border-radius:4px; padding:10px; border:1px solid #ddd;'}}) }}
                        {{ form_errors(form.title) }}
                    </div>

                    <div class="form-group mb-4">
                        <label style="font-weight:700; color:#1a2f45; margin-bottom:6px; display:block;">Contenu</label>
                        {{ form_widget(form.content, {'attr': {
                            'class': 'form-control',
                            'rows': 10,
                            'style': 'border-radius:4px; padding:10px; border:1px solid #ddd;',
                            'data-predict': 'true',
                            'id': 'post_content'
                        }}) }}
                        {{ form_errors(form.content) }}
                        <div class="suggestion-hint">
                            <span><i class="fa fa-lightbulb-o"></i> <strong>AI Predictor :</strong> Tapez un mot et des suggestions apparaîtront</span>
                            <span><kbd>Tab</kbd> Accepter</span>
                            <span><kbd>Esc</kbd> Fermer</span>
                            <span><kbd>Clic</kbd> Sélectionner</span>
                        </div>
                    </div>

                    <div style="display:flex; gap:12px; align-items:center;">
                        <button type="submit" class="boxed-btn3">Publier le Post</button>
                        <a href="{{ path('app_post_index') }}" style="color:#888; font-size:14px;">← Retour au Blog</a>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
{% include 'partials/word_predictor.html.twig' %}
{% endblock %}
