{% extends 'base.html.twig' %}

{% block title %}Recherche TikTok - LAMMA{% endblock %}
{% block page_title %}TikTok Explorer{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        
        <!-- Search Header -->
        <div class="row align-items-center mb-4">
            <div class="col-12 text-center">
                <form action="{{ path('app_tiktok_search') }}" method="GET" class="d-flex justify-content-center" style="max-width: 600px; margin: 0 auto; gap: 10px;">
                    <input type="text" name="q" value="{{ query }}" placeholder="Entrez une destination (ex: Sousse)" class="form-control" style="border-radius: 25px; padding-left: 20px;">
                    <button type="submit" class="btn btn-scout-confirm" style="border-radius: 25px;">
                        🚀 Lancer Recherche
                    </button>
                </form>
            </div>
        </div>

        <!-- Status Messages -->
        <div class="row">
            <div class="col-12 text-center mb-4">
                {% if error %}
                    <div class="alert alert-danger" style="display:inline-block;">{{ error }}</div>
                {% elseif statusMessage %}
                    <div class="alert" style="background: rgba(16, 185, 129, 0.2); color: #10b981; border: 1px solid rgba(16,185,129,0.5); display:inline-block; border-radius:10px; padding: 10px 20px;">
                        {{ statusMessage }}
                    </div>
                {% elseif query == '' %}
                    <div class="alert" style="background: rgba(59, 130, 246, 0.1); color: #93c5fd; border: 1px solid rgba(59,130,246,0.3); display:inline-block; border-radius:10px; padding: 10px 20px;">
                        En attente d'une requête... Entrez un mot clé ci-dessus.
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Grid of Videos -->
        {% if videos|length > 0 %}
            <div class="row">
                {% for video in videos %}
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4 d-flex align-items-stretch">
                        <div class="card glass-panel w-100" style="border-color: rgba(254,44,85,0.3); overflow: hidden;">
                            <!-- Thumbnail -->
                            <div style="position: relative; height: 180px; background-color: #000;">
                                {% if video.cover %}
                                    <img src="{{ video.cover }}" alt="Thumbnail" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.8;">
                                {% else %}
                                    <div class="d-flex justify-content-center align-items-center h-100 text-muted">
                                        <i class="fa fa-image fa-3x"></i>
                                    </div>
                                {% endif %}
                                <span class="badge" style="position: absolute; top: 10px; left: 10px; background-color: rgba(254,44,85,0.9); font-size:10px;">TikWM</span>
                                <span class="badge badge-dark" style="position: absolute; bottom: 10px; right: 10px; background-color: rgba(0,0,0,0.7); font-size:10px;">
                                    <i class="fa fa-play"></i> {{ video.play_count|number_format(0, '', ' ') }}
                                </span>
                            </div>

                            <!-- Body -->
                            <div class="card-body text-center d-flex flex-column justify-content-between p-3">
                                <div>
                                    <p class="scout-subtitle" style="font-size: 0.9rem; font-weight: bold; line-height: 1.2; margin-bottom: 5px;">
                                        {{ video.title|length > 47 ? video.title|slice(0, 47) ~ '...' : video.title }}
                                    </p>
                                    <small style="color: #94a3b8;">@{{ video.author }}</small>
                                </div>
                                <div class="mt-3">
                                    <a href="https://www.tiktok.com/@{{ video.author }}/video/{{ video.id }}" target="_blank" class="btn w-100" style="background-color: #fe2c55; color: white; border-radius: 20px; font-weight: bold; font-size: 0.85rem;">
                                        <i class="fa fa-play mr-1"></i> STREAMER
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

    </div>
</section>
{% endblock %}
