{% extends 'admin/base_admin.html.twig' %}
{% import '_macros.html.twig' as macros %}

{% block title %}Repas - LAMMA{% endblock %}
{% block admin_title %}Planning Alimentaire{% endblock %}

{% block admin_content %}
<section class="crud-section">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 style="font-family:'Anton',sans-serif;color:var(--scout-navy); margin: 0;">Définition des Plats</h2>
            <div style="font-size: 0.85rem; color: var(--text-dim); font-weight: 700;">Gestion du catalogue culinaire et des types de régimes</div>
        </div>
        <div class="col-md-6 text-right">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_repas_new') }}" class="btn-scout-confirm" style="padding: 10px 25px;"><i class="fa fa-plus"></i> NOUVEAU REPAS</a>
            {% endif %}
        </div>
    </div>

    <!-- Filter & Search Bar -->
    <div class="scout-card mb-4" style="padding: 15px; background: rgba(0,0,0,0.2);">
        <div class="row align-items-center">
            <div class="col-md-7 mb-2 mb-md-0">
                <div class="d-flex flex-wrap gap-2" id="category-filters">
                    <button class="genric-btn info-border circle small filter-btn active" data-cat="ALL" style="font-size: 11px; cursor:pointer; margin:3px;">TOUS</button>
                    {% set cats = ['ENTREE', 'PLAT_PRINCIPAL', 'DESSERT', 'BOISSON'] %}
                    {% for cat in cats %}
                        <button class="genric-btn info-border circle small filter-btn" data-cat="{{ cat }}" style="font-size: 11px; cursor:pointer; margin:3px;">{{ cat|replace({'_': ' '}) }}</button>
                    {% endfor %}
                </div>
            </div>
            <div class="col-md-5 d-flex gap-2">
                <input type="text" id="repas-search" class="form-control" placeholder="Rechercher..." style="background: transparent; border: 1px solid #ff005a; color: white; border-radius: 5px;">
                <select id="repas-sort" class="form-control" style="background: transparent; border: 1px solid #444; color: white; border-radius: 5px; width: 140px;">
                    <option value="" style="color: black;">Trier par...</option>
                    <option value="name_asc" style="color: black;">Nom (A-Z)</option>
                    <option value="name_desc" style="color: black;">Nom (Z-A)</option>
                    <option value="price_asc" style="color: black;">Prix croissant</option>
                    <option value="price_desc" style="color: black;">Prix décroissant</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Repas Cards Grid -->
    <div class="row" id="repas-grid">
        {% for item in items %}
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4 repas-card-wrap" data-nom="{{ item.nom }}" data-prix="{{ item.prix }}" data-category="{{ item.categorie }}">
            <div class="ingredient-card" style="background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.08); transition: all 0.3s ease; border: 2px solid transparent;">
                <div style="height: 140px; background: {% if item.imageUrl %}url('{{ item.imageUrl }}') center/cover{% else %}linear-gradient(135deg, #1a1a2e 0%, #16213e 100%){% endif %}; display: flex; align-items: center; justify-content: center; position: relative;">
                    {% if not item.imageUrl %}
                    <span style="font-size: 3rem;">
                        {% if item.categorie == 'ENTREE' %}🥗{% elseif item.categorie == 'PLAT_PRINCIPAL' %}🍲{% elseif item.categorie == 'DESSERT' %}🍰{% elseif item.categorie == 'BOISSON' %}🥤{% else %}🍽️{% endif %}
                    </span>
                    {% endif %}
                    <span style="position: absolute; top: 8px; right: 8px; background: {% if item.disponible %}#28a745{% else %}#dc3545{% endif %}; color: #fff; font-size: 0.6rem; padding: 3px 8px; border-radius: 20px; font-weight: 700;">
                        {% if item.disponible %}DISPO{% else %}RUPTURE{% endif %}
                    </span>
                    <span style="position: absolute; bottom: 8px; left: 8px; background: rgba(0,0,0,0.7); color: #ff005a; font-size: 0.7rem; padding: 3px 8px; border-radius: 20px; font-weight: 700;">
                        {{ item.tempsPreparation }} min
                    </span>
                </div>
                <div style="padding: 15px;">
                    <div style="font-weight: 800; font-size: 0.95rem; color: #1a1a2e; margin-bottom: 5px;">{{ item.nom }}</div>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 0.7rem; color: #888; text-transform: uppercase; font-weight: 700;">{{ item.categorie|slice(0, 10) }} ({{ item.typePlat|slice(0, 8) }})</span>
                        <span style="font-weight: 900; color: #ff005a; font-size: 0.9rem;">{{ item.prix }} €</span>
                    </div>
                </div>
                <div style="padding: 0 15px 12px; display:flex; gap:5px;">
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_repas_edit', {id: item.id}) }}" class="genric-btn info-border circle small" style="font-size: 10px; flex:1; text-align:center; padding-left:0; padding-right:0;">Edit</a>
                        <form method="post" action="{{ path('app_repas_delete', {'id': item.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce repas ?');" style="flex:1; margin:0; display:flex;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                            <button class="genric-btn primary-border circle small" style="font-size: 10px; flex:1; text-align:center; padding-left:0; padding-right:0; border-color: #ff005a; color: #ff005a; background: transparent;">Supp</button>
                        </form>
                    {% endif %}
                    <a href="{{ path('app_repas_show', {id: item.id}) }}" class="genric-btn info-border circle small" style="font-size: 10px; flex:1; text-align:center; padding-left:0; padding-right:0;">Voir</a>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-12 text-center" style="padding: 60px; color: #888;">
            <div style="font-size: 3rem; margin-bottom: 15px;">🍽️</div>
            <p>Aucun repas trouvé. Commencez par en créer un !</p>
        </div>
        {% endfor %}
    </div>

    .filter-btn.active {
        background: #ff005a !important;
        color: #fff !important;
        border-color: #ff005a !important;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('repas-search');
    const sortSelect = document.getElementById('repas-sort');
    const grid = document.getElementById('repas-grid');

    function filterAndSort() {
        const activeCat = document.querySelector('.filter-btn.active').dataset.cat;
        const searchTerm = searchInput.value.toLowerCase().trim();
        const sortMode = sortSelect.value;
        const cards = Array.from(document.querySelectorAll('.repas-card-wrap'));

        // Filter
        cards.forEach(function(card) {
            const matchesCat = (activeCat === 'ALL' || card.dataset.category === activeCat);
            // Search in card text + data names
            const text = card.innerText.toLowerCase();
            const dataNom = card.dataset.nom.toLowerCase();
            const matchesSearch = !searchTerm || text.includes(searchTerm) || dataNom.includes(searchTerm);
            
            card.style.display = (matchesCat && matchesSearch) ? '' : 'none';
        });

        // Sort
        if (sortMode) {
            const visibleCards = cards.filter(c => c.style.display !== 'none');
            visibleCards.sort(function(a, b) {
                const direction = sortMode.includes('asc') ? 'asc' : 'desc';
                
                if (sortMode.startsWith('price_')) {
                    const cleanNum = (s) => s.replace(/[^0-9.-]/g, '');
                    let numA = parseFloat(cleanNum((a.dataset.prix || '0').replace(',', '.')));
                    let numB = parseFloat(cleanNum((b.dataset.prix || '0').replace(',', '.')));
                    return direction === 'asc' ? numA - numB : numB - numA;
                }
                
                if (sortMode.startsWith('name_')) {
                    let valA = a.dataset.nom.toLowerCase();
                    let valB = b.dataset.nom.toLowerCase();
                    return direction === 'asc' ? valA.localeCompare(valB) : valB.localeCompare(valA);
                }
                
                return 0;
            });
            visibleCards.forEach(c => grid.appendChild(c));
        }
    }

    searchInput.addEventListener('input', filterAndSort);
    sortSelect.addEventListener('change', filterAndSort);

    // Category filters
    document.querySelectorAll('.filter-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
            filterAndSort();
        });
    });
});
</script>
</section>
{% endblock %}
