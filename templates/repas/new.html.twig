{% extends 'base.html.twig' %}

{% block title %}Nouveau Repas - LAMMA{% endblock %}
{% block page_title %}Créer un nouveau Plat{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="fiche-card">
                    <div class="fiche-header text-uppercase">
                        <i class="fa fa-cutlery mr-2"></i> FICHE D'INFORMATION REPAS
                    </div>
                    <div class="fiche-body">
                        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="row">
                            <div class="col-12">
                                {{ form_widget(form) }}
                            </div>
                        </div>
                        <div class="mt-5 text-center">
                            <button type="submit" class="btn btn-publier">Publier le Plat</button>
                            <a href="{{ path('app_repas_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
