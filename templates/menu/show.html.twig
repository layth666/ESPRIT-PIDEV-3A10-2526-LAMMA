{% extends 'base.html.twig' %}

{% block title %}Détails Menu - LAMMA{% endblock %}
{% block page_title %}{{ item.nom }}{% endblock %}

{% block body %}
<section class="crud-section" style="padding: 60px 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card card-detail">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fa fa-file-text-o"></i> Fiche Menu</span>
                        <span class="badge badge-status badge-{{ item.actif ? 'actif' : 'expire' }}">
                            {{ item.actif ? 'EN LIGNE' : 'HORS LIGNE' }}
                        </span>
                    </div>
                    <div class="card-body">
                        <h3 class="text-pink" style="color:#fb246a;">{{ item.prix }} €</h3>
                        <p class="lead mt-3">{{ item.description ?? 'Pas de description.' }}</p>
                        <hr>
                        <div class="row info-row">
                            <div class="col-md-6">
                                <strong>Début :</strong>
                                {{ item.dateDebut ? item.dateDebut|date('d/m/Y') : 'Immédiat' }}
                            </div>
                            <div class="col-md-6">
                                <strong>Fin :</strong>
                                {{ item.dateFin ? item.dateFin|date('d/m/Y') : 'Indéfini' }}
                            </div>
                            <div class="col-md-6 mt-2">
                                <strong>Restaurant :</strong>
                                {{ item.restaurantNom ?? 'Non assigné' }}
                            </div>
                        </div>
                        <div class="mt-4 text-center">
                            <a href="{{ path('app_menu_edit', {id: item.id}) }}"
                               class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">Modifier</a>
                            <a href="{{ path('app_menu_index') }}"
                               class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Retour</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
