{% extends 'admin/base_admin.html.twig' %}
{% import '_macros.html.twig' as macros %}

{% block title %}Menu Catalog - LAMMA{% endblock %}
{% block admin_title %}Cartes & Menus{% endblock %}


{% block stylesheets %}
<style>
    .menu-catalog-sidebar {
        background: #0b0f19;
        color: white;
        padding: 30px;
        min-height: calc(100vh - 100px);
        border-radius: 12px;
    }
    .catalog-icon {
        width: 48px; height: 48px;
        background: rgba(16, 185, 129, 0.2);
        color: #10b981;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 20px;
    }
    .catalog-title { font-family: 'Anton', sans-serif; font-size: 1.5rem; margin-bottom: 5px; text-transform: uppercase; }
    .catalog-desc { color: #94a3b8; font-size: 0.8rem; margin-bottom: 30px; }
    
    .sidebar-btns { display: flex; gap: 10px; margin-bottom: 30px; }
    .btn-new-menu {
        background: #f97316; color: white; border: none;
        flex-grow: 1; padding: 12px; border-radius: 8px;
        font-weight: 800; text-transform: uppercase; font-size: 0.85rem;
    }
    .btn-sync {
        background: #334155; color: #94a3b8; border: none;
        padding: 12px; border-radius: 8px;
    }
    
    .scout-search-box {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 10px 15px;
        position: relative;
        margin-bottom: 40px;
    }
    .scout-search-box input {
        background: transparent; border: none; color: white; width: 100%;
        padding-left: 25px; font-size: 0.9rem;
    }
    .scout-search-box i { position: absolute; left: 15px; top: 13px; color: #94a3b8; }

    .menu-group-label { font-size: 0.7rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; }
    .menu-count { font-size: 0.8rem; color: #475569; margin-bottom: 20px; display: block; }

    /* CARD STYLES */
    .menu-item-card {
        background: white;
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 25px;
        border-left: 6px solid #10b981;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        transition: transform 0.2s;
        text-decoration: none !important;
        display: block;
        color: #334155 !important;
    }
    .menu-item-card:hover { transform: translateX(5px); box-shadow: 0 10px 15px rgba(0,0,0,0.1); }
    .card-restau { font-size: 0.7rem; font-weight: 800; color: #10b981; text-transform: uppercase; margin-bottom: 5px; }
    .card-title { font-family: 'Anton', sans-serif; font-size: 1.6rem; margin-bottom: 15px; text-transform: uppercase; color: #0f172a; }
    .card-period { font-size: 0.75rem; color: #94a3b8; margin-top: 15px; font-weight: 600; }
    
    .decoration-wavy {
        height: 10px;
        background-image: radial-gradient(circle at 10px 10px, transparent 10px, #e2e8f0 10px, #e2e8f0 11px, transparent 11px);
        background-size: 20px 20px;
        margin: 10px 0;
    }

</style>
{% endblock %}

{% block admin_content %}
<div class="row">
    <!-- Sidebar -->
    <div class="col-lg-3">
        <div class="menu-catalog-sidebar">
            <div class="catalog-icon"><i class="fa fa-book"></i></div>
            <h2 class="catalog-title">Menu Catalog</h2>
            <p class="catalog-desc">Curate dining experiences for your expedition groups and explorers.</p>
            
            <div class="sidebar-btns">
                <a href="{{ path('app_menu_new') }}" class="btn-new-menu text-center" style="text-decoration:none;">+ NEW</a>
                <button class="btn-sync" title="Synchroniser avec les restaurants"><i class="fa fa-refresh"></i> SYNC</button>
            </div>

            <div class="scout-search-box">
                <i class="fa fa-search"></i>
                <input type="text" placeholder="Scout Search">
            </div>

            <div class="menu-group-label"><i class="fa fa-check-circle"></i> Active Menus</div>
            <span class="menu-count">{{ items|length }} menus found</span>
        </div>
    </div>

    <!-- Main Content -->
    <div class="col-lg-9">
        <h2 style="font-family:'Anton', sans-serif; color:white; margin-bottom: 30px; display: flex; align-items: center; gap: 10px;">
            <i class="fa fa-bars text-success"></i> ACTIVE MENUS
        </h2>
        
        <div class="row">
            {% for menu in items %}
                <div class="col-md-12">
                    <div class="menu-item-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="card-restau">{{ menu.restaurantNom|default('Restaurant Inconnu') }}</div>
                                <h3 class="card-title">{{ menu.nom }}</h3>
                            </div>
                            <div class="card-price" style="font-family: 'Anton', sans-serif; font-size: 1.5rem; color: #10b981;">
                                {{ menu.prix|number_format(2, ',', ' ') }} €
                            </div>
                        </div>
                        
                        <div class="decoration-wavy"></div>
                        
                        <p style="font-size: 0.9rem; font-style: italic; color: #64748b;">
                            {% set desc = menu.description|default('') %}
                            {{ desc|length > 150 ? desc|slice(0, 150) ~ '...' : desc }}
                        </p>
                        
                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <div class="card-period">
                                <i class="fa fa-calendar-o mr-1"></i> {{ menu.dateDebut ? menu.dateDebut|date('Y-m-d') : '--' }} ➔ {{ menu.dateFin ? menu.dateFin|date('Y-m-d') : '--' }}
                            </div>
                            
                            <div class="card-actions d-flex gap-2">
                                <a href="{{ path('app_menu_show', {id: menu.id}) }}" class="btn btn-sm btn-outline-info" title="Voir détails">
                                    <i class="fa fa-eye"></i>
                                </a>
                                <a href="{{ path('app_menu_edit', {id: menu.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier">
                                    <i class="fa fa-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_menu_delete', {id: menu.id}) }}" style="display:inline-block;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce menu ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ menu.id) }}">
                                    <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <i class="fa fa-folder-open-o fa-4x text-muted mb-3"></i>
                    <p style="color: #94a3b8;">Aucun menu n'a été éclaireur pour le moment.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
