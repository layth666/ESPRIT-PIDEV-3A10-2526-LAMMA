{% extends 'admin/base_admin.html.twig' %}
{% import '_macros.html.twig' as macros %}

{% block title %}Menus - LAMMA{% endblock %}
{% block admin_title %}Cartes & Menus{% endblock %}

{% block admin_content %}
<section class="crud-section">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 style="font-family:'Anton',sans-serif;color:var(--scout-navy); margin: 0;">Gestion des Cartes</h2>
            <div style="font-size: 0.85rem; color: var(--text-dim); font-weight: 700;">Configuration des offres gastronomiques par établissement</div>
        </div>
        <div class="col-md-6 text-right">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_menu_new') }}" class="btn-scout-confirm" style="padding: 10px 25px;"><i class="fa fa-plus"></i> NOUVEAU MENU</a>
            {% endif %}
        </div>
    </div>

    <div class="scout-card" style="padding: 0;">
        {% set columns = {
            'nom': 'Designation',
            'restaurantNom': 'Restaurant',
            'prix': 'Tarif',
            'dateDebut': 'Début',
            'dateFin': 'Fin',
            'actif': 'En Vigueur'
        } %}
        {{ macros.crud_table(items, columns, 'app_menu_edit', 'app_menu_show', 'menu', ['restaurantNom', 'actif']) }}
    </div>
</section>
{% endblock %}
