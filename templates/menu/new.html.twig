{% extends 'admin/base_admin.html.twig' %}

{% block title %}Nouveau Menu - LAMMA{% endblock %}

{% block stylesheets %}
<style>
    body { background-color: #0b0f19 !important; }
    .poesie-container {
        max-width: 900px;
        margin: 40px auto;
        background: #fcfaf7;
        border-radius: 8px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        color: #1e293b;
        padding: 60px;
        font-family: 'Inter', sans-serif;
    }
    .poesie-header { text-align: center; margin-bottom: 50px; }
    .title-braces { font-family: 'Anton', sans-serif; font-size: 4rem; color: #164e33; letter-spacing: 2px; }
    .subtitle-poesie { font-weight: 800; color: #164e33; font-size: 1.2rem; margin-top: 10px; }
    .description-poesie { color: #64748b; font-size: 1rem; font-style: italic; margin-top: 10px; }
    
    .poesie-section-title {
        font-family: 'Anton', sans-serif;
        font-size: 1.5rem;
        color: #164e33;
        text-transform: uppercase;
        margin: 60px 0 30px 0;
        text-align: center;
        border-top: 1px solid #e2e8f0;
        padding-top: 50px;
    }
    
    .form-group-poesie { display: flex; align-items: center; margin-bottom: 25px; gap: 20px; }
    .label-poesie {
        width: 180px; text-align: right;
        font-family: 'Anton', sans-serif;
        color: #164e33; font-size: 0.9rem; letter-spacing: 1px;
    }
    .input-poesie, .select-poesie {
        flex-grow: 1; padding: 12px 20px;
        border-radius: 8px; border: 1px solid #e2e8f0;
        background: white; font-size: 1rem; color: #334155;
    }
    .input-poesie::placeholder { color: #cbd5e1; }
    
    .dishes-checkbox-container {
        background: #f1f5f9;
        border-radius: 12px;
        padding: 30px;
        max-height: 400px;
        overflow-y: auto;
    }
    .dish-checkbox-item {
        display: flex; align-items: center; gap: 15px; padding: 10px 0; border-bottom: 1px solid #e2e8f0;
    }
    .dish-checkbox-item:last-child { border-bottom: none; }
    .checkbox-custom { width: 20px; height: 20px; cursor: pointer; }
    .dish-label { font-size: 0.95rem; font-weight: 700; color: #1e293b; }

    .textarea-poesie {
        width: 100%; height: 250px; padding: 20px;
        border-radius: 8px; border: 1px solid #e2e8f0;
        font-size: 1.1rem; color: #334155; resize: none;
    }

    .poesie-footer {
        margin-top: 60px; display: flex; justify-content: center; gap: 20px;
        border-top: 1px solid #e2e8f0; padding-top: 40px;
    }
    .btn-poesie {
        padding: 15px 40px; border-radius: 40px; font-weight: 800; font-size: 0.9rem;
        text-transform: uppercase; cursor: pointer; transition: 0.3s;
    }
    .btn-save-p { background: #164e33; color: white; border: none; }
    .btn-card-p { background: white; color: #164e33; border: 2px solid #164e33; }
    .btn-exit-p { background: white; color: #f87171; border: 1px solid #f87171; }
    
    .btn-poesie:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
</style>
{% endblock %}

{% block admin_content %}
<div class="poesie-container">
    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    
    <!-- Title Section -->
    <div class="poesie-header">
        <div class="title-braces">{MENU}</div>
        <div class="subtitle-poesie">Nouveau Menu</div>
        <p class="description-poesie">L'expérience culinaire LAMMA Explorer</p>
    </div>

    <!-- Informations Générales -->
    <div class="poesie-section-title">{INFORMATIONS GÉNÉRALES}</div>
    
    <div class="form-group-poesie">
        <label class="label-poesie">NOM DU MENU :</label>
        {{ form_widget(form.nom, {'attr': {'class': 'input-poesie', 'placeholder': 'Saisissez le nom du menu...'}}) }}
    </div>
    
    <div class="form-group-poesie">
        <label class="label-poesie">RESTAURANT :</label>
        {{ form_widget(form.restaurantId, {'attr': {'class': 'select-poesie'}}) }}
    </div>

    <div class="form-group-poesie">
        <label class="label-poesie">TARIF (€) :</label>
        {{ form_widget(form.prix, {'attr': {'class': 'input-poesie'}}) }}
    </div>

    <div class="form-group-poesie">
        <label class="label-poesie">VISIBILITÉ :</label>
        <div class="d-flex align-items-center gap-2">
            {{ form_widget(form.actif, {'attr': {'class': 'checkbox-custom'}}) }}
            <span style="font-weight: 700;">Menu disponible et actif immédiatement</span>
        </div>
    </div>

    <!-- Période de Validité -->
    <div class="poesie-section-title d-flex align-items-center justify-content-center gap-3">
        {PÉRIODE DE VALIDITÉ}
        <button type="button" id="btn-ai-dates" class="btn btn-sm" style="background: #fae8d8; color: #9a3412; font-weight: 700; border-radius: 20px; border: none;">✨ Proposer Dates</button>
    </div>
    
    <div class="form-group-poesie">
        <label class="label-poesie">DATE DE DÉBUT :</label>
        {{ form_widget(form.dateDebut, {'attr': {'class': 'input-poesie'}}) }}
    </div>

    <div class="form-group-poesie">
        <label class="label-poesie">DATE DE FIN :</label>
        {{ form_widget(form.dateFin, {'attr': {'class': 'input-poesie'}}) }}
    </div>

    <!-- Composition du Menu -->
    <div class="poesie-section-title">{COMPOSITION DU MENU}</div>
    <p class="text-center text-muted mb-4">Sélectionnez les plats emblématiques pour ce voyage gustatif :</p>
    
    <div class="dishes-checkbox-container">
        {% for dish in allDishes %}
            <div class="dish-checkbox-item">
                <input type="checkbox" name="dishes[{{ dish.id }}]" value="1" id="dish-{{ dish.id }}" 
                       class="checkbox-custom dish-selector" 
                       data-prix="{{ dish.prix }}" 
                       data-nom="{{ dish.nom }}">
                <label for="dish-{{ dish.id }}" class="dish-label">{{ dish.nom }} ({{ dish.prix|number_format(2, ',', ' ') }} €)</label>
            </div>
        {% endfor %}
    </div>

    <!-- Poésie Culinaire -->
    <div class="poesie-section-title d-flex align-items-center justify-content-center gap-3">
        {POÉSIE CULINAIRE}
        <button type="button" id="btn-ai-poetry" class="btn btn-sm" style="background: #164e33; color: white; font-weight: 700; border-radius: 20px;">✨ Rédiger une description poétique</button>
    </div>
    
    {{ form_widget(form.description, {'attr': {'class': 'textarea-poesie', 'placeholder': 'Racontez l\'histoire de ce menu...'}}) }}

    <!-- Footer -->
    <div class="poesie-footer">
        <button type="submit" class="btn-poesie btn-save-p"><i class="fa fa-save mr-2"></i> ENREGISTRER</button>
        <button type="button" class="btn-poesie btn-card-p"><i class="fa fa-paint-brush mr-2"></i> CARTE PRÉSENTATION</button>
        <a href="{{ path('app_menu_index') }}" class="btn-poesie btn-exit-p text-center" style="text-decoration:none;">❌ QUITTER</a>
    </div>

    <div class="text-center mt-5" style="color: #94a3b8; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2px;">
        123 LAMMA ST., EXPLORER CITY | LAMMA-RESTAURANT.COM
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    console.log("LAMMA AI System: Initialized");

    // Standard Symfony Form IDs
    const ID_NOM = 'menu_nom';
    const ID_PRIX = 'menu_prix';
    const ID_START = 'menu_dateDebut';
    const ID_END = 'menu_dateFin';
    const ID_DESC = 'menu_description';

    // 1. AUTO PRICE CALCULATION
    const checkboxes = document.querySelectorAll('.dish-selector');
    const prixInput = document.getElementById(ID_PRIX);

    function updatePrice() {
        if (!prixInput) return;
        let total = 0;
        let count = 0;
        checkboxes.forEach(cb => {
            if (cb.checked) {
                total += parseFloat(cb.dataset.prix || 0);
                count++;
            }
        });
        // Apply 10% discount for menus with 2+ dishes
        if (total > 0 && count >= 2) {
            total = total * 0.9;
        }
        prixInput.value = total.toFixed(2);
        console.log("LAMMA AI: Price updated to", total.toFixed(2));
    }

    checkboxes.forEach(cb => cb.addEventListener('change', updatePrice));

    // 2. SUGGEST DATES
    const btnDates = document.getElementById('btn-ai-dates');
    if (btnDates) {
        btnDates.addEventListener('click', function() {
            const today = new Date();
            const tomorrow = new Date(today);
            tomorrow.setDate(tomorrow.getDate() + 1);
            
            const nextWeek = new Date(tomorrow);
            nextWeek.setDate(nextWeek.getDate() + 7);

            const startElt = document.getElementById(ID_START);
            const endElt = document.getElementById(ID_END);

            if (startElt) startElt.value = tomorrow.toISOString().split('T')[0];
            if (endElt) endElt.value = nextWeek.toISOString().split('T')[0];
            
            console.log("LAMMA AI: Dates suggested");
            this.innerHTML = '<i class="fa fa-check"></i> Dates Suggérées';
            setTimeout(() => this.innerText = '✨ Proposer Dates', 2000);
        });
    }

    // 3. POETIC DESCRIPTION GENERATION
    const btnPoetry = document.getElementById('btn-ai-poetry');
    if (btnPoetry) {
        btnPoetry.addEventListener('click', function() {
            const nomElt = document.getElementById(ID_NOM);
            const menuNom = (nomElt ? nomElt.value : "") || "Expédition Culinaire";
            const selected = Array.from(document.querySelectorAll('.dish-selector:checked')).map(cb => cb.dataset.nom);
            
            if (selected.length === 0) {
                alert("Veuillez d'abord sélectionner quelques plats pour inspirer l'IA.");
                return;
            }

            const templates = [
                `Plongez au cœur de l'aventure avec notre menu "${menuNom}". Un voyage sensoriel qui débute par la délicatesse de ${selected[0]} et se poursuit à travers les saveurs sauvages de ${selected[1] || 'nos produits locaux'}. Une halte gourmande indispensable pour tout explorateur lamma.`,
                `L'esprit de la montagne se retrouve dans chaque bouchée de "${menuNom}". Cette sélection exclusive, mettant à l'honneur ${selected.join(', ')}, a été conçue comme une carte postale gustative de nos sommets les plus secrets.`,
                `"${menuNom}" : plus qu'un menu, une légende. Savourez l'alliance parfaite de ${selected[0]} et de la tradition. Une expérience sculptée par le vent et les épices pour réveiller l'âme du scout qui sommeille en vous.`
            ];

            const randomTemplate = templates[Math.floor(Math.random() * templates.length)];
            const descField = document.getElementById(ID_DESC);
            
            if (!descField) return;

            // Typing effect
            descField.value = "";
            let idx = 0;
            const speed = 15;
            function typeWriter() {
                if (idx < randomTemplate.length) {
                    descField.value += randomTemplate.charAt(idx);
                    idx++;
                    setTimeout(typeWriter, speed);
                }
            }
            typeWriter();
            
            console.log("LAMMA AI: Poetry generated");
            this.innerHTML = '<i class="fa fa-magic"></i> Inspiration Générée';
            setTimeout(() => this.innerText = '✨ Rédiger une description poétique', 2000);
        });
    }
});
</script>
{% endblock %}
