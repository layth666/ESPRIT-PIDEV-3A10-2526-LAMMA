{# Macro for rendering a CRUD index table with inline delete #}
{% macro crud_table(entities, columns, edit_path, show_path, delete_path, filters = []) %}
    {% set crudId = 'crud_' ~ random(100000, 999999) %}
    <div id="{{ crudId }}" class="crud-instance-container" data-crud-id="{{ crudId }}">
        <!-- Generic Search and Sort Controls -->
        <div class="scout-card mb-4" style="padding: 15px; background: rgba(0,0,0,0.2);">
            <div class="row align-items-center">
                <div class="col-md-12 mb-3">
                    <span style="color: var(--scout-blue); font-weight: bold; font-family: 'Anton', sans-serif;"><i class="fa fa-filter"></i> FILTRES ET TRI</span>
                </div>
                <div class="col-md-6 d-flex flex-wrap gap-2 mb-2 mb-md-0">
                    {% for filterField in filters %}
                        <div class="filter-group d-flex align-items-center gap-2 mr-3 mb-2">
                            <span style="font-size: 0.7rem; color: #aab1b7; font-weight: bold; text-transform: uppercase;">{{ filterField }} :</span>
                            <select class="form-control crud-filter-select" data-filter-field="{{ filterField|lower }}" style="background: transparent; border: 1px solid #444; color: white; border-radius: 5px; width: auto; height: 30px; font-size: 0.8rem; padding: 0 10px;">
                                <option value="ALL" style="color: black;">TOUS</option>
                            </select>
                        </div>
                    {% endfor %}
                </div>
                <div class="col-md-6 d-flex gap-2 justify-content-md-end">
                    <input type="text" class="form-control crud-search-input" placeholder="Rechercher..." style="background: transparent; border: 1px solid #ff005a; color: white; border-radius: 5px; flex: 1;">
                    <select class="form-control crud-sort-select" style="background: transparent; border: 1px solid #444; color: white; border-radius: 5px; width: 170px;">
                        <option value="" style="color: black;">Trier par...</option>
                        {% for field, label in columns %}
                            {% set is_price = (label|lower matches '/prix|budget|tarif|montant/') %}
                            {% if is_price %}
                                <option value="{{ field|lower }}_asc" style="color: black;">{{ label }} croissant</option>
                                <option value="{{ field|lower }}_desc" style="color: black;">{{ label }} décroissant</option>
                            {% else %}
                                <option value="{{ field|lower }}_asc" style="color: black;">{{ label }} (A-Z)</option>
                                <option value="{{ field|lower }}_desc" style="color: black;">{{ label }} (Z-A)</option>
                            {% endif %}
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>

        <div class="row mt-4 crud-grid" style="gap: 20px 0;">
            {% for entity in entities %}
                <div class="col-md-6 col-lg-4 d-flex align-items-stretch crud-card-wrap" 
                    {% for field, label in columns %}
                        {% set val = attribute(entity, field) %}
                        {% if val is not null %}
                            {% set data_val = "" %}
                            {% if val.format is defined %}{% set data_val = val|date('Y-m-d H:i:s') %}{% elseif val is same as(true) %}{% set data_val = "OUI" %}{% elseif val is same as(false) %}{% set data_val = "NON" %}{% else %}{% set data_val = val %}{% endif %}
                            data-{{ field|lower }}="{{ data_val|trim|escape('html_attr') }}"
                        {% endif %}
                    {% endfor %}
                >
                    <div class="card w-100 scout-crud-card" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 15px; backdrop-filter: blur(10px); color: #fff; box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: transform 0.3s ease;">
                        <div class="card-body" style="padding: 20px;">
                            <h4 class="crud-card-title" style="font-family: 'Anton', sans-serif; color: #3b82f6; border-bottom: 1px dashed rgba(255,255,255,0.1); padding-bottom: 10px; margin-bottom: 15px; text-transform: uppercase;">
                                {% set first_col = columns|keys|first %}
                                {{ attribute(entity, first_col) }}
                            </h4>
                            
                            <div class="entity-details" style="font-size: 0.9rem; line-height: 1.6;">
                                {% for field, label in columns %}
                                    {% if field != first_col %}
                                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px; border-bottom: 1px dashed rgba(255,255,255,0.05); padding-bottom: 4px; align-items: center;">
                                            <span style="color: #aab1b7; font-weight: 600; font-size: 0.8rem; text-transform: uppercase;">{{ label }}</span>
                                            <span class="detail-value" data-field-name="{{ field|lower }}" style="text-align: right; font-weight: bold; font-size: 0.95rem;">
                                                {% set value = attribute(entity, field) %}
                                                {% if value is null %}
                                                    <span class="text-muted">-</span>
                                                {% elseif value is same as(true) %}
                                                    <span class="badge" style="background:#28a745; color: white;">OUI</span>
                                                {% elseif value is same as(false) %}
                                                    <span class="badge" style="background:#dc3545; color: white;">NON</span>
                                                {% elseif value is iterable %}
                                                    <span class="badge" style="background-color: #3b82f6;">Collection ({{ value|length }})</span>
                                                {% elseif value is not same as(null) and value is not same as(true) and value is not same as(false) %}
                                                    {% if value.__toString is defined %}
                                                        {{ value }}
                                                    {% elseif value.format is defined %}
                                                        <i class="fa fa-calendar-o mr-1" style="color: #3b82f6;"></i> {{ value|date('d/m/Y') }}
                                                    {% else %}
                                                        {{ value }}
                                                    {% endif %}
                                                {% endif %}
                                            </span>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                        <div class="card-footer" style="background: transparent; border-top: 1px solid rgba(255,255,255,0.1); padding: 15px; display: flex; justify-content: space-between; align-items: center;">
                            <a href="{{ path(show_path, {'id': entity.id}) }}" class="btn btn-sm btn-outline-light" style="border-radius: 20px; font-size: 11px; padding: 5px 15px; border-color: rgba(255,255,255,0.2);">VOIR DÉTAILS</a>
                            
                            {% if is_granted('ROLE_ADMIN') or (entity.userId is defined and app.user is not null and entity.userId == app.user.id) %}
                                <div class="d-flex gap-2">
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <a href="{{ path(edit_path, {'id': entity.id}) }}" class="btn btn-sm" style="background: rgba(255,193,7,0.8); color: #000; border-radius: 20px; font-size: 11px; font-weight: bold;"><i class="fa fa-pen"></i></a>
                                    {% endif %}
                                    {% if delete_path %}
                                        <form method="post" action="{{ path('app_' ~ delete_path ~ '_delete', {'id': entity.id}) }}" onsubmit="return confirm('Êtes-vous sûr ?');" style="display:inline; margin:0;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entity.id) }}">
                                            <button type="submit" class="btn btn-sm" style="background: rgba(220,53,69,0.8); color: #fff; border-radius: 20px; font-size: 11px;"><i class="fa fa-trash"></i></button>
                                        </form>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center" style="padding: 40px; color: #aab1b7;">
                    <i class="fa fa-folder-open mb-3" style="font-size: 3rem; color: #3b82f6; opacity: 0.5;"></i>
                    <h4>Aucune donnée disponible</h4>
                </div>
            {% endfor %}
        </div>
        
        <script>
        (function() {
            function init{{ crudId }}() {
                const container = document.getElementById('{{ crudId }}');
                if (!container) return;
                
                const searchInput = container.querySelector('.crud-search-input');
                const sortSelect = container.querySelector('.crud-sort-select');
                const filterSelects = container.querySelectorAll('.crud-filter-select');
                const grid = container.querySelector('.crud-grid');

                // Auto-populate filter options
                filterSelects.forEach(select => {
                    const field = select.getAttribute('data-filter-field');
                    const values = new Set();
                    container.querySelectorAll('.crud-card-wrap').forEach(card => {
                        const val = (card.getAttribute('data-' + field) || '').trim();
                        if (val) values.add(val);
                    });
                    
                    Array.from(values).sort().forEach(val => {
                        const opt = document.createElement('option');
                        opt.value = val;
                        opt.textContent = val;
                        opt.style.color = 'black';
                        select.appendChild(opt);
                    });
                });

                function filterAndSortCards() {
                    const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';
                    const sortMode = sortSelect ? sortSelect.value : '';
                    const cards = Array.from(grid.querySelectorAll('.crud-card-wrap'));

                    cards.forEach(function(card) {
                        // Search
                        const text = card.textContent.toLowerCase();
                        const matchesSearch = !searchTerm || text.includes(searchTerm);
                        
                        // Filters
                        let matchesFilters = true;
                        filterSelects.forEach(select => {
                            const field = select.getAttribute('data-filter-field');
                            const filterVal = select.value;
                            if (filterVal !== 'ALL') {
                                const cardVal = (card.getAttribute('data-' + field) || '').trim();
                                if (cardVal !== filterVal) matchesFilters = false;
                            }
                        });

                        card.style.display = (matchesSearch && matchesFilters) ? '' : 'none';
                    });

                    // Sort
                    if (sortMode) {
                        const parts = sortMode.split('_');
                        const direction = parts.pop();
                        const field = parts.join('_').toLowerCase();

                        const visibleCards = cards.filter(c => c.style.display !== 'none');
                        visibleCards.sort(function(a, b) {
                            let valA = (a.getAttribute('data-' + field) || '').trim();
                            let valB = (b.getAttribute('data-' + field) || '').trim();
                            
                            const cleanNum = (s) => s.replace(/[^0-9.-]/g, '');
                            let numA = parseFloat(cleanNum(valA.replace(',', '.')));
                            let numB = parseFloat(cleanNum(valB.replace(',', '.')));

                            if (!isNaN(numA) && !isNaN(numB)) {
                                return direction === 'asc' ? numA - numB : numB - numA;
                            }
                            return direction === 'asc' ? valA.localeCompare(valB) : valB.localeCompare(valA);
                        });
                        visibleCards.forEach(c => grid.appendChild(c));
                    }
                }

                if (searchInput) searchInput.addEventListener('input', filterAndSortCards);
                if (sortSelect) sortSelect.addEventListener('change', filterAndSortCards);
                filterSelects.forEach(s => {
                    s.addEventListener('change', filterAndSortCards);
                    s.addEventListener('input', filterAndSortCards);
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init{{ crudId }});
            } else {
                init{{ crudId }}();
            }
        })();
        </script>
    </div>
    
    <style>
    .scout-crud-card:hover { transform: translateY(-5px) !important; box-shadow: 0 10px 25px rgba(59,130,246,0.15) !important; border-color: rgba(59,130,246,0.3) !important; }
    .filter-group select:focus { border-color: #ff005a !important; box-shadow: none !important; }
    </style>
{% endmacro %}
