{# Macro for rendering a CRUD index table with inline delete #}
{% macro crud_table(entities, columns, edit_path, show_path, delete_path, filters = []) %}
    {% set crudId = 'crud_' ~ random(100000, 999999) %}
    <div id="{{ crudId }}" class="crud-instance-container" data-crud-id="{{ crudId }}">
        <!-- Generic Search and Sort Controls -->
        <div class="scout-card mb-4 border-0" style="padding: 20px; background: rgba(0,0,0,0.05); border-radius: 20px;">
            <div class="row align-items-center g-3">
                <div class="col-md-auto">
                    <span class="text-prm fw-bold" style="font-family: 'Anton', sans-serif; letter-spacing: 1px;"><i class="fas fa-filter me-2"></i> RECHERCHE</span>
                </div>
                <div class="col-md">
                    <div class="input-group overflow-hidden" style="border-radius: 12px; border: 1px solid rgba(0,0,0,0.1);">
                        <span class="input-group-text bg-white border-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" class="form-control border-0 crud-search-input py-2" placeholder="Rechercher par nom, type, ville...">
                    </div>
                </div>
                <div class="col-md-auto d-flex flex-wrap gap-2">
                    {% for filterField in filters %}
                        <div class="filter-group d-flex align-items-center bg-white rounded-3 shadow-sm border px-3 py-1">
                            <span class="small fw-bold text-muted me-2" style="font-size: 0.65rem; text-transform: uppercase;">{{ filterField }}</span>
                            <select class="border-0 bg-transparent fw-bold crud-filter-select" data-filter-field="{{ filterField|lower }}" style="font-size: 0.8rem; outline: none; min-width: 80px;">
                                <option value="ALL">TOUS</option>
                            </select>
                        </div>
                    {% endfor %}
                    
                    <select class="form-select border-0 shadow-sm rounded-3 fw-bold crud-sort-select" style="font-size: 0.8rem; width: 180px; padding: 10px;">
                        <option value="">Trier par...</option>
                        {% for field, label in columns %}
                            {% set is_price = (label|lower matches '/prix|budget|tarif|montant/') %}
                            {% if is_price %}
                                <option value="{{ field|lower }}_asc">{{ label }} ↑</option>
                                <option value="{{ field|lower }}_desc">{{ label }} ↓</option>
                            {% else %}
                                <option value="{{ field|lower }}_asc">{{ label }} (A-Z)</option>
                                <option value="{{ field|lower }}_desc">{{ label }} (Z-A)</option>
                            {% endif %}
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>

        <div class="row g-4 crud-grid">
            {% for entity in entities %}
                <div class="col-md-6 col-lg-4 d-flex align-items-stretch crud-card-wrap" 
                    {% for field, label in columns %}
                        {% set val = attribute(entity, field) %}
                        {% if val is not null %}
                            {% set data_val = "" %}
                            {% if val.format is defined %}{% set data_val = val|date('Y-m-d H:i:s') %}{% elseif val is same as(true) %}{% set data_val = "OUI" %}{% elseif val is same as(false) %}{% set data_val = "NON" %}{% else %}{% set data_val = val %}{% endif %}
                            data-{{ field|lower }}="{{ data_val|trim|escape('html_attr') }}"
                        {% endif %}
                    {% endfor %}
                >
                    <div class="card w-100 scout-crud-card border-0 shadow-sm" style="border-radius: 20px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); background: #fff;">
                        <div class="card-body p-4">
                            <h5 class="crud-card-title fw-bold text-dark mb-4 pb-3 border-bottom border-light" style="font-family: 'DM Sans', sans-serif;">
                                {% set first_col = columns|keys|first %}
                                {{ attribute(entity, first_col) }}
                            </h5>
                            
                            <div class="entity-details">
                                {% for field, label in columns %}
                                    {% if field != first_col %}
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <span class="text-muted fw-bold small" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">{{ label }}</span>
                                            <span class="detail-value fw-bold text-end" data-field-name="{{ field|lower }}" style="font-size: 0.9rem;">
                                                {% set value = attribute(entity, field) %}
                                                {% if value is null %}
                                                    <span class="text-muted">-</span>
                                                {% elseif value is same as(true) %}
                                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Oui</span>
                                                {% elseif value is same as(false) %}
                                                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">Non</span>
                                                {% elseif value is iterable %}
                                                    <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3">{{ value|length }} items</span>
                                                {% elseif value is not same as(null) and value is not same as(true) and value is not same as(false) %}
                                                    {% if value.__toString is defined %}
                                                        {{ value }}
                                                    {% elseif value.format is defined %}
                                                        <span class="text-prm"><i class="far fa-calendar-alt me-1"></i> {{ value|date('d M Y') }}</span>
                                                    {% else %}
                                                        {{ value }}
                                                    {% endif %}
                                                {% endif %}
                                            </span>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 p-4 pt-0 d-flex gap-2">
                            <a href="{{ path(show_path, {'id': entity.id}) }}" class="btn btn-light flex-grow-1 fw-bold rounded-3" style="font-size: 0.8rem; padding: 10px;"><i class="fas fa-eye me-2 text-muted"></i> DÉTAILS</a>
                            
                            {% if is_granted('ROLE_ADMIN') %}
                                <div class="d-flex gap-2">
                                    <a href="{{ path(edit_path, {'id': entity.id}) }}" class="btn btn-warning bg-opacity-25 text-warning border-0 fw-bold rounded-3" style="width: 40px;"><i class="fas fa-pen"></i></a>
                                    
                                    {% if delete_path %}
                                        <form method="post" action="{{ path('app_' ~ delete_path ~ '_delete', {'id': entity.id}) }}" onsubmit="return confirm('Silencer cette donnée ?');" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entity.id) }}">
                                            <button type="submit" class="btn btn-danger bg-opacity-25 text-danger border-0 fw-bold rounded-3" style="width: 40px;"><i class="fas fa-trash"></i></button>
                                        </form>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <i class="fas fa-box-open fa-4x text-light mb-4 d-block"></i>
                    <h5 class="text-muted">Aucune donnée trouvée</h5>
                </div>
            {% endfor %}
        </div>

        
        <script>
        (function() {
            function init{{ crudId }}() {
                const container = document.getElementById('{{ crudId }}');
                if (!container) return;
                
                const searchInput = container.querySelector('.crud-search-input');
                const sortSelect = container.querySelector('.crud-sort-select');
                const filterSelects = container.querySelectorAll('.crud-filter-select');
                const grid = container.querySelector('.crud-grid');

                // Auto-populate filter options
                filterSelects.forEach(select => {
                    const field = select.getAttribute('data-filter-field');
                    const values = new Set();
                    container.querySelectorAll('.crud-card-wrap').forEach(card => {
                        const val = (card.getAttribute('data-' + field) || '').trim();
                        if (val) values.add(val);
                    });
                    
                    Array.from(values).sort().forEach(val => {
                        const opt = document.createElement('option');
                        opt.value = val;
                        opt.textContent = val;
                        opt.style.color = 'black';
                        select.appendChild(opt);
                    });
                });

                function filterAndSortCards() {
                    const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';
                    const sortMode = sortSelect ? sortSelect.value : '';
                    const cards = Array.from(grid.querySelectorAll('.crud-card-wrap'));

                    cards.forEach(function(card) {
                        // Search
                        const text = card.textContent.toLowerCase();
                        const matchesSearch = !searchTerm || text.includes(searchTerm);
                        
                        // Filters
                        let matchesFilters = true;
                        filterSelects.forEach(select => {
                            const field = select.getAttribute('data-filter-field');
                            const filterVal = select.value;
                            if (filterVal !== 'ALL') {
                                const cardVal = (card.getAttribute('data-' + field) || '').trim();
                                if (cardVal !== filterVal) matchesFilters = false;
                            }
                        });

                        card.style.display = (matchesSearch && matchesFilters) ? '' : 'none';
                    });

                    // Sort
                    if (sortMode) {
                        const parts = sortMode.split('_');
                        const direction = parts.pop();
                        const field = parts.join('_').toLowerCase();

                        const visibleCards = cards.filter(c => c.style.display !== 'none');
                        visibleCards.sort(function(a, b) {
                            let valA = (a.getAttribute('data-' + field) || '').trim();
                            let valB = (b.getAttribute('data-' + field) || '').trim();
                            
                            const cleanNum = (s) => s.replace(/[^0-9.-]/g, '');
                            let numA = parseFloat(cleanNum(valA.replace(',', '.')));
                            let numB = parseFloat(cleanNum(valB.replace(',', '.')));

                            if (!isNaN(numA) && !isNaN(numB)) {
                                return direction === 'asc' ? numA - numB : numB - numA;
                            }
                            return direction === 'asc' ? valA.localeCompare(valB) : valB.localeCompare(valA);
                        });
                        visibleCards.forEach(c => grid.appendChild(c));
                    }
                }

                if (searchInput) searchInput.addEventListener('input', filterAndSortCards);
                if (sortSelect) sortSelect.addEventListener('change', filterAndSortCards);
                filterSelects.forEach(s => {
                    s.addEventListener('change', filterAndSortCards);
                    s.addEventListener('input', filterAndSortCards);
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init{{ crudId }});
            } else {
                init{{ crudId }}();
            }
        })();
        </script>
    </div>
    
    <style>
    .scout-crud-card:hover { transform: translateY(-5px) !important; box-shadow: 0 10px 25px rgba(59,130,246,0.15) !important; border-color: rgba(59,130,246,0.3) !important; }
    .filter-group select:focus { border-color: #ff005a !important; box-shadow: none !important; }
    </style>
{% endmacro %}
