{% extends 'base.html.twig' %}

{% block title %}LAMMA - Bienvenue{% endblock %}
{% block page_title %}Bienvenue sur LAMMA{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8 text-center text-white">
        <h1 style="color: white; font-family: 'Anton', sans-serif; font-size: 4rem; margin-bottom: 30px;">PRÊT POUR L'EXPÉDITION ?</h1>
        
        <p style="font-size: 1.2rem; margin-bottom: 40px; color: #ccc;">
            Bienvenue sur la plateforme logistique complète de synchronisation d'événements, 
            de restauration et de participations. LAMMA propulse vos expériences au niveau supérieur.
        </p>

        <div class="d-flex justify-content-center gap-4">
            <a href="{{ path('app_evenement_index') }}" class="genric-btn danger e-large" style="margin-right: 20px;">DÉCOUVRIR LES ÉVÉNEMENTS</a>
            <a href="{{ path('app_abonnement_index') }}" class="genric-btn info-border e-large">NOS ABONNEMENTS</a>
        </div>
        
        <div style="margin-top: 80px;">
            <img src="{{ asset('img/performer/1.png') }}" alt="Performers" class="img-fluid" style="border-radius: 15px; box-shadow: 0 10px 30px rgba(255, 0, 90, 0.2);">
        </div>
    </div>
</div>
{% endblock %}
