{% extends 'base_admin.html.twig' %}

{% block title %}Éditer un Programme{% endblock %}

{% block body %}
    <h1 class="mt-4">Éditer un Programme</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="{{ path('app_evenement_index') }}">Événements</a></li>
        <li class="breadcrumb-item active">Éditer {{ programme.titre }}</li>
    </ol>
    
    <div class="card mb-4 bg-dark text-white border-secondary">
        <div class="card-header border-secondary border-bottom">
            <i class="fas fa-edit me-1"></i> Formulaire de modification
        </div>
        <div class="card-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                {{ form_widget(form) }}
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <button type="submit" class="btn btn-danger px-5 fw-bold" style="background-color:#ff3c36; border:none; border-radius:0;">METTRE À JOUR</button>
            {{ form_end(form) }}
                
                <form method="post" action="{{ path('app_programme_delete', {'id_prog': programme.id_prog}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ programme.id_prog) }}">
                    <button class="btn btn-outline-danger btn-sm p-2"><i class="fa fa-trash"></i> Supprimer</button>
                </form>
                </div>
        </div>
    </div>
{% endblock %}
