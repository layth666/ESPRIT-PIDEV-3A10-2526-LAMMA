{% extends 'base.html.twig' %}

{% block title %}Mes Restaurants Favoris - LAMMA{% endblock %}
{% block page_title %}Restaurants Favoris{% endblock %}

{% block body %}
<section class="crud-section mt-5 mb-5">
    <div class="row align-items-center mb-5">
        <div class="col-md-8 text-center text-md-left">
            <h2 style="font-family:'Anton',sans-serif; color:var(--scout-navy); text-transform:uppercase;">
                <i class="fa fa-heart" style="color:#ff005a;"></i> Ma Sélection d'Établissements
            </h2>
            <p style="color: #64748b;">Retrouvez ici tous les restaurants que vous avez marqués comme favoris.</p>
        </div>
        <div class="col-md-4 text-center text-md-right">
            <a href="{{ path('app_user_dashboard') }}" class="btn btn-sm" style="background: rgba(255,255,255,0.1); color: #fff; padding: 10px 20px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.2);">
                <i class="fa fa-arrow-left"></i> Retour au Dashboard
            </a>
        </div>
    </div>

    <div class="row">
        {% for entity in items %}
            <div class="col-xl-4 col-lg-6 col-md-6 mb-4">
                <div class="glass-panel" style="padding: 25px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.05); transition: 0.3s;">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h3 style="font-family: 'Anton', sans-serif; font-size: 1.25rem; color: #f97316; margin: 0; text-transform: uppercase;">{{ entity.nom }}</h3>
                        <div style="color: #f1c40f;"><i class="fa fa-star"></i> {{ entity.rating|default('0.0') }}</div>
                    </div>
                    
                    <div style="font-size: 0.85rem; color: #94a3b8; margin-bottom: 20px;">
                        <span style="display: block; margin-bottom: 5px;"><i class="fa fa-map-marker" style="color: #3b82f6; width: 22px;"></i> {{ entity.adresse|default('Position non certifiée') }}</span>
                        <span style="display: block; margin-bottom: 5px;"><i class="fa fa-phone" style="color: #3b82f6; width: 22px;"></i> {{ entity.telephone|default('N/A') }}</span>
                    </div>

                    <div class="d-flex gap-2">
                        <a href="{{ path('app_restaurant_show', {id: entity.id}) }}" class="btn btn-sm" style="background: rgba(59,130,246,0.1); color: #3b82f6; border: 1px solid #3b82f6; border-radius: 12px; font-weight: 800; flex: 1; text-align: center; padding: 10px;">
                            VOIR PROFIL
                        </a>
                        <button class="btn-favorite active" data-type="RESTAURANT" data-id="{{ entity.id }}" 
                                style="background: rgba(255,0,90,0.3); border: 1px solid rgba(255,0,90,0.3); color: #ff005a; border-radius: 12px; padding: 10px; width: 45px; cursor: pointer;">
                            <i class="fa fa-heart"></i>
                        </button>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <i class="fa fa-heart-o mb-3" style="font-size: 3rem; color: #ff005a; opacity: 0.3;"></i>
                <h3 style="color:#94a3b8;">Vous n'avez pas encore de restaurants favoris.</h3>
                <a href="{{ path('app_restaurant_index') }}" class="genric-btn danger-border radius mt-3">Explorer les restaurants</a>
            </div>
        {% endfor %}
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const favoriteBtns = document.querySelectorAll('.btn-favorite');
    favoriteBtns.forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            const type = this.getAttribute('data-type');
            const id = this.getAttribute('data-id');
            const icon = this.querySelector('i');
            
            fetch("{{ path('app_favori_toggle') }}", {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ type: type, id: id })
            })
            .then(res => res.json())
            .then(data => {
                if (data.active) {
                    icon.classList.remove('fa-heart-o');
                    icon.classList.add('fa-heart');
                    this.style.background = 'rgba(255,0,90,0.3)';
                } else {
                    icon.classList.remove('fa-heart');
                    icon.classList.add('fa-heart-o');
                    this.style.background = 'rgba(255,0,90,0.1)';
                    // Optionally remove parent card if unfavorited from this specific page
                    // this.closest('.col-xl-4').style.opacity = '0.5';
                }
            });
        });
    });
});
</script>
{% endblock %}
