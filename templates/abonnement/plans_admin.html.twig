{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des Plans d'Abonnement - Admin{% endblock %}
{% block admin_title %}Plans d'Abonnement{% endblock %}

{% block admin_content %}
<section class="crud-section">

    {# Header #}
    <div class="row align-items-center mb-4">
        <div class="col-md-7">
            <h2 style="font-family:'Anton',sans-serif;color:var(--scout-navy); margin: 0;">
                Offres & Plans d'Abonnement
            </h2>
            <div style="font-size: 0.85rem; color: var(--text-dim); font-weight: 600; margin-top: 4px;">
                Créez et gérez les plans proposés à vos utilisateurs
            </div>
        </div>
        <div class="col-md-5 text-right d-flex justify-content-end gap-2" style="gap:12px;">
            <a href="{{ path('app_abonnement_index') }}" class="btn btn-sm"
               style="background:rgba(255,255,255,0.08);color:#cbd5e1;border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:8px 16px;font-weight:600;">
                <i class="fa fa-list"></i> Souscriptions
            </a>
            <a href="{{ path('app_abonnement_plan_new') }}"
               style="background:linear-gradient(135deg,#3b82f6,#8b5cf6);color:#fff;border:none;border-radius:8px;padding:9px 22px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:8px;box-shadow:0 4px 15px rgba(59,130,246,0.35);">
                <i class="fa fa-plus"></i> Créer un Plan
            </a>
        </div>
    </div>

    {# Flash #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'error' ? 'danger' : 'warning') }} mb-3"
                 style="border-radius:10px;font-weight:600;">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Grille des plans #}
    {% if plans is empty %}
        <div class="scout-card text-center" style="padding: 60px 20px;">
            <div style="font-size: 3rem; margin-bottom: 16px; opacity:0.4;">📭</div>
            <h4 style="color:#94a3b8;">Aucun plan créé</h4>
            <p style="color:#64748b;font-size:0.9rem;">Commencez par créer votre première offre d'abonnement.</p>
            <a href="{{ path('app_abonnement_plan_new') }}"
               style="display:inline-block;margin-top:16px;background:#3b82f6;color:#fff;padding:10px 28px;border-radius:8px;font-weight:700;text-decoration:none;">
                + Créer un Plan
            </a>
        </div>
    {% else %}
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;">
            {% for plan in plans %}
                {% set typeColors = {
                    'MENSUEL':       {'bg': 'linear-gradient(135deg,#1e3a5f,#2d6a9f)', 'border': 'rgba(59,130,246,0.4)', 'badge': '#3b82f6'},
                    'ANNUEL':        {'bg': 'linear-gradient(135deg,#2d1b69,#7c3aed)', 'border': 'rgba(139,92,246,0.4)', 'badge': '#8b5cf6'},
                    'PREMIUM':       {'bg': 'linear-gradient(135deg,#78350f,#d97706)', 'border': 'rgba(245,158,11,0.5)', 'badge': '#f59e0b'},
                    'EVENEMENT_PASS':{'bg': 'linear-gradient(135deg,#064e3b,#059669)', 'border': 'rgba(16,185,129,0.4)',  'badge': '#10b981'}
                } %}
                {% set colors = typeColors[plan.type] ?? {'bg': '#1e293b', 'border': 'rgba(255,255,255,0.1)', 'badge': '#64748b'} %}
                {% set typeIcons = {'MENSUEL':'📅','ANNUEL':'🗓️','PREMIUM':'👑','EVENEMENT_PASS':'🎫'} %}

                <div style="background:{{ colors.bg }};border:1px solid {{ colors.border }};border-radius:16px;padding:24px;display:flex;flex-direction:column;gap:16px;transition:transform 0.2s,box-shadow 0.2s;"
                     onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 20px 40px rgba(0,0,0,0.4)'"
                     onmouseout="this.style.transform='';this.style.boxShadow=''">

                    {# Top row #}
                    <div class="d-flex justify-content-between align-items-start">
                        <div style="font-size:2rem;">{{ typeIcons[plan.type] ?? '📦' }}</div>
                        <span style="background:{{ colors.badge }};color:#fff;font-size:0.7rem;font-weight:800;padding:4px 12px;border-radius:20px;letter-spacing:1px;text-transform:uppercase;">
                            {{ plan.type }}
                        </span>
                    </div>

                    {# Nom + Prix #}
                    <div>
                        <div style="font-size:1.1rem;font-weight:800;color:#fff;">{{ plan.nom }}</div>
                        <div style="font-size:1.8rem;font-weight:900;color:#fff;margin-top:4px;">
                            {{ plan.prix|number_format(2, ',', ' ') }}€
                            <span style="font-size:0.75rem;font-weight:500;color:rgba(255,255,255,0.6);">HT</span>
                        </div>
                    </div>

                    {# Détails #}
                    <div style="font-size:0.82rem;color:rgba(255,255,255,0.65);display:flex;flex-direction:column;gap:6px;">
                        {% if plan.restrictionType %}
                            <div>🌿 Restriction: {{ plan.restrictionType }}</div>
                        {% endif %}
                        <div>🔄 Auto-renew: {{ plan.autoRenew ? 'Oui' : 'Non' }}</div>
                        <div>📌 Statut: <strong style="color:{{ plan.statut == 'ACTIF' ? '#6ee7b7' : '#fca5a5' }};">{{ plan.statut }}</strong></div>
                    </div>

                    {# Actions #}
                    <div style="display:flex;gap:10px;margin-top:auto;padding-top:8px;border-top:1px solid rgba(255,255,255,0.1);">
                        <a href="{{ path('app_abonnement_plan_edit', {id: plan.id}) }}"
                           style="flex:1;text-align:center;padding:9px;border-radius:8px;background:rgba(255,255,255,0.12);color:#fff;font-weight:700;font-size:0.82rem;text-decoration:none;transition:background 0.2s;"
                           onmouseover="this.style.background='rgba(255,255,255,0.2)'"
                           onmouseout="this.style.background='rgba(255,255,255,0.12)'">
                            ✏️ Modifier
                        </a>
                        <form method="post" action="{{ path('app_abonnement_plan_delete', {id: plan.id}) }}"
                              onsubmit="return confirm('Supprimer ce plan ? Cette action est irréversible.');"
                              style="flex:1;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_plan_' ~ plan.id) }}">
                            <button type="submit"
                                    style="width:100%;padding:9px;border-radius:8px;background:rgba(239,68,68,0.2);color:#fca5a5;border:1px solid rgba(239,68,68,0.3);font-weight:700;font-size:0.82rem;cursor:pointer;transition:background 0.2s;"
                                    onmouseover="this.style.background='rgba(239,68,68,0.35)'"
                                    onmouseout="this.style.background='rgba(239,68,68,0.2)'">
                                🗑 Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</section>
{% endblock %}
