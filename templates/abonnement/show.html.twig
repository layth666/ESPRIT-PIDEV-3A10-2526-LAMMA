{% extends 'base.html.twig' %}

{% block title %}Détails Abonnement - LAMMA{% endblock %}
{% block page_title %}Abonnement {% endblock %}
{% block page_subtitle %}Consulter les informations de l'abonnement{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card card-detail">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fa fa-info-circle"></i> Détails de l'Abonnement</span>
                        <span class="badge badge-status badge-{{ abonnement.statut }}">{{ abonnement.statut }}</span>
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered">
                            <tbody>
                                <tr><th>Utilisateur</th><td>{{ abonnement.userId }}</td></tr>
                                <tr><th>Nom de l'abonnement</th><td>{{ abonnement.nom ?? '-' }}</td></tr>
                                <tr><th>Type</th><td><span class="badge badge-status badge-{{ abonnement.type }}">{{ abonnement.type }}</span></td></tr>
                                <tr><th>Date de Début</th><td>{{ abonnement.dateDebut|date('d/m/Y') }}</td></tr>
                                <tr><th>Date de Fin</th><td>{{ abonnement.dateFin ? abonnement.dateFin|date('d/m/Y') : '-' }}</td></tr>
                                <tr><th>Prix</th><td>{{ abonnement.prix }} €</td></tr>
                                <tr><th>Renouvellement auto</th><td>{{ abonnement.autoRenew ? 'Oui' : 'Non' }}</td></tr>
                                <tr><th>Points accumulés</th><td>{{ abonnement.pointsAccumules }}</td></tr>
                                <tr><th>Score de désabonnement</th><td>{{ abonnement.churnScore }}</td></tr>
                                <tr><th>ID Événement lié</th><td>{{ abonnement.evenementId ?? '-' }}</td></tr>
                                <tr><th>Type de restriction</th><td>{{ abonnement.restrictionType ?? 'Aucune' }}</td></tr>
                            </tbody>
                        </table>
                        <div class="mt-4 text-center">
                            {% if is_granted('ROLE_ADMIN') %}
                                {% if abonnement.statut != 'ACTIF' %}
                                    <a href="{{ path('app_abonnement_confirmer', {id: abonnement.id}) }}" class="btn btn-success" style="border-radius:25px;padding:10px 30px;">✅ Activer</a>
                                {% endif %}
                                {% if abonnement.statut != 'SUSPENDU' %}
                                    <a href="{{ path('app_abonnement_suspendre', {id: abonnement.id}) }}" class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">⏸ Suspendre</a>
                                {% endif %}
                                <form method="post" action="{{ path('app_abonnement_delete', {id: abonnement.id}) }}" onsubmit="return confirm('Supprimer cet abonnement ?');" style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ abonnement.id) }}">
                                    <button type="submit" class="btn btn-danger" style="border-radius:25px;padding:10px 30px;">🗑 Supprimer</button>
                                </form>
                            {% else %}
                                <a href="{{ path('app_abonnement_edit', {id: abonnement.id}) }}" class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">Modifier</a>
                            {% endif %}
                            <a href="{{ path('app_abonnement_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Retour à la liste</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

