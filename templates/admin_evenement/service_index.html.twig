{% extends 'base_admin.html.twig' %}

{% block title %}Gestion des Services{% endblock %}

{% block body %}
    <h1 class="mt-4">Gestion des Services</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">Catalogue des services</li>
    </ol>

    <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-cogs me-1"></i>
                Liste des Services
            </div>
            <a href="#" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Créer un Service</a>
        </div>
        <div class="card-body">
            <table id="datatablesSimple" class="table table-bordered table-striped" style="width:100%">
                <thead>
                    <tr>
                        <th style="width: 5%">ID</th>
                        <th>Nom du Service</th>
                        <th>Description</th>
                        <th>Prix (€)</th>
                    </tr>
                </thead>
                <tbody>
                {% for service in services %}
                    <tr>
                        <td>{{ service.id }}</td>
                        <td>{{ service.nom }}</td>
                        <td>{{ service.description|length > 50 ? service.description|slice(0, 50) ~ '...' : service.description }}</td>
                        <td>{{ service.prix }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center">Aucun service n'a été créé pour le moment.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
