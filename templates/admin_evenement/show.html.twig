{% extends 'base_admin.html.twig' %}

{% block title %}Détail de l'événement{% endblock %}

{% block body %}
    <h1 class="mt-4">Détails : {{ evenement.titre }}</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="{{ path('app_evenement_index') }}">Événements</a></li>
        <li class="breadcrumb-item active">Inspection</li>
    </ol>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4 shadow-sm">
                <div class="card-header">
                    <i class="fas fa-eye me-1"></i> Synthèse de la fiche événement
                </div>
                <div class="card-body">
                    <table class="table table-bordered table-striped">
                        <tbody>
                            <tr><th style="width: 30%">Titre</th><td>{{ evenement.titre }}</td></tr>
                            <tr><th>Description</th><td>{{ evenement.description }}</td></tr>
                            <tr><th>Type</th><td>{{ evenement.type }}</td></tr>
                            <tr><th>Date de Début</th><td>{{ evenement.date_debut ? evenement.date_debut|date('d/m/Y') : '' }}</td></tr>
                            <tr><th>Date de Fin</th><td>{{ evenement.date_fin ? evenement.date_fin|date('d/m/Y') : '' }}</td></tr>
                            <tr><th>Lieu</th><td>{{ evenement.lieu }}</td></tr>
                            <tr><th>Vues Actuelles</th><td><span class="badge bg-primary">{{ evenement.nb_vues }}</span></td></tr>
                            <tr><th>Aperçu Image</th><td>
                                {% if evenement.image is not empty %}
                                <img src="{{ evenement.image starts with 'http' ? evenement.image : asset('uploads/' ~ evenement.image) }}"
                                     class="img-fluid rounded shadow" 
                                     alt="Affiche" 
                                     style="max-height: 400px; border: 1px solid #444;">

                                {% else %}
                                    <span class="text-muted">Aucune image assignée</span>
                                {% endif %}
                            </td></tr>
                        </tbody>
                    </table>
                    
                    <h5 class="mt-4 border-bottom pb-2"><i class="fas fa-list-ol text-secondary"></i> Programmes de l'événement</h5>
                    {% if evenement.programmes is not empty %}
                        <table class="table table-sm table-hover table-bordered mt-3">
                            <thead class="table-dark">
                                <tr>
                                    <th>Description / Détail</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for prog in evenement.programmes %}
                                    <tr>
                                        <td><strong>{{ prog.titre }}</strong><br><small class="text-muted">{{ prog.date_debut|date('d/m/Y H:i') }} {{ prog.date_fin ? 'au ' ~ prog.date_fin|date('d/m/Y H:i') : '' }}</small></td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% else %}
                        <p class="text-muted mt-2">Aucun programme n'est assigné Ã  cet événement.</p>
                    {% endif %}

                    <div class="d-flex justify-content-between mt-4 border-top pt-3">
                        <a href="{{ path('app_evenement_index') }}" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Retour Ã  la table</a>
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_programme_new') }}" class="btn btn-success"><i class="fas fa-plus"></i> Ajouter Prog</a>
                            <a href="{{ path('app_evenement_edit', {'id': evenement.id_event}) }}" class="btn btn-warning text-white"><i class="fas fa-edit"></i> Modifier</a>
                            {{ include('evenement/_delete_form.html.twig') }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
