{% extends 'base_admin.html.twig' %}

{% block title %}Liste des événements{% endblock %}

{% block body %}
    <h1 class="mt-4">Gestion des Événements</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">Visualisez tous vos événements depuis la base de données.</li>
    </ol>

    <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-table me-1"></i>
                Base de données des Événements
            </div>
            <a href="{{ path('app_evenement_new') }}" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Créer un événement</a>
        </div>
        <div class="card-body">
            <table class="table table-bordered table-striped" style="width:100%">
                <thead>
                    <tr>
                        <th style="width: 5%">ID</th>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Lieu</th>
                        <th>Date Début</th>
                        <th>Date Fin</th>
                        <th>Vues</th>
                        <th style="width: 15%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for evenement in evenements %}
                    <tr>
                        <td>{{ evenement.id_event }}</td>
                        <td>{{ evenement.titre }}</td>
                        <td>{{ evenement.type }}</td>
                        <td>{{ evenement.lieu }}</td>
                        <td>{{ evenement.date_debut ? evenement.date_debut|date('d/m/Y') : '' }}</td>
                        <td>{{ evenement.date_fin ? evenement.date_fin|date('d/m/Y') : '' }}</td>
                        <td>{{ evenement.nb_vues }}</td>
                        <td>
                            <a href="{{ path('app_evenement_show', {'id': evenement.id_event}) }}" class="btn btn-info btn-sm text-white" title="Voir"><i class="fas fa-eye"></i></a>
                            <a href="{{ path('app_evenement_edit', {'id': evenement.id_event}) }}" class="btn btn-warning btn-sm text-white" title="Modifier"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center">Aucun événement n'a été trouvé.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            
            <div class="d-flex justify-content-center mt-4">
                {{ knp_pagination_render(evenements) }}
            </div>
        </div>
    </div>
{% endblock %}
