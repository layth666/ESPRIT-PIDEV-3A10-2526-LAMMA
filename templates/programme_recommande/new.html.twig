{% extends 'base.html.twig' %}

{% block title %}Nouveau Programme - LAMMA{% endblock %}
{% block page_title %}Ajouter une Activité{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="fiche-card">
                    <div class="fiche-header text-uppercase">
                        <i class="fa fa-star mr-2"></i> FICHE D'INFORMATION PROGRAMME RECOMMANDÉ
                    </div>
                    <div class="fiche-body">
                        {{ form_start(form) }}
                        
                        <div class="fiche-row">
                            <div class="fiche-col">{{ form_row(form.nom) }}</div>
                            <div class="fiche-col">{{ form_row(form.score) }}</div>
                        </div>
                        
                        <div class="form-group mb-4">
                            {{ form_row(form.description) }}
                        </div>

                        <div class="mt-5 text-center">
                            <button type="submit" class="btn btn-publier">Enregistrer le Programme</button>
                            <a href="{{ path('app_programme_recommande_index') }}" class="btn btn-annuler">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
