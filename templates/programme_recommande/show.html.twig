{% extends 'base.html.twig' %}

{% block title %}Détails Programme - LAMMA{% endblock %}
{% block page_title %}Consultation Activité{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card card-detail">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="fa fa-info-circle"></i> Détails : {{ item.activite }}</span>
                        <span class="badge badge-status badge-{{ item.recommande ? 'actif' : 'expire' }}">{{ item.recommande ? 'RECOMMANDÉ' : 'NOTÉ' }}</span>
                    </div>
                    <div class="card-body">
                        <h3>{{ item.activite }}</h3>
                        <p class="mb-4"><i class="fa fa-clock-o"></i> Horaires : {{ item.heureDebut|date('H:i') }} - {{ item.heureFin|date('H:i') }}</p>
                        <div class="mb-4">
                            <span class="badge badge-pill badge-primary p-2 px-3">Ambiance : {{ item.ambiance }}</span>
                        </div>
                        <hr>
                        <h5>Justification</h5>
                        <p class="p-3 bg-light rounded">{{ item.justification ?? 'Pas de justification.' }}</p>
                        <div class="mt-4 text-center">
                            <a href="{{ path('app_programme_recommande_edit', {id: item.id}) }}" class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">Modifier</a>
                            <a href="{{ path('app_programme_recommande_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Retour</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
