{% extends 'base.html.twig' %}

{% block title %}Tail Rations 2026 - LAMMA{% endblock %}

{% block stylesheets %}
<style>
    body {
        background-color: #0b0f19 !important;
        color: #f8fafc !important;
    }
    .rations-sidebar {
        width: 280px;
        background: rgba(15, 23, 42, 0.5);
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        height: calc(100vh - 80px);
        padding: 30px;
        position: sticky;
        top: 80px;
    }
    .sidebar-title {
        font-family: 'Anton', sans-serif;
        font-size: 1.5rem;
        margin-bottom: 5px;
        text-transform: uppercase;
    }
    .sidebar-subtitle {
        color: #94a3b8;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 1px;
        margin-bottom: 40px;
        display: block;
    }
    .nav-pills-custom .nav-link {
        color: #94a3b8;
        background: transparent;
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 10px 15px;
        border-radius: 8px;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .nav-pills-custom .nav-link.active {
        background: #f97316 !important;
        color: white !important;
    }
    .ration-card {
        background: rgba(30, 41, 59, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
        display: flex;
        gap: 20px;
        transition: all 0.3s;
        text-decoration: none !important;
    }
    .ration-card:hover {
        background: rgba(30, 41, 59, 0.7);
        border-color: #10b981;
    }
    .ration-img {
        width: 100px;
        height: 100px;
        border-radius: 12px;
        object-fit: cover;
    }
    .ration-info h3 {
        font-family: 'Anton', sans-serif;
        font-size: 1.2rem;
        margin-bottom: 5px;
    }
    .ration-desc {
        font-size: 0.8rem;
        color: #64748b;
        margin-bottom: 10px;
    }
    .ration-price {
        color: #10b981;
        font-weight: 900;
        font-size: 1.1rem;
    }
    .main-ration-content {
        flex-grow: 1;
        padding: 40px;
    }
    .search-bar-rations {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 10px 20px;
        color: white;
        width: 100%;
        max-width: 400px;
    }
</style>
{% endblock %}

{% block body %}
<div class="d-flex">
    <!-- Sidebar -->
    <div class="rations-sidebar d-none d-lg-block">
        <div class="sidebar-title">Trail Rations 2026</div>
        <span class="sidebar-subtitle"><i class="fa fa-folder-open"></i> LAMMA EXPEDITION</span>
        
        <div class="nav flex-column nav-pills nav-pills-custom">
            <a class="nav-link active" href="#"><i class="fa fa-circle"></i> ALL GEAR</a>
            <a class="nav-link" href="#"><i class="fa fa-heart"></i> MY SAVED</a>
            <a class="nav-link" href="#"><i class="fa fa-mountain"></i> HIGH-ALT</a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-ration-content">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 style="font-family:'Anton', sans-serif; text-transform:uppercase;">Explore Our Bowls</h2>
            
            <button id="btn-surprise-meal" class="btn" style="background: linear-gradient(135deg, #f97316, #eab308); color: white; font-weight: 800; border-radius: 10px; padding: 10px 20px; box-shadow: 0 4px 15px rgba(249, 115, 22, 0.4); border: none; transition: transform 0.2s;">
                <i class="fa fa-magic"></i> Plat Surprise (IA)
            </button>

            <div class="position-relative">
                <i class="fa fa-search position-absolute" style="left: 15px; top: 15px; color: #475569;"></i>
                <input type="text" class="search-bar-rations pl-5" placeholder="Scout for trail rations...">
            </div>
        </div>

        <div class="row" id="meal-grid">
            {% for item in items %}
                <div class="col-md-12">
                    <a href="{{ path('app_repas_personnaliser', {id: item.id}) }}" class="ration-card">
                        <img src="{{ item.imageUrl|default('https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=1000&auto=format&fit=crop') }}" alt="{{ item.nom }}" class="ration-img">
                        <div class="ration-info">
                            <h3>{{ item.nom }}</h3>
                            <div style="font-size: 0.6rem; color: #10b981; font-weight: 800; margin-bottom: 5px;">LIGHT PACK <i class="fa fa-leaf"></i> FORAGER <i class="fa fa-bolt"></i></div>
                            <p class="ration-desc">{{ item.description|slice(0, 100) }}...</p>
                            <div class="ration-price">{{ item.prix }} €</div>
                        </div>
                    </a>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    document.getElementById('btn-surprise-meal').addEventListener('click', function() {
        const btn = this;
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Génération...';
        btn.disabled = true;

        fetch('https://www.themealdb.com/api/json/v1/1/random.php')
            .then(response => response.json())
            .then(data => {
                const meal = data.meals[0];
                const grid = document.getElementById('meal-grid');
                
                // Create a new card HTML
                const newCard = document.createElement('div');
                newCard.className = 'col-md-12';
                newCard.innerHTML = `
                    <div class="ration-card" style="border-color: #f97316; box-shadow: 0 0 20px rgba(249, 115, 22, 0.2);">
                        <img src="${meal.strMealThumb}" alt="${meal.strMeal}" class="ration-img">
                        <div class="ration-info">
                            <h3>⭐ ${meal.strMeal} (Surprise du Chef)</h3>
                            <div style="font-size: 0.6rem; color: #f97316; font-weight: 800; margin-bottom: 5px;">ORIGINE: ${meal.strArea.toUpperCase()} <i class="fa fa-globe"></i> THE MEAL DB API</div>
                            <p class="ration-desc">${meal.strInstructions.substring(0, 120)}...</p>
                            <div class="ration-price">
                                15.00 € <span style="font-size: 0.7rem; color: #64748b; font-weight: normal;">(Prix suggéré)</span>
                                <button class="btn btn-sm btn-success float-right add-api-cart-btn" style="border-radius: 8px;"
                                    data-nom="⭐ ${meal.strMeal} (Surprise)"
                                    data-desc="${meal.strInstructions}"
                                    data-img="${meal.strMealThumb}">
                                    <i class="fa fa-cart-plus"></i> Ajouter
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                
                // Add it to the top of the grid with a fade-in animation
                newCard.style.opacity = '0';
                newCard.style.transform = 'translateY(-20px)';
                newCard.style.transition = 'all 0.5s ease-out';
                grid.insertBefore(newCard, grid.firstChild);
                
                // Trigger animation
                setTimeout(() => {
                    newCard.style.opacity = '1';
                    newCard.style.transform = 'translateY(0)';
                }, 50);

                if (typeof toastr !== 'undefined') {
                    toastr.success('La recette magique ' + meal.strMeal + ' a été ajoutée !');
                }

                // Restore button
                btn.innerHTML = originalText;
                btn.disabled = false;
            })
            .catch(error => {
                console.error("Erreur TheMealDB:", error);
                btn.innerHTML = originalText;
                btn.disabled = false;
                if (typeof toastr !== 'undefined') toastr.error('Erreur lors de la génération du plat.');
            });
    });

    // Event delegation for "Ajouter au Panier" on dynamic API cards
    document.getElementById('meal-grid').addEventListener('click', function(e) {
        const targetBtn = e.target.closest('.add-api-cart-btn');
        if (!targetBtn) return;
        
        e.preventDefault();
        
        const originalHtml = targetBtn.innerHTML;
        targetBtn.innerHTML = '<i class="fa fa-spinner fa-spin"></i>';
        targetBtn.disabled = true;

        const formData = new FormData();
        formData.append('nom', targetBtn.getAttribute('data-nom'));
        formData.append('description', targetBtn.getAttribute('data-desc'));
        formData.append('imageUrl', targetBtn.getAttribute('data-img'));

        fetch('{{ path("app_cart_add_api_meal") }}', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                if (typeof toastr !== 'undefined') {
                    toastr.success(data.message);
                }
                // Redirect to cart after 1 second
                setTimeout(() => {
                    window.location.href = '{{ path("app_cart_index") }}';
                }, 1000);
            }
        })
        .catch(err => {
            console.error(err);
            targetBtn.innerHTML = originalHtml;
            targetBtn.disabled = false;
            if (typeof toastr !== 'undefined') toastr.error('Erreur lors de l\'ajout au panier');
        });
    });
</script>
{% endblock %}
