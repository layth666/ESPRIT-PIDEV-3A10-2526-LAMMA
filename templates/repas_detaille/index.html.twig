{% extends 'admin/base_admin.html.twig' %}
{% import '_macros.html.twig' as macros %}

{% block title %}Repas Détaillés - LAMMA{% endblock %}
{% block admin_title %}Logs Nutritionnels{% endblock %}

{% block admin_content %}
<section class="crud-section">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 style="font-family:'Anton',sans-serif;color:var(--scout-navy); margin: 0;">Historique de Consommation</h2>
            <div style="font-size: 0.85rem; color: var(--text-dim); font-weight: 700;">Suivi détaillé des apports et des préférences de repas</div>
        </div>
        <div class="col-md-6 text-right">
            <a href="{{ path('app_repas_detaille_new') }}" class="btn-scout-confirm" style="padding: 10px 25px;"><i class="fa fa-plus"></i> NOUVEAU LOG</a>
        </div>
    </div>

    <div class="scout-card" style="padding: 0;">
        {% set columns = {
            'id': 'ID',
            'nom': 'Designation',
            'date': 'Consommé le',
            'calories': 'Kcal',
            'typeRepas': 'Type',
            'vegetarien': 'Végé',
            'actif': 'Actif'
        } %}
        {{ macros.crud_table(items, columns, 'app_repas_detaille_edit', 'app_repas_detaille_show', 'repas_detaille') }}
    </div>
</section>
{% endblock %}
