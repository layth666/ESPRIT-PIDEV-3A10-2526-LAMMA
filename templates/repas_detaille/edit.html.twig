{% extends 'base.html.twig' %}

{% block title %}Modifier Repas Détaille - LAMMA{% endblock %}
{% block page_title %}Édition de Repas Détaille{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card card-detail">
                    <div class="card-header">Mise à jour Dossier </div>
                    <div class="card-body form-section">
                        {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.nom) }}</div>
                            <div class="col-md-6">{{ form_row(form.prix) }}</div>
                            <div class="col-12">{{ form_row(form.description) }}</div>
                            <div class="col-md-4">{{ form_row(form.calories) }}</div>
                            <div class="col-md-4">{{ form_row(form.typeRepas) }}</div>
                            <div class="col-md-4">{{ form_row(form.date) }}</div>
                            <div class="col-md-3">{{ form_row(form.participantId) }}</div>
                            <div class="col-md-3">{{ form_row(form.evenementId) }}</div>
                            <div class="col-md-3">{{ form_row(form.restaurantId) }}</div>
                            <div class="col-md-3">{{ form_row(form.imageUrl) }}</div>
                            <div class="col-md-3" style="padding-top:30px;">{{ form_row(form.vegetarien) }}</div>
                            <div class="col-md-3" style="padding-top:30px;">{{ form_row(form.vegan) }}</div>
                            <div class="col-md-3" style="padding-top:30px;">{{ form_row(form.sansGluten) }}</div>
                            <div class="col-md-3" style="padding-top:30px;">{{ form_row(form.halal) }}</div>
                            <div class="col-12">{{ form_row(form.notes) }}</div>
                            <div class="col-md-3" style="padding-top:30px;">{{ form_row(form.actif) }}</div>
                        </div>
                        <div class="mt-4 text-center">
                            <button class="btn btn-add">Sauvegarder les modifications</button>
                            <a href="{{ path('app_repas_detaille_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
