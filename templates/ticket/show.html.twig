{% extends 'base.html.twig' %}

{% block title %}Détails Ticket - LAMMA{% endblock %}
{% block page_title %}Ticket {{ item.codeUnique }}{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card card-detail text-center">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span class="badge badge-info">{{ item.format }}</span>
                        <span class="badge badge-status badge-{{ item.statut }}">{{ item.statut }}</span>
                    </div>
                    <div class="card-body">
                        <div class="my-4">
                            {% if item.qrCode %}
                                <div class="p-3 bg-white d-inline-block border rounded">
                                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={{ item.qrCode|url_encode }}" alt="QR Code">
                                </div>
                            {% else %}
                                <div class="p-5 bg-light text-muted border rounded">
                                    <i class="fa fa-ticket fa-5x"></i>
                                </div>
                            {% endif %}
                        </div>
                        <h4 class="mb-3">{{ item.type }}</h4>
                        <h2 style="font-family:'Anton',sans-serif;letter-spacing:2px;color:#fb246a;">{{ item.codeUnique }}</h2>
                        <hr>
                        <div class="text-left px-3">
                            <p><strong>Lieu :</strong> {{ item.lieu ?? 'Non spécifié' }}</p>
                            <p><strong>Expire le :</strong> {{ item.dateExpiration ? item.dateExpiration|date('d/m/Y H:i') : 'Jamais' }}</p>
                            <p><strong>Créé le :</strong> {{ item.dateCreation|date('d/m/Y H:i') }}</p>
                            <p><strong>Notes :</strong> {{ item.informationsSupplementaires ?? '-' }}</p>
                        </div>
                        <div class="mt-4">
                            <a href="{{ path('app_ticket_edit', {id: item.id}) }}" class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">Modifier</a>
                            <a href="{{ path('app_ticket_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Retour</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
