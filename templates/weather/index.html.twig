{% extends 'base.html.twig' %}

{% block title %}Météo & Prévisions — LAMMA{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .lamma-weather { background: #0f172a; min-height: 100vh; color: #e5e7eb; padding: 3rem 0; }
    .weather-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 20px; padding: 2rem; }
    .temp-large { font-size: 4.5rem; font-weight: 900; color: #F97316; font-family: 'Anton', sans-serif; line-height: 1; }
    .obs-pill { background: rgba(51, 65, 85, 0.5); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px; padding: 1.25rem; text-align: center; }
    .obs-label { font-size: 0.75rem; text-transform: uppercase; color: #94a3b8; font-weight: 700; display: block; margin-bottom: 0.5rem; }
    .obs-val { font-size: 1.25rem; font-weight: 700; color: #fff; }
    #weather-chart { background: rgba(0,0,0,0.2); border-radius: 12px; padding: 1rem; margin-top: 2rem; }
</style>
{% endblock %}

{% block body %}
<div class="lamma-weather">
    <div class="container-fluid px-lg-5">
        <div class="d-flex align-items-center justify-content-between mb-5">
            <div>
                <h1 class="h2 text-white mb-2" style="font-family:'Anton', sans-serif;">PROCHAINES EXPÉDITIONS : MÉTÉO</h1>
                <p class="text-white-50 small mb-0"><i class="fa fa-map-marker-alt me-2"></i><span id="location-name">Tunis, TN</span> (Prévisions 14 jours)</p>
            </div>
            <div class="text-end">
                <div id="current-temp" class="temp-large">--°C</div>
                <div class="text-white-50 fw-bold uppercase small" style="letter-spacing: 2px;">Température Actuelle</div>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="obs-pill">
                    <span class="obs-label">🌅 Lever du soleil</span>
                    <span class="obs-val" id="sunrise-val">--:--</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="obs-pill">
                    <span class="obs-label">🌇 Coucher du soleil</span>
                    <span class="obs-val" id="sunset-val">--:--</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="obs-pill" style="border-color: #F97316;">
                    <span class="obs-label">📦 Risque Livraison</span>
                    <span class="obs-val text-prm">FAIBLE (Simulation)</span>
                </div>
            </div>
        </div>

        <div class="weather-card">
            <h4 class="text-white mb-4" style="font-family:'Anton', sans-serif;">RELEVÉS THERMIQUES HORAIRES</h4>
            <div id="loading-spinner" class="text-center py-5">
                <div class="spinner-border text-prm" role="status"></div>
                <p class="mt-3 text-white-50">Synchronisation via satellite...</p>
            </div>
            <div id="weather-chart"></div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const defaultApiUrl = '{{ api_url|raw }}';
        let chartInstance = null;

        async function fetchWeatherData(apiUrl) {
            try {
                const response = await fetch(apiUrl);
                const data = await response.json();

                document.getElementById('loading-spinner').style.display = 'none';

                const hourlyTime = data.hourly.time;
                const hourlyTemp = data.hourly.temperature_2m;
                const dailySunrise = data.daily.sunrise;
                const dailySunset = data.daily.sunset;

                // Current temp logic
                const now = new Date();
                let currentIndex = 0;
                let minDiff = Infinity;
                hourlyTime.forEach((timeStr, index) => {
                    const diff = Math.abs(now - new Date(timeStr));
                    if(diff < minDiff) { minDiff = diff; currentIndex = index; }
                });
                document.getElementById('current-temp').innerText = Math.round(hourlyTemp[currentIndex]) + '°C';

                const formatTime = (iso) => new Date(iso).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
                document.getElementById('sunrise-val').innerText = formatTime(dailySunrise[0]);
                document.getElementById('sunset-val').innerText = formatTime(dailySunset[0]);

                const chartData = hourlyTime.map((time, idx) => ({ x: new Date(time).getTime(), y: hourlyTemp[idx] }));

                const options = {
                    series: [{ name: 'Température (°C)', data: chartData }],
                    chart: { type: 'area', height: 400, toolbar: { show: false }, background: 'transparent' },
                    theme: { mode: 'dark' },
                    colors: ['#F97316'],
                    stroke: { curve: 'smooth', width: 3 },
                    fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.4, opacityTo: 0.1 } },
                    xaxis: { type: 'datetime', labels: { style: { colors: '#94a3b8' } } },
                    yaxis: { labels: { style: { colors: '#94a3b8' } } },
                    grid: { borderColor: 'rgba(255,255,255,0.05)' }
                };

                if(chartInstance) chartInstance.destroy();
                chartInstance = new ApexCharts(document.querySelector("#weather-chart"), options);
                chartInstance.render();

            } catch (error) {
                console.error("Météo Error:", error);
                document.getElementById('loading-spinner').innerHTML = '<p class="text-danger">Service temporairement indisponible.</p>';
            }
        }

        if ("geolocation" in navigator) {
            navigator.geolocation.getCurrentPosition(async (pos) => {
                const lat = pos.coords.latitude;
                const lon = pos.coords.longitude;
                try {
                    const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`);
                    const json = await res.json();
                    document.getElementById('location-name').innerText = json.address.city || json.address.town || 'Ma Position';
                } catch(e) {}
                fetchWeatherData(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=sunrise,sunset&hourly=temperature_2m&forecast_days=14`);
            }, () => fetchWeatherData(defaultApiUrl));
        } else fetchWeatherData(defaultApiUrl);
    });
</script>
{% endblock %}
