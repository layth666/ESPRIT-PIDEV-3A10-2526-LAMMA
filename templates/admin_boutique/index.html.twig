{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion Boutique — LAMMA{% endblock %}
{% block page_title %}Gestion Boutique{% endblock %}
{% block breadcrumb %}Catalogue et Ventes{% endblock %}

{% block body %}
    <div class="card shadow-sm mb-4 border-0" style="background: rgba(255,255,255,0.02) !important;">
        <div class="card-body p-3">
            <form method="get" action="{{ path('app_admin_boutique_index') }}" class="d-flex flex-wrap align-items-center justify-content-between gap-3" id="admin-toolbar"
                 data-search-url="{{ path('app_admin_boutique_search') }}">
                <div class="d-flex flex-wrap align-items-center gap-2 w-100 w-md-auto">
                    <input type="search" id="admin-q" name="q" value="{{ q|default('') }}" autocomplete="off"
                           class="form-control bg-dark border-secondary text-white" placeholder="Rechercher un produit…" style="min-width:250px;">
                    <select id="admin-categorie" name="categorie" class="form-select bg-dark border-secondary text-white" style="max-width:200px;">
                        {% for c in categories %}
                            <option value="{{ c }}" {% if c == current_categorie %}selected{% endif %}>{{ c }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="ms-auto">
                    <span class="badge bg-prm px-3 py-2 shadow-sm" id="admin-count">
                        {{ total }} résultat(s)
                    </span>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #3b82f6, #06b6d4) !important; color: white;">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <div class="display-5 fw-bold mb-1" style="font-family:'Anton', sans-serif;">{{ total }}</div>
                    <div class="text-white-50 text-uppercase fw-bold small" style="letter-spacing: 1px;">
                        <i class="fa fa-boxes me-2"></i>Produits en vente
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #10b981, #059669) !important; color: white;">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <div class="display-5 fw-bold mb-1" style="font-family:'Anton', sans-serif;">{{ livrable_count }}</div>
                    <div class="text-white-50 text-uppercase fw-bold small" style="letter-spacing: 1px;">
                        <i class="fa fa-truck me-2"></i>Livrables
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #f59e0b, #d97706) !important; color: white;">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <div class="display-5 fw-bold mb-1" style="font-family:'Anton', sans-serif;">{{ delivery_count }}</div>
                    <div class="text-white-50 text-uppercase fw-bold small" style="letter-spacing: 1px;">
                        <i class="fa fa-clock me-2"></i>Livraisons
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-transparent border-bottom border-secondary pt-4 px-4">
            <h5 class="m-0 text-white" style="font-family:'Anton', sans-serif; letter-spacing:1px;"><i class="fa fa-list me-2 text-prm"></i>Catalogue Équipements</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead style="background: rgba(255,255,255,0.05);">
                        <tr>
                            <th class="ps-3 text-muted small uppercase">#</th>
                            <th class="text-muted small uppercase">Nom</th>
                            <th class="text-muted small uppercase">Type</th>
                            <th class="text-muted small uppercase">Catégorie</th>
                            <th class="text-muted small uppercase">Statut</th>
                            <th class="text-muted small uppercase">Livrable</th>
                            <th class="text-muted small uppercase">Vendeur</th>
                            <th class="text-muted small uppercase">Acheteur</th>
                            <th class="text-muted small uppercase">Livraison</th>
                            <th class="text-end pe-3 text-muted small uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="admin-table-body">
                        {% include 'admin_boutique/_equipement_rows.html.twig' %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-transparent border-bottom border-secondary pt-4 px-4">
            <h5 class="m-0 text-white" style="font-family:'Anton', sans-serif; letter-spacing:1px;"><i class="fa fa-money-bill-wave me-2 text-success"></i>Transactions de la Boutique</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead style="background: rgba(255,255,255,0.05);">
                        <tr>
                            <th class="ps-3 text-muted small uppercase">Date</th>
                            <th class="text-muted small uppercase">Équipement</th>
                            <th class="text-muted small uppercase">Vendeur</th>
                            <th class="text-muted small uppercase">Acheteur</th>
                            <th class="text-muted small uppercase">Prix</th>
                            <th class="text-end pe-3 text-muted small uppercase">Réf/Token</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for t in transactions %}
                            <tr>
                                <td class="ps-3">{{ t.createdAt ? t.createdAt|date('d/m/Y H:i') : '-' }}</td>
                                <td><span class="badge bg-secondary">{{ t.equipement.nom }}</span></td>
                                <td>{{ t.seller.name }}</td>
                                <td>{{ t.buyer.name }}</td>
                                <td><span class="fw-bold text-success">{{ t.price }} TND</span></td>
                                <td class="text-end pe-3"><small class="text-muted">{{ t.stripeToken|default('-')|slice(0, 15) }}...</small></td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">Aucune vente enregistrée.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}

{% block extra_scripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const qInput = document.getElementById('admin-q');
            const catSelect = document.getElementById('admin-categorie');
            const tableBody = document.getElementById('admin-table-body');
            const countBadge = document.getElementById('admin-count');
            const toolbar = document.getElementById('admin-toolbar');
            
            if (!toolbar || !qInput) return;
            
            const searchUrl = toolbar.getAttribute('data-search-url');
            let searchTimer = null;

            function doSearch() {
                const q = qInput.value.trim();
                const cat = catSelect.value;
                const params = new URLSearchParams();
                if (q) params.set('q', q);
                if (cat) params.set('categorie', cat);
                
                fetch(searchUrl + '?' + params.toString())
                    .then(r => r.json())
                    .then(data => {
                        tableBody.innerHTML = data.html;
                        countBadge.textContent = data.count + ' résultat(s)';
                    });
            }

            qInput.addEventListener('input', () => {
                clearTimeout(searchTimer);
                searchTimer = setTimeout(doSearch, 300);
            });
            catSelect.addEventListener('change', doSearch);
        });
    </script>
{% endblock %}
