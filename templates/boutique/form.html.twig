{% extends 'base.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .lamma-form-area {
            background: #0f172a;
            min-height: 100vh;
            color: #e5e7eb;
            padding: 0;
            margin: 0;
            width: 100%;
            overflow-x: hidden;
        }

        .form-page-navbar {
            background: rgba(15, 23, 42, 0.98);
            border-bottom: 1px solid rgba(249, 115, 22, 0.25);
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 200;
            box-shadow: 0 2px 18px rgba(0, 0, 0, 0.24);
        }

        .form-page-navbar .nav-inner {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .form-page-navbar .nav-brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-weight: 700;
            color: #fff;
            text-decoration: none;
            font-size: 1.15rem;
        }

        .form-page-navbar .nav-brand span {
            font-size: 1.45rem;
        }

        .form-page-navbar .nav-actions {
            display: flex;
            align-items: center;
            gap: 0.85rem;
            flex-wrap: wrap;
        }

        .form-page-navbar .nav-actions a,
        .form-page-navbar .nav-actions button {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.55rem 1rem;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            transition: transform 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
        }

        .form-page-navbar .btn-primary {
            background: #F97316;
            color: #111827;
            border: none;
        }

        .form-page-navbar .btn-primary:hover {
            background: #fb923c;
            transform: translateY(-1px);
            box-shadow: 0 8px 18px rgba(249, 115, 22, 0.22);
        }

        .form-page-navbar .btn-secondary {
            background: rgba(255,255,255,0.08);
            color: #e5e7eb;
            border: 1px solid rgba(255,255,255,0.18);
        }

        .form-page-navbar .btn-secondary:hover {
            background: rgba(255,255,255,0.13);
            transform: translateY(-1px);
        }

        .form-page-layout {
            display: flex;
            gap: 1.75rem;
            padding: 2rem 2rem 3rem;
            max-width: 100%;
        }

        .form-page-main-full {
            flex: 1;
            min-width: 0;
            width: 100%;
        }

        .lamma-form-card {
            background: rgba(15,23,42,0.95);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 2rem;
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.18);
        }

        .form-hero {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.75rem;
            flex-wrap: wrap;
        }

        .form-hero h1 {
            margin: 0;
            font-size: 2rem;
            line-height: 1.1;
        }

        .form-hero p {
            margin: 0.35rem 0 0;
            color: #94a3b8;
        }

        .form-hero .btn-small {
            padding: 0.6rem 1rem;
            border-radius: 10px;
            font-size: 0.95rem;
        }

        .lamma-equipement-form {
            --lamma-input-bg: #1e293b;
            --lamma-input-fg: #f8fafc;
            --lamma-input-border: rgba(255,255,255,0.2);
            --lamma-label: #cbd5e1;
            --lamma-muted: #94a3b8;
        }

        .form-section {
            background: rgba(30, 41, 59, 0.5);
            border: 1px solid rgba(249, 115, 22, 0.15);
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 1rem;
        }

        .form-section h3 {
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .lamma-equipement-form .form-label {
            display: block;
            width: 100%;
            margin-bottom: 0.35rem;
            font-weight: 600;
            color: var(--lamma-label) !important;
        }

        .lamma-equipement-form .mb-3 {
            margin-bottom: 1.25rem !important;
        }

        .lamma-equipement-form .form-control,
        .lamma-equipement-form .form-select,
        .lamma-equipement-form textarea.form-control {
            width: 100% !important;
            max-width: 100%;
            display: block;
            background-color: var(--lamma-input-bg) !important;
            color: var(--lamma-input-fg) !important;
            border: 1px solid var(--lamma-input-border) !important;
            border-radius: 12px;
            padding: 0.75rem 1rem;
            box-shadow: none !important;
        }

        .lamma-equipement-form .form-control:focus,
        .lamma-equipement-form .form-select:focus,
        .lamma-equipement-form textarea.form-control:focus {
            background-color: #0f172a !important;
            color: #fff !important;
            border-color: #F97316 !important;
            box-shadow: 0 0 0 0.2rem rgba(249, 115, 22, 0.22) !important;
        }

        .lamma-equipement-form .form-control::placeholder,
        .lamma-equipement-form textarea::placeholder {
            color: #64748b !important;
            opacity: 1;
        }

        .lamma-equipement-form select.form-select option {
            background: #1e293b;
            color: #f8fafc;
        }

        .lamma-equipement-form .invalid-feedback,
        .lamma-equipement-form ul li {
            color: #fecaca !important;
            font-size: 0.9rem;
        }

        .lamma-equipement-form .form-text {
            color: var(--lamma-muted) !important;
        }

        .lamma-form-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-top: 1.5rem;
            padding-top: 1.25rem;
            border-top: 1px solid rgba(255,255,255,0.08);
        }

        .lamma-form-actions .boxed-btn3,
        .lamma-form-actions a.boxed-btn3 {
            color: #fff !important;
            text-decoration: none;
            line-height: 1.3;
            padding: 0.75rem 1.4rem;
            border-radius: 12px;
            background: #F97316;
            border: none;
            transition: background-color 0.25s ease, transform 0.25s ease;
        }

        .lamma-form-actions a.boxed-btn3.btn-cancel {
            background: rgba(255,255,255,0.08) !important;
            border: 1px solid rgba(255,255,255,0.12) !important;
        }

        .lamma-form-actions .boxed-btn3:hover {
            background: #fb923c;
            transform: translateY(-1px);
        }

        .lamma-form-actions a.boxed-btn3.btn-cancel:hover {
            background: rgba(255,255,255,0.15) !important;
        }

        @media (max-width: 1200px) {
            .form-page-layout {
                padding: 2rem 1.25rem 2.5rem;
                gap: 1.5rem;
            }

            .form-page-sidebar {
                min-height: auto;
                position: static;
                top: auto;
            }
        }

        @media (max-width: 992px) {
            .form-page-layout {
                flex-direction: column;
                padding: 1.5rem 1rem 2rem;
            }

            .form-page-sidebar {
                width: 100%;
            }
        }
    </style>
{% endblock %}

{% block header %}{% endblock %}

{% block body %}
<div class="lamma-form-area">
    <div class="form-page-navbar">
        <div class="nav-inner container-fluid px-0">
            <a href="{{ path('app_boutique') }}" class="nav-brand">
                <span>🛒</span>
                <span>Boutique LAMMA</span>
            </a>
            <div class="nav-actions">
                <a href="{{ path('app_boutique') }}" class="btn-secondary">Retour boutique</a>
                <a href="{{ path('app_boutique_new') }}" class="btn-primary">Ajouter un équipement</a>
            </div>
        </div>
    </div>

    <div class="container-fluid px-0">
        <div class="form-page-layout">
            <main class="form-page-main-full">
                <div class="lamma-form-card">
                    <div class="form-hero">
                        <div>
                            <h1>{{ title }}</h1>
                            <p>Complète ce formulaire pour publier un nouvel équipement dans la boutique.</p>
                        </div>
                    </div>

                    <div class="lamma-equipement-form">
                        {{ form_start(form, { attr: { novalidate: 'novalidate', id: 'equipement-form', class: 'lamma-equipement-form-inner' } }) }}
                            {{ form_errors(form) }}

                            <!-- Informations principales -->
                            <div class="form-section">
                                <h3 style="color:#F97316;margin-bottom:1rem;font-size:1.1rem;">Informations principales</h3>
                                <div class="row g-3">
                                    <div class="col-md-8">{{ form_row(form.nom) }}</div>
                                    <div class="col-md-4">{{ form_row(form.categorie) }}</div>
                                </div>
                                {{ form_row(form.description) }}
                            </div>

                            <!-- Détails et prix -->
                            <div class="form-section" style="margin-top:2rem;">
                                <h3 style="color:#F97316;margin-bottom:1rem;font-size:1.1rem;">Détails et prix</h3>
                                <div class="row g-3">
                                    <div class="col-md-4">{{ form_row(form.type) }}</div>
                                    <div class="col-md-4">{{ form_row(form.prix) }}</div>
                                    <div class="col-md-4">{{ form_row(form.ville) }}</div>
                                </div>
                            </div>

                            <!-- Statut -->
                            <div class="form-section" style="margin-top:2rem;">
                                <h3 style="color:#F97316;margin-bottom:1rem;font-size:1.1rem;">Statut</h3>
                                {{ form_row(form.statut) }}
                            </div>

                            <!-- Contact -->
                            <div class="form-section" style="margin-top:2rem;">
                                <h3 style="color:#F97316;margin-bottom:1rem;font-size:1.1rem;">Contact</h3>
                                {{ form_row(form.mail) }}
                            </div>

                            <div class="lamma-form-actions">
                                <button type="submit" class="boxed-btn3">Enregistrer l'équipement</button>
                                <a href="{{ path('app_boutique') }}" class="boxed-btn3 btn-cancel">Annuler</a>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </main>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}
