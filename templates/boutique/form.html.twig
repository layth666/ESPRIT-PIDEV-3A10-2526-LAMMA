{% extends 'base.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block title %}{{ title }} — LAMMA{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .lamma-boutique-form { background: #0f172a; min-height: 100vh; color: #e5e7eb; padding: 8rem 0; }
        .form-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; padding: 3rem; max-width: 800px; margin: 0 auto; box-shadow: 0 20px 50px rgba(0,0,0,0.3); }
        .form-card h1 { font-family: 'Anton', sans-serif; color: #fff; margin-bottom: 2rem; letter-spacing: 1px; text-transform: uppercase; }
        .form-label { color: #94a3b8; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.5rem; }
        .form-control, .form-select { background: rgba(15, 23, 42, 0.8) !important; border: 1px solid rgba(255, 255, 255, 0.1) !important; color: #fff !important; border-radius: 8px !important; padding: 0.75rem 1rem !important; }
        .form-control:focus, .form-select:focus { border-color: #F97316 !important; box-shadow: 0 0 0 0.2rem rgba(249, 115, 22, 0.2) !important; outline: none !important; }
        .btn-lamma-prm { background: #F97316; color: #111827 !important; font-weight: 800; border-radius: 8px; padding: 0.8rem 2rem; border: none; transition: all 0.3s; text-transform: uppercase; letter-spacing: 1px; }
        .btn-lamma-prm:hover { background: #fb923c; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(249,115,22,0.4); }
        .btn-lamma-outline { background: transparent; color: #e5e7eb !important; border: 1px solid rgba(255,255,255,0.3); padding: 0.8rem 2rem; border-radius: 8px; text-decoration: none; transition: all 0.3s; text-transform: uppercase; letter-spacing: 1px; margin-left: 1rem; }
        .btn-lamma-outline:hover { background: rgba(255,255,255,0.05); border-color: #fff; }
    </style>
{% endblock %}

{% block body %}
<div class="lamma-boutique-form">
    <div class="container">
        <div class="form-card border-0">
            <h1>{{ title }}</h1>
            <p class="text-white-50 mb-5">Remplissez les détails de l'équipement pour le lister dans notre catalogue communautaire.</p>

            {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
                <div class="row g-4">
                    <div class="col-md-8">
                        {{ form_row(form.nom) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.categorie) }}
                    </div>
                    <div class="col-12">
                        {{ form_row(form.description) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.type) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.prix) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.ville) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.statut) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.mail) }}
                    </div>
                    <div class="col-12">
                         {{ form_row(form.livrable) }}
                    </div>
                </div>

                <div class="mt-5 pt-4 border-top border-secondary">
                    <button type="submit" class="btn-lamma-prm">Enregistrer l'équipement</button>
                    <a href="{{ path('app_boutique') }}" class="btn-lamma-outline">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
