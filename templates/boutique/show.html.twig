{% extends 'base.html.twig' %}

{% block title %}{{ equipement.nom }} — LAMMA{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .lamma-boutique-detail { background: #0f172a; min-height: 100vh; color: #e5e7eb; padding: 6rem 0 4rem; }
        .detail-wrapper { display: flex; gap: 2rem; flex-wrap: wrap; }
        .detail-sidebar { flex: 0 0 320px; background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 12px; padding: 2rem; height: fit-content; position: sticky; top: 20px; }
        .detail-main { flex: 1; min-width: 300px; background: rgba(255, 255, 255, 0.02); border-radius: 12px; padding: 2rem; border: 1px solid rgba(255, 255, 255, 0.05); }
        .price-badge { background: #F97316; color: #111827; padding: 0.5rem 1rem; border-radius: 8px; font-weight: 800; font-size: 1.5rem; display: inline-block; margin-bottom: 1.5rem; font-family: 'Anton', sans-serif; }
        .info-card { background: rgba(15,23,42,0.6); padding: 1.5rem; border-radius: 10px; margin-bottom: 1.5rem; border-left: 4px solid #F97316; }
        .info-card h3 { color: #fff; font-size: 1.2rem; margin-bottom: 1rem; font-family: 'Anton', sans-serif; text-transform: uppercase; letter-spacing: 1px; }
        .attribute-pill { background: rgba(255,255,255,0.05); padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.85rem; border: 1px solid rgba(255,255,255,0.1); margin: 0.2rem; display: inline-block; }
        .btn-lamma-prm { background: #F97316; color: #111827 !important; font-weight: 700; border-radius: 8px; padding: 0.75rem 1.5rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.3s; border: none; width: 100%; justify-content: center; }
        .btn-lamma-prm:hover { background: #fb923c; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(249,115,22,0.4); text-decoration: none; }
        .btn-lamma-outline { background: transparent; color: #e5e7eb !important; border: 1px solid rgba(255,255,255,0.3); padding: 0.75rem 1.5rem; border-radius: 8px; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; width: 100%; justify-content: center; }
        .btn-lamma-outline:hover { background: rgba(255,255,255,0.05); border-color: #fff; text-decoration: none; }
    </style>
{% endblock %}

{% block body %}
<div class="lamma-boutique-detail">
    <div class="container-fluid px-lg-5">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb bg-transparent p-0">
                <li class="breadcrumb-item"><a href="{{ path('app_boutique') }}" class="text-prm">Boutique</a></li>
                <li class="breadcrumb-item active text-white-50">{{ equipement.nom }}</li>
            </ol>
        </nav>

        <div class="detail-wrapper">
            <aside class="detail-sidebar">
                <h1 class="h3 text-white mb-3" style="font-family:'Anton', sans-serif;">{{ equipement.nom }}</h1>
                <div class="mb-4">
                    <span class="badge bg-dark border border-secondary text-white-50 px-3 py-2">{{ equipement.categorie ?: 'Matériel' }}</span>
                </div>
                
                <div class="price-badge">{{ equipement.prix|number_format(2, ',', ' ') }} TND</div>

                <div class="d-grid gap-2">
                    {% if can_manage %}
                        <a href="{{ path('app_boutique_edit', {id: equipement.id}) }}" class="btn-lamma-prm">
                            <i class="fa fa-edit"></i> Modifier l'annonce
                        </a>
                        {% if equipement.delivery %}
                            <a href="{{ path('app_boutique_delivery', {id: equipement.id}) }}" class="btn btn-info fw-bold py-2 w-100 mb-2">
                                <i class="fa fa-truck"></i> Suivi Livraison
                            </a>
                        {% endif %}
                        {% if has_transaction %}
                            <a href="{{ path('app_qrcode_recap', {id: equipement.id}) }}" class="btn btn-dark fw-bold py-2 w-100 mb-2">
                                <i class="fa fa-file-invoice"></i> Bordereau PDF
                            </a>
                        {% endif %}
                        <form method="post" action="{{ path('app_boutique_delete', {id: equipement.id}) }}" onsubmit="return confirm('Supprimer définitivement ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_equipement_' ~ equipement.id) }}">
                            <button type="submit" class="btn btn-link text-danger w-100 text-decoration-none small mt-2">
                                <i class="fa fa-trash"></i> Supprimer l'équipement
                            </button>
                        </form>
                    {% elseif can_order %}
                        <form method="post" action="{{ path('app_boutique_order', {id: equipement.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('order_equipement_' ~ equipement.id) }}">
                            <button type="submit" class="btn-lamma-prm">
                                <i class="fa fa-shopping-cart"></i> Commander maintenant
                            </button>
                        </form>
                    {% elseif current_user %}
                        <div class="alert alert-info bg-dark border-info text-info small">
                            <i class="fa fa-clock"></i> Commande en cours de traitement
                            {% if can_view_delivery %}
                                <br><a href="{{ path('app_boutique_delivery', {id: equipement.id}) }}" class="alert-link">Voir le suivi</a>
                            {% endif %}
                        </div>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn-lamma-prm">Connectez-vous pour acheter</a>
                    {% endif %}
                    
                    <a href="{{ path('app_boutique') }}" class="btn-lamma-outline mt-2">
                        <i class="fa fa-arrow-left"></i> Retour au catalogue
                    </a>
                </div>

                <hr class="border-secondary my-4">
                
                <div class="small text-white-50">
                    <div class="mb-2"><i class="fa fa-eye me-2 text-prm"></i> <strong>{{ views_count }}</strong> vues uniques</div>
                    <div class="mb-2"><i class="fa fa-map-marker-alt me-2 text-prm"></i> {{ equipement.ville ?: 'Localisation non spécifiée' }}</div>
                    {% if equipement.dateAjout %}
                        <div><i class="fa fa-calendar-alt me-2 text-prm"></i> Mis en ligne le {{ equipement.dateAjout|date('d/m/Y') }}</div>
                    {% endif %}
                </div>
            </aside>

            <main class="detail-main">
                <div class="info-card">
                    <h3>Description de l'équipement</h3>
                    <p class="text-white-50">{{ equipement.description|nl2br ?: 'Aucune description détaillée.' }}</p>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="info-card h-100">
                            <h3>Spécifications</h3>
                            <div class="d-flex flex-wrap">
                                <div class="attribute-pill">Type: {{ equipement.type ?: '—' }}</div>
                                <div class="attribute-pill">Statut: {{ equipement.statut }}</div>
                                <div class="attribute-pill">Livrable: {{ equipement.livrable ? 'OUI' : 'NON' }}</div>
                            </div>
                        </div>
                    </div>
                    {% if equipement.attributs|length > 0 %}
                    <div class="col-md-6">
                        <div class="info-card h-100">
                            <h3>Attributs techniques</h3>
                            <div class="d-flex flex-wrap">
                                {% for a in equipement.attributs %}
                                    {% if a.nomAttribut|lower != 'mail' %}
                                        <div class="attribute-pill"><strong>{{ a.nomAttribut }}:</strong> {{ a.valeur }}</div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                    {% endif %}
                </div>

                {% if equipement.delivery %}
                <div class="info-card mt-4 border-info" style="border-left-color: #0ea5e9;">
                    <h3 class="text-info">Logistique & Expédition</h3>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="small text-white-50">Statut actuel</div>
                            <div class="badge bg-info text-dark mb-3">{{ equipement.delivery.statut|replace({'en_attente': 'En attente', 'confirmee': 'Confirmée', 'preparation': 'Préparation', 'expediee': 'Expédiée', 'en_cours': 'En cours', 'livree': 'Livrée', 'annulee': 'Annulée'}) }}</div>
                        </div>
                        {% if equipement.delivery.estimation %}
                        <div class="col-sm-6">
                            <div class="small text-white-50">Estimation d'arrivée</div>
                            <div class="text-white fw-bold">{{ equipement.delivery.estimation|date('d/m/Y') }}</div>
                        </div>
                        {% endif %}
                    </div>
                </div>
                {% endif %}
            </main>
        </div>
    </div>
</div>
{% endblock %}
