{# Fragment pour la liste de cartes (page initiale + AJAX recherche) #}
{% for e in equipements %}
    <div class="card-eq" data-detail-url="{{ path('app_boutique_show', {id: e.id}) }}" role="button" tabindex="0" title="Double-clic pour ouvrir la fiche détail">
        <h3><a href="{{ path('app_boutique_show', {id: e.id}) }}" class="text-white text-decoration-none">{{ e.nom }}</a></h3>
        <div class="meta">{{ e.categorie ?? '—' }}</div>
        <div class="price mt-1">{{ e.prix|number_format(2, ',', ' ') }} TND</div>
        <div class="meta mt-1">👁 {{ views_count[e.id] ?? 0 }}</div>
        {% if e.delivery %}
            <div class="meta mt-1">🚚 {{ e.delivery.statut|replace({'en_attente': 'En attente', 'confirmee': 'Confirmée', 'preparation': 'En préparation', 'expediee': 'Expédiée', 'en_cours': 'En cours', 'livree': 'Livrée', 'annulee': 'Annulée'}) }}</div>
        {% endif %}
        <div class="d-flex gap-1 mt-2">
            {% if current_user and e.owner and e.owner.id == current_user.id %}
                <a href="{{ path('app_boutique_edit', {id: e.id}) }}" class="btn btn-sm" style="background:rgba(249,115,22,.85);color:#fff;">✏</a>
                <form method="post" action="{{ path('app_boutique_delete', {id: e.id}) }}" onsubmit="return confirm('Supprimer cet équipement ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_equipement_' ~ e.id) }}">
                    <button type="submit" class="btn btn-sm btn-danger">🗑</button>
                </form>
            {% endif %}
        </div>
        <p class="small mt-2 mb-0" style="color:#64748b;">Double-clic sur la carte → fiche détail (comptage des vues si UserId défini).</p>
    </div>
{% else %}
    <p class="text-muted w-100" id="boutique-empty-msg">{{ empty_message|default('Aucun équipement ne correspond à votre recherche.') }}</p>
{% endfor %}
