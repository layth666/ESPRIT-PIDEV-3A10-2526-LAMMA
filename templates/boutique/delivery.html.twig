{% extends 'base.html.twig' %}

{% block title %}Gestion de livraison — LAMMA{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .lamma-delivery-detail { background: #0f172a; min-height: 70vh; color: #e5e7eb; padding: 2rem 0 3rem; }
        .lamma-delivery-detail .breadcrumb-item a { color: #F97316; }
        .lamma-delivery-detail .breadcrumb-item.active { color: #94a3b8; }
        .lamma-delivery-detail .card { background: #111827; border-color: rgba(255,255,255,0.08); }
        .lamma-delivery-detail .form-control, .lamma-delivery-detail .form-select { background: #1e293b; color: #f8fafc; border: 1px solid rgba(255,255,255,0.15); }
        .alert { background: #1e293b; border-left: 4px solid #F97316; border-radius: 4px; padding: 1rem; }
        .status-badge { display: inline-block; padding: 0.5rem 1rem; border-radius: 4px; font-weight: 600; font-size: 0.9rem; }
        .status-en_attente { background: #f97316; color: white; }
        .status-confirmee { background: #0ea5e9; color: white; }
        .status-preparation { background: #8b5cf6; color: white; }
        .status-expediee { background: #10b981; color: white; }
        .status-en_cours { background: #06b6d4; color: white; }
        .status-livree { background: #059669; color: white; }
        .status-annulee { background: #ef4444; color: white; }
        .role-label { display: inline-block; padding: 0.35rem 0.7rem; border-radius: 3px; font-size: 0.85rem; font-weight: 600; background: #334155; color: #e2e8f0; margin-bottom: 1rem; }
        #leaflet-map { height: 400px; width: 100%; border-radius: 8px; border: 2px solid rgba(255,255,255,0.1); margin-bottom: 1.5rem; }
        .leaflet-popup-content-wrapper { background: #1e293b; color: #f8fafc; }
        .leaflet-popup-tip { background: #1e293b; }
        #ai-estimation-result { display: none; background: #1e293b; padding: 1.5rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); margin-top: 1rem; }
        .ai-stat { text-align: center; margin-bottom: 1rem; }
        .ai-stat div { font-size: 2rem; font-weight: 700; color: #f8fafc; }
        .ai-stat span { font-size: 0.9rem; color: #94a3b8; }
        .ai-badge { background: #3b82f6; color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.8rem; font-weight: bold; margin-right: 0.5rem; }
    </style>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />
{% endblock %}

{% block body %}
<div class="lamma-delivery-detail">
    <div class="container" style="max-width:900px;">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="{{ path('app_boutique') }}">Boutique</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_boutique_show', {id: equipement.id}) }}">{{ equipement.nom }}</a></li>
                <li class="breadcrumb-item active">Livraison</li>
            </ol>
        </nav>

        {% if isOwner %}
            <div class="role-label">👤 Propriétaire / Vendeur</div>
        {% elseif isBuyer %}
            <div class="role-label">🛒 Acheteur / Client</div>
        {% endif %}

        <div class="row mb-4">
            <div class="col-lg-8">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="text-white mb-2">Produit</h5>
                        <p class="mb-1"><strong class="text-white">{{ equipement.nom }}</strong></p>
                        <p class="text-white-50 mb-0"><strong>Prix :</strong> {{ equipement.prix|number_format(2, ',', ' ') }} TND</p>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body">
                        <h5 class="text-white mb-3">État de la livraison</h5>
                        <div class="status-badge status-{{ delivery.statut }}">
                            {{ delivery.statut|replace({
                                'en_attente': 'En attente de confirmation',
                                'confirmee': 'Confirmée',
                                'preparation': 'En préparation',
                                'expediee': 'Expédiée',
                                'en_cours': 'En cours de livraison',
                                'livree': 'Livrée',
                                'annulee': 'Annulée'
                            }) }}
                        </div>
                        {% if delivery.estimation %}
                            <p class="mt-3 mb-1 text-white-50"><strong>Estimation d'arrivée :</strong> {{ delivery.estimation|date('d/m/Y à H:i') }}</p>
                        {% endif %}
                        {% if delivery.dateLivraison %}
                            <p class="mb-0 text-white-50"><strong>Date de livraison finale :</strong> {{ delivery.dateLivraison|date('d/m/Y à H:i') }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                {% if isOwner and delivery.acheteur %}
                    <div class="card h-100">
                        <div class="card-body">
                            <h6 class="text-white mb-3">📍 Adresse de livraison du client</h6>
                            {% if delivery.rue and delivery.ville %}
                                <p class="text-white-50 mb-0">
                                    {{ delivery.rue }}<br>
                                    {{ delivery.codePostal }} {{ delivery.ville }}<br>
                                    {{ delivery.pays }}
                                </p>
                            {% else %}
                                <p class="text-warning">⚠️ <em>Le client n'a pas encore renseigné ses coordonnées.</em></p>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="text-white mb-4">
                    {% if isOwner %}
                        🚚 Gérer l'état de la livraison
                    {% else %}
                        📋 Saisir vos coordonnées de livraison
                    {% endif %}
                </h5>

                {% if isOwner %}
                    <div class="alert">
                        Mettez à jour l'état de livraison. Chaque modification sera synchronisée automatiquement avec le compte du client.
                    </div>
                {% else %}
                    <div class="alert">
                        Complétez vos coordonnées de livraison. Ces informations permettront de calculer le trajet et les frais.
                    </div>
                {% endif %}

                <!-- Carte et Trajet OSRM -->
                <div class="row mb-4 border-bottom border-secondary pb-4">
                    <div class="col-12">
                        <h6 class="text-white mb-3">🗺️ Carte interactive du trajet de livraison</h6>
                        <div id="leaflet-map"></div>
                        {% if isBuyer %}
                            <p class="small text-muted"><i class="fa fa-info-circle me-1"></i>Cliquez sur la carte pour définir votre adresse de livraison exacte.</p>
                        {% endif %}
                        
                        <!-- Bloc d'estimation IA -->
                        <div id="ai-estimation-result" class="row align-items-center mt-3">
                            <div class="col-12 mb-3 border-bottom border-secondary pb-2">
                                <h6 class="text-white mb-0"><span class="ai-badge">IA LAMMA</span> Estimation dynamique des frais</h6>
                            </div>
                            <div class="col-sm-6 col-md-3 ai-stat">
                                <div id="ai-cost" class="text-primary">--</div>
                                <span>Total estimé (TND)</span>
                            </div>
                            <div class="col-sm-6 col-md-3 ai-stat">
                                <div id="ai-distance">--</div>
                                <span>Distance (Km)</span>
                            </div>
                            <div class="col-sm-6 col-md-3 ai-stat">
                                <div id="ai-weather">--</div>
                                <span>Météo locale</span>
                            </div>
                            <div class="col-sm-6 col-md-3 ai-stat">
                                <div id="ai-traffic">--</div>
                                <span>Trafic estimé</span>
                            </div>
                        </div>
                    </div>
                </div>

                {{ form_start(form, { attr: { class: 'delivery-form' } }) }}
                    {{ form_errors(form) }}

                    {% if isOwner %}
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.estimation) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.dateLivraison) }}
                            </div>
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.statut) }}
                        </div>
                        <div class="d-none">
                            {{ form_row(form.latitude) }}
                            {{ form_row(form.longitude) }}
                            {{ form_row(form.fraisLivraison) }}
                            {{ form_row(form.rue) }}
                            {{ form_row(form.ville) }}
                            {{ form_row(form.codePostal) }}
                            {{ form_row(form.pays) }}
                        </div>
                    {% else %}
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.rue) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.ville) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.codePostal) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.pays) }}
                            </div>
                        </div>
                        <div class="d-none">
                            {{ form_row(form.latitude) }}
                            {{ form_row(form.longitude) }}
                            {{ form_row(form.fraisLivraison) }}
                        </div>
                    {% endif %}

                    <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top border-secondary">
                        <button type="submit" class="boxed-btn3 btn-lamma">💾 Enregistrer</button>
                        <a href="{{ path('app_boutique_show', {id: equipement.id}) }}" class="boxed-btn3" style="background:#64748b;text-decoration:none;">← Retour</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async function() {
            const mapEl = document.getElementById('leaflet-map');
            if (!mapEl) return;

            // Coordonnées de départ par défaut (Tunis)
            let startLat = 36.8065;
            let startLng = 10.1815;
            
            const equipementVille = "{{ equipement.ville|escape('js') }}";
            const isBuyer = {{ isBuyer ? 'true' : 'false' }};
            const osrmApiUrl = "{{ osrm_apiUrl|escape('js') }}";
            const osrmApiKey = "{{ osrm_apiKey|escape('js') }}";
            
            const latInput = document.querySelector('input[name="delivery[latitude]"]');
            const lngInput = document.querySelector('input[name="delivery[longitude]"]');
            const rueInput = document.querySelector('input[name="delivery[rue]"]');
            const villeInput = document.querySelector('input[name="delivery[ville]"]');
            const cpInput = document.querySelector('input[name="delivery[codePostal]"]');
            const paysInput = document.querySelector('input[name="delivery[pays]"]');

            // 1. Initialiser la carte Leaflet
            const map = L.map('leaflet-map').setView([startLat, startLng], 8);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            let startMarker = L.marker([startLat, startLng], {title: 'Point de départ (Vendeur)'}).addTo(map);
            let endMarker = null;
            let routeLayer = null;

            // 2. Trouver la coordonnée du vendeur (depuis equipement.ville)
            if (equipementVille) {
                try {
                    const resp = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(equipementVille)}&format=json&limit=1`);
                    const data = await resp.json();
                    if (data && data.length > 0) {
                        startLat = parseFloat(data[0].lat);
                        startLng = parseFloat(data[0].lon);
                        startMarker.setLatLng([startLat, startLng]);
                        startMarker.bindPopup(`<strong>Point de départ</strong><br>${equipementVille}`).openPopup();
                        map.setView([startLat, startLng], 10);
                    }
                } catch(e) { console.error("Erreur géo-départ:", e); }
            }

            // 3. Dessiner la route OSRM et estimer l'IA si on a le point d'arrivée
            async function calculateRouteAndCost(endLat, endLng) {
                if (!endMarker) {
                    endMarker = L.marker([endLat, endLng], {title: 'Destination (Acheteur)'}).addTo(map);
                } else {
                    endMarker.setLatLng([endLat, endLng]);
                }
                
                // Fetch Route via OSRM
                try {
                    let osrmUrl = `${osrmApiUrl}/driving/${startLng},${startLat};${endLng},${endLat}?overview=full&geometries=geojson`;
                    if (osrmApiKey.trim() !== "") {
                         osrmUrl += `&key=${osrmApiKey}`;
                    }
                    const res = await fetch(osrmUrl);
                    const routeData = await res.json();
                    
                    if (routeData.code === 'Ok' && routeData.routes.length > 0) {
                        const route = routeData.routes[0];
                        const distanceKm = route.distance / 1000;
                        
                        if (routeLayer) { map.removeLayer(routeLayer); }
                        
                        routeLayer = L.geoJSON(route.geometry, {
                            style: { color: '#F97316', weight: 4, opacity: 0.8 }
                        }).addTo(map);
                        
                        // Zoom pour accomoder toute la route
                        const bounds = L.latLngBounds([[startLat, startLng], [endLat, endLng]]);
                        map.fitBounds(bounds, { padding: [50, 50] });

                        // Appeler l'IA pour l'estimation de prix
                        estimateAICost(distanceKm);
                    }
                } catch (e) {
                    console.error("OSRM Error:", e);
                }
            }

            async function estimateAICost(distanceKm) {
                try {
                    document.getElementById('ai-estimation-result').style.display = 'flex';
                    document.getElementById('ai-cost').innerText = '...';
                    
                    const response = await fetch('{{ path("app_delivery_estimate") }}', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ distance_km: distanceKm })
                    });
                    
                    const aiData = await response.json();
                    
                    if (aiData && aiData.total_tnd) {
                        document.getElementById('ai-cost').innerText = aiData.total_tnd.toFixed(2);
                        document.getElementById('ai-distance').innerText = aiData.distance_km.toFixed(1);
                        document.getElementById('ai-weather').innerHTML = `${aiData.factors.weather.icon} <br> ${aiData.factors.weather.label}`;
                        document.getElementById('ai-traffic').innerHTML = `${aiData.factors.traffic.icon} <br> ${aiData.factors.traffic.label}`;
                        
                        const fraisInput = document.querySelector('input[name="delivery[fraisLivraison]"]');
                        if (fraisInput) {
                            fraisInput.value = aiData.total_tnd.toFixed(2);
                        }
                    }
                } catch(e) {
                    console.error("AI Estimation Error:", e);
                }
            }

            // Si on a déjà des coordonnées de livraison (soit en BDD, soit fraîchement cliquées)
            if (latInput && latInput.value && lngInput && lngInput.value) {
                calculateRouteAndCost(parseFloat(latInput.value), parseFloat(lngInput.value));
            }

            // Seulement l'acheteur peut modifier son adresse en cliquant
            if (isBuyer) {
                map.on('click', function(e) {
                    const clickLat = e.latlng.lat;
                    const clickLng = e.latlng.lng;
                    
                    if (latInput) latInput.value = clickLat;
                    if (lngInput) lngInput.value = clickLng;
                    
                    // Calcul routing OSRM
                    calculateRouteAndCost(clickLat, clickLng);

                    // Reverse geocoding avec Nominatim
                    const nominatimUrl = '{{ nominatim_apiUrl|default("https://nominatim.openstreetmap.org/reverse")|escape("js") }}';
                    fetch(`${nominatimUrl}?format=json&lat=${clickLat}&lon=${clickLng}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data && data.address) {
                                if(endMarker) endMarker.bindPopup(`<strong>Adresse de livraison :</strong><br>${data.display_name}`).openPopup();
                                
                                const add = data.address;
                                if (rueInput) rueInput.value = add.road || add.residential || add.pedestrian || add.suburb || '';
                                if (villeInput) villeInput.value = add.city || add.town || add.village || add.state || '';
                                if (cpInput) cpInput.value = add.postcode || '';
                                if (paysInput) paysInput.value = add.country || '';
                                
                                // Éclairer les inputs
                                document.querySelectorAll('.delivery-form input[type="text"]').forEach(input => {
                                    input.style.borderColor = '#F97316';
                                    setTimeout(() => { input.style.borderColor = ''; }, 1000);
                                });
                            }
                        })
                        .catch(error => console.error("Erreur de géocodage:", error));
                });
            }
        });
    </script>
{% endblock %}
