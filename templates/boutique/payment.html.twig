{% extends 'base.html.twig' %}

{% block title %}Paiement Sécurisé — LAMMA{% endblock %}

{% block hero %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .lamma-payment { background: #0f172a; min-height: 100vh; color: #e5e7eb; padding: 7rem 0 3rem; }
        .payment-card { background: #1e293b; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); padding: 2.5rem; max-width: 620px; margin: 0 auto; box-shadow: 0 20px 50px rgba(0,0,0,0.4); }
        .payment-card h2 { color: #f8fafc; margin-bottom: 2rem; font-weight: 700; text-align: center; font-family: 'Anton', sans-serif; letter-spacing: 1px; }
        .order-summary { background: #0f172a; padding: 1.5rem; border-radius: 10px; margin-bottom: 2rem; border-left: 4px solid #E8392C; }
        .order-summary h4 { color: #E8392C; font-size: 1rem; margin-bottom: 1rem; text-transform: uppercase; font-weight: 800; letter-spacing: 1px; }
        .order-summary strong { color: #fff; }

        /* Card UI */
        .card-visual { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); border-radius: 16px; padding: 1.5rem 2rem; margin-bottom: 1.5rem; color: white; position: relative; overflow: hidden; box-shadow: 0 8px 25px rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1); min-height: 160px; }
        .card-visual::before { content: ''; position: absolute; top: -30px; right: -30px; width: 200px; height: 200px; background: rgba(255,255,255,0.03); border-radius: 50%; }
        .card-visual::after { content: ''; position: absolute; bottom: -50px; left: -20px; width: 180px; height: 180px; background: rgba(255,255,255,0.02); border-radius: 50%; }
        .card-network { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
        .card-chip { width: 40px; height: 30px; background: linear-gradient(135deg, #d4af37, #f0d060); border-radius: 5px; }
        .card-network-logo { font-size: 1.8rem; letter-spacing: -2px; font-weight: 900; color: #fff; opacity: 0.9; }
        .card-number-display { font-size: 1.3rem; letter-spacing: 4px; font-family: 'Courier New', monospace; margin-bottom: 1rem; opacity: 0.9; }
        .card-info-row { display: flex; justify-content: space-between; font-size: 0.8rem; }
        .card-info-row .label { opacity: 0.5; text-transform: uppercase; font-size: 0.65rem; letter-spacing: 1px; margin-bottom: 2px; }
        .card-info-row .value { font-size: 0.9rem; letter-spacing: 1px; }

        /* Form fields */
        .field-group { margin-bottom: 1.25rem; }
        .field-label { color: #94a3b8; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; display: block; }
        .field-input { background: #0f172a; border: 1px solid rgba(255,255,255,0.12); color: #f8fafc; border-radius: 8px; padding: 0.75rem 1rem; width: 100%; font-size: 1rem; transition: all 0.3s; }
        .field-input:focus { outline: none; border-color: #E8392C; box-shadow: 0 0 0 3px rgba(232,57,44,0.15); }
        .field-input::placeholder { color: #475569; }

        .btn-pay { background: linear-gradient(135deg, #E8392C, #c0392b); color: #fff; border: none; padding: 1rem 2rem; border-radius: 10px; font-weight: 800; font-size: 1.05rem; width: 100%; transition: all 0.3s; margin-top: 0.5rem; cursor: pointer; text-transform: uppercase; letter-spacing: 2px; display: flex; align-items: center; justify-content: center; gap: 0.5rem; }
        .btn-pay:hover { background: linear-gradient(135deg, #ff4d3d, #e74c3c); transform: translateY(-2px); box-shadow: 0 8px 20px rgba(232,57,44,0.4); }
        .btn-pay:disabled { opacity: 0.7; transform: none; cursor: not-allowed; }
        .secure-badge { text-align: center; color: #10b981; font-weight: 600; margin-top: 1rem; font-size: 0.85rem; }
        .secure-icons { display: flex; justify-content: center; gap: 1.5rem; margin-top: 0.75rem; opacity: 0.4; font-size: 1.8rem; }
        .back-link { display: block; text-align: center; margin-top: 1.5rem; color: #64748b; font-size: 0.85rem; text-decoration: none; }
        .back-link:hover { color: #94a3b8; }
    </style>
{% endblock %}

{% block body %}
<div class="lamma-payment">
    <div class="container-fluid px-4">
        <div class="payment-card">
            <h2>💳 Paiement Sécurisé</h2>

            {% set frais = delivery.fraisLivraison ?? 0 %}
            {% set total = equipement.prix + frais %}

            <div class="order-summary">
                <h4>📋 Résumé de la commande</h4>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-white-50">Produit:</span>
                    <strong class="text-white">{{ equipement.nom }}</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-white-50">Prix HT:</span>
                    <strong class="text-white">{{ equipement.prix|number_format(2, ',', ' ') }} TND</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-white-50">Logistique (IA):</span>
                    <strong class="text-info">{% if frais > 0 %}+ {{ frais|number_format(2, ',', ' ') }} TND{% else %}GRATUIT{% endif %}</strong>
                </div>
                <hr style="border-color: rgba(255,255,255,0.1)">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold">TOTAL À REGLER:</span>
                    <span style="font-size: 1.5rem; color: #10b981; font-family: 'Anton', sans-serif;">{{ total|number_format(2, ',', ' ') }} TND</span>
                </div>
                {% if delivery.estimation %}
                <p class="text-info small mt-2 mb-0"><i class="fa fa-robot me-2"></i>Estimation d'arrivée : <strong>{{ delivery.estimation|date('d/m/Y') }}</strong></p>
                {% endif %}
            </div>

            <!-- Live Card Visual -->
            <div class="card-visual">
                <div class="card-network">
                    <div class="card-chip"></div>
                    <div class="card-network-logo" id="card-brand-logo">VISA</div>
                </div>
                <div class="card-number-display" id="card-number-display">•••• •••• •••• ••••</div>
                <div class="card-info-row">
                    <div>
                        <div class="label">Titulaire</div>
                        <div class="value" id="card-name-display">VOTRE NOM</div>
                    </div>
                    <div>
                        <div class="label">Expire</div>
                        <div class="value" id="card-expiry-display">MM/YY</div>
                    </div>
                    <div>
                        <div class="label">CVV</div>
                        <div class="value">•••</div>
                    </div>
                </div>
            </div>

            <form action="{{ path('app_boutique_payment_process', {id: equipement.id}) }}" method="post" id="payment-form">
                <input type="hidden" name="_token" value="{{ csrf_token('process_payment_' ~ equipement.id) }}">
                <input type="hidden" name="stripeToken" value="sim_{{ equipement.id }}_{{ 'now'|date('U') }}">

                <div class="field-group">
                    <label class="field-label">Titulaire de la carte</label>
                    <input type="text" class="field-input" id="card-name" placeholder="EX: MOHAMED BEN ALI" required autocomplete="cc-name" oninput="updateCardName(this.value)">
                </div>

                <div class="field-group">
                    <label class="field-label">Numéro de carte</label>
                    <input type="text" class="field-input" id="card-number" placeholder="4242 4242 4242 4242" maxlength="19" required autocomplete="cc-number" oninput="formatCard(this)">
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <div class="field-group">
                            <label class="field-label">Date d'expiration</label>
                            <input type="text" class="field-input" id="card-expiry" placeholder="MM / YY" maxlength="7" required autocomplete="cc-exp" oninput="formatExpiry(this)">
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="field-group">
                            <label class="field-label">CVV / CVC</label>
                            <input type="text" class="field-input" placeholder="•••" maxlength="4" required autocomplete="cc-csc">
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-pay" id="pay-btn">
                    <i class="fa fa-lock"></i> Confirmer le paiement — {{ total|number_format(2, ',', ' ') }} TND
                </button>

                <div class="secure-badge">
                    <i class="fa fa-shield-alt me-1"></i> Paiement simulé — Environnement de démonstration sécurisé
                </div>
                <div class="secure-icons">
                    <span title="Visa">💳</span>
                    <span title="Mastercard">🔐</span>
                    <span title="SSL">🛡️</span>
                </div>
            </form>

            <a href="{{ path('app_boutique_delivery', {id: equipement.id}) }}" class="back-link">
                ← Retour à la livraison
            </a>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    function formatCard(input) {
        let v = input.value.replace(/\D/g, '').substring(0, 16);
        let formatted = v.replace(/(.{4})/g, '$1 ').trim();
        input.value = formatted;
        // Update display
        let display = formatted.length > 0 ? formatted.padEnd(19, '•').replace(/[^•\d ]/g, '•') : '•••• •••• •••• ••••';
        document.getElementById('card-number-display').textContent = formatted || '•••• •••• •••• ••••';
        // Detect brand
        const brand = v.startsWith('4') ? 'VISA' : v.startsWith('5') ? 'MASTERCARD' : v.startsWith('3') ? 'AMEX' : 'CARD';
        document.getElementById('card-brand-logo').textContent = brand;
    }
    function formatExpiry(input) {
        let v = input.value.replace(/\D/g, '').substring(0, 4);
        if (v.length >= 3) v = v.substring(0,2) + ' / ' + v.substring(2);
        input.value = v;
        document.getElementById('card-expiry-display').textContent = v || 'MM/YY';
    }
    function updateCardName(val) {
        document.getElementById('card-name-display').textContent = val.toUpperCase() || 'VOTRE NOM';
    }

    document.getElementById('payment-form').addEventListener('submit', function(e) {
        const btn = document.getElementById('pay-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin me-2"></i>Traitement en cours...';
    });
    </script>
{% endblock %}
