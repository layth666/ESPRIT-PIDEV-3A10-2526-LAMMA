{% extends 'admin/base_admin.html.twig' %}

{% block title %}Blog — Statistiques Détaillées{% endblock %}
{% block page_title %}Statistiques du Blog{% endblock %}
{% block breadcrumb %}Blog → Statistiques{% endblock %}

{% block stylesheets %}
<style>
    .chart-container { position:relative; height:350px; width:100%; }
</style>
{% endblock %}

{% block body %}

<div class="row g-4 mb-4">
    <div class="col-xl-8">
        <div class="card h-100" style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07); border-radius:12px;">
            <div class="card-header" style="background:transparent; border-bottom:1px solid rgba(255,255,255,0.07); padding:16px 20px;">
                <i class="fas fa-chart-line me-2" style="color:#f09000;"></i>
                <span class="fw-bold" style="font-family:'Bebas Neue',sans-serif; letter-spacing:0.5px;">ACTIVITÉ DU BLOG (6 DERNIERS MOIS)</span>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="activityChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card h-100" style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05); border-radius:12px;">
            <div class="card-header" style="background:transparent; border-bottom:1px solid rgba(255,255,255,0.07); padding:16px 20px;">
                <span class="fw-bold" style="font-family:'Bebas Neue',sans-serif; letter-spacing:0.5px;"><i class="fas fa-medal me-2" style="color:#f5c842;"></i>POSTS LES PLUS ACTIFS</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0" style="background:transparent;">
                        <tbody>
                            {% for post in active_posts %}
                            <tr>
                                <td style="padding:15px 16px;">
                                    <div class="fw-bold mb-1">{{ post.title|slice(0, 40) }}…</div>
                                    <div class="progress" style="height: 4px; background: rgba(255,255,255,0.05);">
                                        <div class="progress-bar" role="progressbar" 
                                             style="width: {{ (post.comments / (total_comments > 0 ? total_comments : 1) * 100)|round }}%; background: #f09000;" 
                                             aria-valuenow="{{ post.comments }}" aria-valuemin="0" aria-valuemax="{{ total_comments }}"></div>
                                    </div>
                                </td>
                                <td style="padding:15px 16px; text-align:right;">
                                    <span class="badge" style="background:rgba(240,144,0,0.1); color:#f09000; border:1px solid rgba(240,144,0,0.2);">
                                        {{ post.comments }} comm.
                                    </span>
                                </td>
                            </tr>
                            {% else %}
                            <tr><td colspan="2" class="text-center py-5 text-muted">Aucune donnée</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card" style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05); border-radius:12px;">
            <div class="card-body p-4 text-center">
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="fs-4 fw-bold" style="color:#f09000;">{{ total_posts }}</div>
                        <div class="small text-muted text-uppercase">Articles publiés</div>
                    </div>
                    <div class="col-md-4">
                        <div class="fs-4 fw-bold" style="color:#3b82f6;">{{ total_comments }}</div>
                        <div class="small text-muted text-uppercase">Commentaires reçus</div>
                    </div>
                    <div class="col-md-4">
                        <div class="fs-4 fw-bold" style="color:#10b981;">
                            {{ total_posts > 0 ? (total_comments / total_posts)|round(1) : 0 }}
                        </div>
                        <div class="small text-muted text-uppercase">Moyenne comm./post</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const months = {{ months_json|raw }};
    const postsData = {{ post_data_json|raw }};
    const commentsData = {{ comment_data_json|raw }};

    new Chart(document.getElementById('activityChart').getContext('2d'), {
        type: 'line',
        data: {
            labels: months,
            datasets: [
                {
                    label: 'Nouveaux Posts',
                    data: postsData,
                    borderColor: '#f09000',
                    backgroundColor: 'rgba(240,144,0,0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#f09000'
                },
                {
                    label: 'Nouveaux Commentaires',
                    data: commentsData,
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59,130,246,0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#3b82f6'
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    labels: { color: '#aab1b7', font: { family: 'DM Sans' } }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { color: '#aab1b7', stepSize: 1 },
                    grid: { color: 'rgba(255,255,255,0.05)' }
                },
                x: {
                    ticks: { color: '#aab1b7' },
                    grid: { display: false }
                }
            }
        }
    });
});
</script>
{% endblock %}
