{% extends 'admin/base_admin.html.twig' %}

{% block title %}Tableau de bord — LAMMA{% endblock %}

{% block admin_content %}
    <form method="get" action="{{ path('app_admin') }}" class="card shadow-sm mb-4" id="admin-toolbar"
         data-search-url="{{ path('app_admin_search') }}"
         data-admin-url="{{ path('app_admin') }}">
         <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-3 p-3">
            <div class="d-flex flex-wrap align-items-center gap-2 w-100">
                <label class="small text-muted fw-bold d-none d-md-inline" for="admin-q"><i class="fa fa-search me-1"></i> Filtrer les équipements</label>
                <input type="search" id="admin-q" name="q" value="{{ q|default('') }}" autocomplete="off"
                       class="form-control form-control-sm" placeholder="Recherche…" style="min-width:220px;">
                <select id="admin-categorie" name="categorie" class="form-select form-select-sm" style="max-width:220px;">
                    {% for c in categories %}
                        <option value="{{ c }}" {% if c == current_categorie %}selected{% endif %}>{{ c }}</option>
                    {% endfor %}
                </select>
                <button type="submit" class="d-none">Rechercher</button>
            </div>
            <div class="ms-auto d-flex align-items-center gap-3">
                <span class="badge bg-primary rounded-pill px-3 py-2 shadow-sm" id="admin-count" style="font-size: 0.9rem;">
                    {{ total }} résultat(s)
                </span>
            </div>
        </div>
    </form>

    <div class="row g-4 mb-4">
        <div class="col-xl-4 col-md-6">
            <div class="card bg-primary text-white shadow h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <div class="display-4 fw-bold mb-2">{{ total }}</div>
                    <div class="text-white-50 text-uppercase fw-semibold" style="letter-spacing: 1px;">
                        <i class="fa fa-boxes me-2"></i>Total Équipements
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="card bg-success text-white shadow h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <div class="display-4 fw-bold mb-2">{{ livrable_count }}</div>
                    <div class="text-white-50 text-uppercase fw-semibold" style="letter-spacing: 1px;">
                        <i class="fa fa-truck me-2"></i>Équipements Livrables
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="card bg-warning text-white shadow h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <div class="display-4 fw-bold mb-2">{{ delivery_count }}</div>
                    <div class="text-white-50 text-uppercase fw-semibold" style="letter-spacing: 1px;">
                        <i class="fa fa-clock me-2"></i>Livraisons Actives
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header">
            <i class="fa fa-table me-1"></i>
            Liste des équipements
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Nom</th>
                            <th>Type</th>
                            <th>Catégorie</th>
                            <th>Statut</th>
                            <th>Livrable</th>
                            <th>Propriétaire</th>
                            <th>Acheteur</th>
                            <th>Livraison</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                </thead>
                <tbody id="admin-table-body">
                    {% include 'admin/_equipement_rows.html.twig' %}
                </tbody>
            </table>
            </div>
        </div>
    </div>
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <i class="fa fa-handshake me-1"></i>
            Historique des Ventes / Transactions
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Date</th>
                            <th>Équipement</th>
                            <th>Vendeur</th>
                            <th>Acheteur</th>
                            <th>Prix</th>
                            <th class="text-end pe-3">Token Stripe</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for t in transactions %}
                            <tr>
                                <td class="ps-3">{{ t.createdAt ? t.createdAt|date('d/m/Y H:i') : '-' }}</td>
                                <td><span class="badge bg-info">{{ t.equipement.nom }}</span></td>
                                <td>{{ t.seller.userid }}</td>
                                <td>{{ t.buyer.userid }}</td>
                                <td><span class="fw-bold text-success">{{ t.price }} TND</span></td>
                                <td class="text-end pe-3"><small class="text-muted">{{ t.stripeToken|default('-')|slice(0, 15) }}...</small></td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">Aucune transaction enregistrée.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
