            <div class="card-body d-flex align-items-center gap-3">
                <div style="width: 50px; height: 50px; background: #2ecfb8; border-radius: 10px; display: grid; place-items: center;">
                    <i class="fas fa-users text-dark fa-lg"></i>
                </div>
                <div>
                    <div class="small fw-bold text-uppercase" style="color: #2ecfb8; letter-spacing: 1px;">Utilisateurs</div>
                    <div class="fs-3 fw-bold" style="font-family: 'Anton', sans-serif;">{{ totalUsers }}</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0 pb-3 ps-3">
                <a href="{{ path('app_users_index') }}?role=USER" class="small text-decoration-none" style="color: rgba(255,255,255,0.5);">Consulter la liste →</a>
            </div>
        </div>
    </div>
    <!-- Banned Role Card -->
    <div class="col-md-4">
        <div class="card h-100" style="background: rgba(232, 57, 44, 0.1); border: 1px solid rgba(232, 57, 44, 0.2); border-radius: 12px;">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width: 50px; height: 50px; background: #e8392c; border-radius: 10px; display: grid; place-items: center;">
                    <i class="fas fa-user-slash text-white fa-lg"></i>
