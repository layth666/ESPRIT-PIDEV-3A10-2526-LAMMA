{% endblock %}

{% block javascripts %}
{# Google Charts Loader #}
<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.8.0/Chart.min.js" crossorigin="anonymous"></script>
<script src="{{ asset('sbadmin/js/datatables-simple-demo.js') }}"></script>

<script type="text/javascript">
    google.charts.load('current', {'packages':['corechart', 'bar']});
    google.charts.setOnLoadCallback(drawCharts);

    function drawCharts() {
        // --- 1. REVENUE PIE CHART ---
        var revenueData = google.visualization.arrayToDataTable([
            ['Type', 'Revenu'],
            {% for item in revenueStats %}
                ['{{ item.label }}', {{ item.total }}],
            {% else %}
                ['Aucune donnée', 0]
            {% endfor %}
        ]);

        var revenueOptions = {
            pieHole: 0.4,
            colors: ['#ff005a', '#3b82f6', '#10b981', '#f59e0b', '#8b5cf6'],
            chartArea: {width: '90%', height: '80%'},
            legend: {position: 'bottom'},
            backgroundColor: 'transparent'
        };

        var revenueChart = new google.visualization.PieChart(document.getElementById('revenue_chart'));
        revenueChart.draw(revenueData, revenueOptions);

        // --- 2. POPULARITY BAR CHART ---
        var popularityData = google.visualization.arrayToDataTable([
            ['Établissement', 'Nombre de Favoris', { role: 'style' }],
            {% set colors = ['#f97316', '#fb923c', '#fdba74', '#fed7aa', '#ffedd5'] %}
            {% for item in popularityStats %}
                ['{{ item.label }}', {{ item.total }}, '{{ colors[loop.index0] }}'],
            {% else %}
                ['Aucun', 0, '#ccc']
            {% endfor %}
        ]);

        var popularityOptions = {
            legend: { position: "none" },
            chartArea: {width: '70%', height: '80%'},
            hAxis: { minValue: 0 },
            backgroundColor: 'transparent'
        };

        var popularityChart = new google.visualization.BarChart(document.getElementById('popularity_chart'));
        popularityChart.draw(popularityData, popularityOptions);

        // --- 3. TIMELINE AREA CHART ---
        var timelineData = google.visualization.arrayToDataTable([
            ['Mois', 'Participations'],
            {% for item in participationTimeline %}
                ['{{ item.label }}', {{ item.total }}],
            {% else %}
                ['N/A', 0]
            {% endfor %}
        ]);

        var timelineOptions = {
            hAxis: {title: 'Mois',  titleTextStyle: {color: '#333'}},
            vAxis: {minValue: 0},
            colors: ['#3b82f6'],
            areaOpacity: 0.2,
            chartArea: {width: '85%', height: '70%'},
            legend: {position: 'none'},
            backgroundColor: 'transparent'
        };

        var timelineChart = new google.visualization.AreaChart(document.getElementById('timeline_chart'));
        timelineChart.draw(timelineData, timelineOptions);
    }
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Coordonnées pour Tunis: 36.8065° N, 10.1815° E
    fetch('https://api.open-meteo.com/v1/forecast?latitude=36.8065&longitude=10.1815&current_weather=true')
        .then(response => response.json())
        .then(data => {
            const weather = data.current_weather;
            const temp = weather.temperature;
            const code = weather.weathercode;
            const isDay = weather.is_day;
            
            document.getElementById('weather-temp').innerHTML = temp + ' °C';
            
            let desc = "Inconnu";
            let icon = "fa-cloud";
            
            // WMO Weather interpretation codes
            if (code === 0) { desc = "Ciel clair"; icon = isDay ? "fa-sun" : "fa-moon"; }
            else if (code === 1 || code === 2 || code === 3) { desc = "Peu nuageux"; icon = isDay ? "fa-cloud-sun" : "fa-cloud-moon"; }
            else if (code === 45 || code === 48) { desc = "Brouillard"; icon = "fa-smog"; }
            else if (code >= 51 && code <= 57) { desc = "Bruine"; icon = "fa-cloud-rain"; }
            else if (code >= 61 && code <= 67) { desc = "Pluie"; icon = "fa-cloud-showers-heavy"; }
            else if (code >= 71 && code <= 77) { desc = "Neige"; icon = "fa-snowflake"; }
            else if (code >= 80 && code <= 82) { desc = "Averses"; icon = "fa-cloud-rain"; }
            else if (code >= 85 && code <= 86) { desc = "Averses de neige"; icon = "fa-snowflake"; }
            else if (code >= 95 && code <= 99) { desc = "Orage"; icon = "fa-bolt"; }
            
            document.getElementById('weather-desc').innerText = desc;
            document.getElementById('weather-icon').className = 'fas ' + icon + ' fa-3x';
        })
        .catch(error => {
            document.getElementById('weather-temp').innerHTML = '-- °C';
            document.getElementById('weather-desc').innerText = 'Erreur API';
            document.getElementById('weather-icon').className = 'fas fa-exclamation-triangle fa-3x';
        });
});
</script>
{% endblock %}
