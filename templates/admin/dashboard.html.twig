{% extends 'admin/base_admin.html.twig' %}

{% block title %}Dashboard - SB Admin{% endblock %}
{% block admin_title %}Dashboard{% endblock %}

{% block body %}
<div class="row g-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 scout-card" style="background: linear-gradient(135deg, #3b82f6, #06b6d4); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-white-85 small text-uppercase fw-bold" style="letter-spacing: 0.5px; opacity: 0.85;">Météo Tunis</div>
                        <div class="fw-bold fs-3 mt-1" id="weather-temp" style="font-family: 'Anton', sans-serif;"><i class="fas fa-spinner fa-spin text-white"></i></div>
                        <div class="fw-bold small" id="weather-desc">Chargement...</div>
                    </div>
                    <i class="fas fa-cloud-sun fa-3x opacity-50" id="weather-icon"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 scout-card" style="background: linear-gradient(135deg, #a855f7, #ec4899); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-white-50 small text-uppercase fw-bold">Participants</div>
                        <div class="fw-bold fs-3 mt-1" style="font-family: 'Anton', sans-serif;">{{ totalParticipants }}</div>
                        <div class="small">Confirmés</div>
                    </div>
                    <i class="fas fa-users fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 scout-card" style="background: linear-gradient(135deg, #10b981, #059669); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-white-50 small text-uppercase fw-bold">Restaurants</div>
                        <div class="fw-bold fs-3 mt-1" style="font-family: 'Anton', sans-serif;">{{ totalRestaurants }}</div>
                        <div class="small">Partenaires</div>
                    </div>
                    <i class="fas fa-utensils fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 scout-card" style="background: linear-gradient(135deg, #f59e0b, #d97706); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-white-50 small text-uppercase fw-bold">Revenu Total</div>
                        <div class="fw-bold fs-3 mt-1" style="font-family: 'Anton', sans-serif;">{{ totalRevenue|number_format(2, ',', ' ') }}€</div>
                        <div class="small">Cumulé</div>
                    </div>
                    <i class="fas fa-wallet fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 scout-card" style="background: linear-gradient(135deg, #fbbf24, #d97706); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-white-50 small text-uppercase fw-bold">Boutique</div>
                        <div class="fw-bold fs-3 mt-1" style="font-family: 'Anton', sans-serif;">{{ totalEquipements }}</div>
                        <div class="small">Produits</div>
                    </div>
                    <i class="fas fa-campground fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 scout-card" style="background: linear-gradient(135deg, #ec4899, #be185d); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-white-50 small text-uppercase fw-bold">Ventes Boutique</div>
                        <div class="fw-bold fs-3 mt-1" style="font-family: 'Anton', sans-serif;">{{ totalTransactionValue|number_format(2, ',', ' ') }} TND</div>
                        <div class="small">Total Ventes</div>
                    </div>
                    <i class="fas fa-shopping-cart fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5 g-4">
    <div class="col-xl-6">
        <div class="card scout-card border-0">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h5 class="m-0" style="font-family:'Anton', sans-serif; letter-spacing:1px;"><i class="fas fa-chart-pie me-2 text-prm"></i>RÉPARTITION REVENUS</h5>
            </div>
            <div class="card-body p-4">
                <div id="revenue_chart" style="width: 100%; height: 300px;"></div>
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card scout-card border-0">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h5 class="m-0" style="font-family:'Anton', sans-serif; letter-spacing:1px;"><i class="fas fa-crown me-2 text-warning"></i>TOP FAVORIS</h5>
            </div>
            <div class="card-body p-4">
                <div id="popularity_chart" style="width: 100%; height: 300px;"></div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card scout-card border-0">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h5 class="m-0" style="font-family:'Anton', sans-serif; letter-spacing:1px;"><i class="fas fa-chart-line me-2 text-info"></i>TENDANCE PARTICIPATIONS</h5>
            </div>
            <div class="card-body p-4">
                <div id="timeline_chart" style="width: 100%; height: 350px;"></div>
            </div>
        </div>
    </div>
</div>


{# Recent Participations Section #}
<div class="row mt-4">
    <div class="col-12">
        <h4 style="font-family: 'Anton', sans-serif; text-transform: uppercase; letter-spacing: 1px; color: #fff; margin-bottom: 25px;">
            <i class="fas fa-list-ol me-2" style="color: #10b981;"></i> DERNIÈRES INSCRIPTIONS
        </h4>
        
        <div class="card mb-4" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 15px;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0" style="background: transparent;">
                        <thead style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <tr>
                                <th style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 700;">ID</th>
                                <th style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 700;">Événement</th>
                                <th style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 700;">Type</th>
                                <th style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 700;">Statut</th>
                                <th style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 700;">Date</th>
                                <th style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 700;">Cout</th>
                                <th class="text-right"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for p in recentParticipations %}
                            <tr>
                                <td class="align-middle fw-bold">#{{ p.id }}</td>
                                <td class="align-middle fw-bold" style="color: #3b82f6;">Événement #{{ p.evenement ? p.evenement.idEvent : 'N/A' }}</td>
                                <td class="align-middle">{{ p.type }}</td>
                                <td class="align-middle">
                                    <span class="badge" style="
                                        {% if p.statut == 'CONFIRME' %}background: #10b981;
                                        {% elseif p.statut == 'ANNULE' %}background: #ef4444;
                                        {% else %}background: #f59e0b;{% endif %}
                                        px-2 py-1 rounded">
                                        {{ p.statut }}
                                    </span>
                                </td>
                                <td class="align-middle" style="font-size: 0.9rem;">{{ p.dateInscription|date('d/m/Y H:i') }}</td>
                                <td class="align-middle fw-bold text-success">{{ p.montantCalcule }} {{ p.devise }}</td>
                                <td class="align-middle text-right">
                                    <a href="{{ path('app_participation_show', {'id': p.id}) }}" class="btn btn-sm" style="background: rgba(255,255,255,0.1); color: #fff; font-size: 0.75rem;">Détails</a>
                                </td>
                            </tr>
                            {% else %}
                            <tr><td colspan="7" class="text-center text-muted py-4">Aucune participation</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-transparent py-3" style="border-top: 1px solid rgba(255,255,255,0.05);">
                <a href="{{ path('app_participation_index') }}" class="btn w-100" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); font-weight: bold; text-transform: uppercase; font-size: 0.85rem;">Voir toutes les participations</a>
            </div>
        </div>
    </div>
</div>

{# Recent Users Section #}
<div class="row mt-4">
    <div class="col-12">
        <h4 style="font-family: 'Anton', sans-serif; text-transform: uppercase; letter-spacing: 1px; color: #fff; margin-bottom: 25px;">
            <i class="fas fa-users me-2" style="color: #3b82f6;"></i> DERNIERS UTILISATEURS / PARTICIPANTS
        </h4>
        
        <div class="card mb-4" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 15px;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0" style="background: transparent;">
                        <thead style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <tr>
                                <th style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 700;">Auteur</th>
                                <th style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 700;">Email</th>
                                <th style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 700;">Rôle</th>
                                <th class="text-right"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for u in recentUsers %}
                            <tr>
                                <td class="align-middle fw-bold">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="user-avatar-sm rounded-circle d-grid place-items-center fw-bold" style="width:32px; height:32px; background:#3b82f6; font-size:0.75rem;">
                                            {% if u.image %}
                                                <img src="{{ asset('uploads/images/' ~ u.image) }}" alt="{{ u.name }}">
                                            {% else %}
                                                {{ u.name|slice(0,1)|upper }}
                                            {% endif %}
                                        </div>
                                        <span>{{ u.name }}</span>
                                    </div>
                                </td>
                                <td class="align-middle" style="color: #94a3b8;">{{ u.email }}</td>
                                <td class="align-middle">
                                    <span class="badge" style="
                                        {% if u.role == 'ADMIN' %}background: #f59e0b;
                                        {% elseif u.role == 'BANNED' %}background: #ef4444;
                                        {% else %}background: #10b981;{% endif %}
                                        px-2 py-1 rounded">
                                        {{ u.role }}
                                    </span>
                                </td>
                                <td class="align-middle text-right">
                                    <a href="{{ path('app_users_edit', {'id': u.id}) }}" class="btn btn-sm" style="background: rgba(255,255,255,0.1); color: #fff; font-size: 0.75rem;">Gérer</a>
                                </td>
                            </tr>
                            {% else %}
                            <tr><td colspan="4" class="text-center text-muted py-4">Aucun utilisateur</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-transparent py-3" style="border-top: 1px solid rgba(255,255,255,0.05);">
                <a href="{{ path('app_users_index') }}" class="btn w-100" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.2); font-weight: bold; text-transform: uppercase; font-size: 0.85rem;">Voir tous les utilisateurs</a>
            </div>
        </div>
    </div>
</div>

{# User Roles Section #}
<div class="row mt-4">
    <div class="col-12">
        <h4 style="font-family: 'Anton', sans-serif; text-transform: uppercase; letter-spacing: 1px; color: #fff; margin-bottom: 25px;">
            <i class="fas fa-user-shield me-2" style="color: #f5c842;"></i> GESTION DES RÔLES
        </h4>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Admin Role Card -->
    <div class="col-md-4">
        <div class="card h-100" style="background: rgba(245, 200, 66, 0.1); border: 1px solid rgba(245, 200, 66, 0.2); border-radius: 12px;">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width: 50px; height: 50px; background: #f5c842; border-radius: 10px; display: grid; place-items: center;">
                    <i class="fas fa-crown text-dark fa-lg"></i>
                </div>
                <div>
                    <div class="small fw-bold text-uppercase" style="color: #f5c842; letter-spacing: 1px;">Admins</div>
                    <div class="fs-3 fw-bold" style="font-family: 'Anton', sans-serif;">{{ totalAdmins }}</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0 pb-3 ps-3">
