{% extends 'admin/base_admin.html.twig' %}

{% block title %}Tableau de bord — LAMMA{% endblock %}

{% block admin_content %}
    <form method="get" action="{{ path('app_admin') }}" class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4 admin-toolbar" id="admin-toolbar"
         data-search-url="{{ path('app_admin_search') }}"
         data-admin-url="{{ path('app_admin') }}">
        <div class="d-flex align-items-center gap-2">
            <span style="font-size:1.35rem">⚙️</span>
            <div>
                <h2 class="mb-0">Tableau de bord</h2>
                <p class="text-white-50 mb-0">Recherche et filtre en direct, comme sur le front.</p>
            </div>
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2 ms-auto">
            <label class="small mb-0 text-white-50 d-none d-md-inline" for="admin-q">Recherche</label>
            <input type="search" id="admin-q" name="q" value="{{ q|default('') }}" autocomplete="off"
                   class="form-control form-control-sm" placeholder="Recherche…" style="min-width:220px;">
            <select id="admin-categorie" name="categorie" class="form-select form-select-sm" style="max-width:220px;">
                {% for c in categories %}
                    <option value="{{ c }}" {% if c == current_categorie %}selected{% endif %}>{{ c }}</option>
                {% endfor %}
            </select>
            <button type="submit" class="d-none">Rechercher</button>
        </div>
        <span class="count-pill" id="admin-count">{{ total }} équipement(s)</span>
    </form>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="admin-card p-4 h-100">
                <div class="text-white-50 mb-2">Équipements</div>
                <div class="h1 mb-0">{{ total }}</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="admin-card p-4 h-100">
                <div class="text-white-50 mb-2">Livrable</div>
                <div class="h1 mb-0">{{ livrable_count }}</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="admin-card p-4 h-100">
                <div class="text-white-50 mb-2">Livraisons actives</div>
                <div class="h1 mb-0">{{ delivery_count }}</div>
            </div>
        </div>
    </div>

    <div class="admin-card p-3">
        <div class="table-responsive">
            <table class="table table-dark table-striped align-middle text-white mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nom</th>
                        <th>Type</th>
                        <th>Catégorie</th>
                        <th>Statut</th>
                        <th>Livrable</th>
                        <th>Propriétaire</th>
                        <th>Acheteur</th>
                        <th>Livraison</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="admin-table-body">
                    {% include 'admin/_equipement_rows.html.twig' %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
