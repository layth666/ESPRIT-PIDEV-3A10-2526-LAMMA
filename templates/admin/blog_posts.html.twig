{% extends 'admin/base_admin.html.twig' %}

{% block title %}Blog — Gestion des Posts{% endblock %}
{% block page_title %}Gestion des Posts{% endblock %}
{% block breadcrumb %}Blog → Posts{% endblock %}

{% block body %}

<div class="card" style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05); border-radius:12px;">
    <div class="card-header d-flex justify-content-between align-items-center" style="background:transparent; border-bottom:1px solid rgba(255,255,255,0.07); padding:16px 20px;">
        <span class="fw-bold" style="font-family:'Bebas Neue',sans-serif; letter-spacing:0.5px;">
            <i class="fas fa-file-alt me-2" style="color:#f09000;"></i>TOUS LES POSTS
        </span>
        <a href="{{ path('app_post_new') }}" class="btn btn-sm" style="background:rgba(240,144,0,0.15); color:#f09000; border:1px solid rgba(240,144,0,0.3); font-size:0.8rem;">
            <i class="fas fa-plus me-1"></i> Nouveau Post
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0" style="background:transparent;" id="blog-posts-table">
                <thead style="border-bottom:1px solid rgba(255,255,255,0.07);">
                    <tr>
                        <th style="color:#aab1b7; font-size:0.75rem; text-transform:uppercase; padding:14px 16px;">ID</th>
                        <th style="color:#aab1b7; font-size:0.75rem; text-transform:uppercase; padding:14px 16px;">Titre</th>
                        <th style="color:#aab1b7; font-size:0.75rem; text-transform:uppercase; padding:14px 16px;">Auteur</th>
                        <th style="color:#aab1b7; font-size:0.75rem; text-transform:uppercase; padding:14px 16px;">Extrait du contenu</th>
                        <th style="color:#aab1b7; font-size:0.75rem; text-transform:uppercase; padding:14px 16px;">Commentaires</th>
                        <th style="color:#aab1b7; font-size:0.75rem; text-transform:uppercase; padding:14px 16px;">Date</th>
                        <th style="color:#aab1b7; font-size:0.75rem; text-transform:uppercase; padding:14px 16px; text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for post in posts %}
                    <tr>
                        <td style="padding:12px 16px; color:#94a3b8; font-size:0.85rem;">#{{ post.id }}</td>
                        <td style="padding:12px 16px; font-weight:600;">{{ post.title|slice(0, 50) }}{% if post.title|length > 50 %}…{% endif %}</td>
                        <td style="padding:12px 16px; color:#94a3b8; font-size:0.85rem;">{{ post.author.name|default('Inconnu') }}</td>
                        <td style="padding:12px 16px; color:#94a3b8; font-size:0.85rem;">{{ post.content|slice(0, 70) }}…</td>
                        <td style="padding:12px 16px;">
                            <span class="badge" style="background:#f09000; border-radius:20px; padding:4px 10px;">{{ post.comments|length }}</span>
                        </td>
                        <td style="padding:12px 16px; color:#94a3b8; font-size:0.85rem;">{{ post.createdAt ? post.createdAt|date('d/m/Y') : '—' }}</td>
                        <td style="padding:12px 16px; text-align:right;">
                            
                            <form method="post" action="{{ path('admin_blog_post_delete', {'id': post.id}) }}" onsubmit="return confirm('Supprimer ce post et tous ses commentaires ?')" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_delete_post_' ~ post.id) }}">
                                <button type="submit" class="btn btn-sm" style="background:rgba(239,68,68,0.15); color:#ef4444; border:1px solid rgba(239,68,68,0.3); font-size:0.75rem;">
                                    <i class="fas fa-trash"></i> Supprimer
                                </button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="fas fa-file-alt fa-2x mb-3 d-block" style="opacity:0.3;"></i>
                            Aucun post pour le moment.
                            <br><a href="{{ path('app_post_new') }}" style="color:#f09000;">Créer le premier post</a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% endblock %}
