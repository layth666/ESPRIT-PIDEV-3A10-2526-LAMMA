{% for e in equipements %}
    <tr>
        <td>{{ e.id }}</td>
        <td><a href="{{ path('app_admin_equipement_show', {id: e.id}) }}" class="text-white text-decoration-none">{{ e.nom }}</a></td>
        <td>{{ e.type }}</td>
        <td>{{ e.categorie ?: '—' }}</td>
        <td>{{ e.statut }}</td>
        <td>{{ e.livrable ? 'Oui' : 'Non' }}</td>
        <td>{{ e.owner ? e.owner.userid : 'Aucun' }}</td>
        <td>{{ e.delivery and e.delivery.acheteur ? e.delivery.acheteur.userid : '—' }}</td>
        <td>{{ e.delivery ? e.delivery.statut|replace({'en_attente': 'En attente', 'confirmee': 'Confirmée', 'preparation': 'En préparation', 'expediee': 'Expédiée', 'en_cours': 'En cours', 'livree': 'Livrée', 'annulee': 'Annulée'}) : 'Aucune' }}</td>
        <td class="text-end">
            <a href="{{ path('app_admin_equipement_show', {id: e.id}) }}" class="btn btn-sm btn-outline-light">Voir</a>
            <a href="{{ path('app_admin_equipement_edit', {id: e.id}) }}" class="btn btn-sm btn-warning text-dark">Modifier</a>
            <form method="post" action="{{ path('app_admin_equipement_delete', {id: e.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cet équipement ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_equipement_' ~ e.id) }}">
                <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
            </form>
        </td>
    </tr>
{% else %}
    <tr>
        <td colspan="10" class="text-center text-white-50">Aucun équipement trouvé.</td>
    </tr>
{% endfor %}
