{# templates/admin/base_admin.html.twig
   Base layout for all LAMMA back-office pages.
   Blocks available:
     - title         → <title> suffix
     - page_title    → H1 inside header
     - breadcrumb    → small text under H1
     - content       → main page body
     - extra_styles  → additional <style> tags
     - extra_scripts → JS at bottom of body
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LAMMA Admin — {% block title %}Dashboard{% endblock %}</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="{{ asset('css/lamma_redesign.css') }}">
  <style>
    :root {
      --sidebar-w: 260px;
    }
    body { background: var(--dark); color: var(--white); overflow: hidden; height: 100vh; }
    
    .admin-shell { display: flex; height: 100vh; }
    
    .sidebar {
      width: var(--sidebar-w);
      background: var(--dark-surface);
      border-right: 1px solid var(--line-white);
      display: flex; flex-direction: column;
      z-index: 100;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .sidebar-brand {
      padding: 30px 24px;
      display: flex; align-items: center; gap: 12px;
      border-bottom: 1px solid var(--line-white);
    }
    
    .sidebar-logo { width: 40px; filter: drop-shadow(0 0 8px rgba(232, 57, 44, 0.3)); }
    .sidebar-name { font-family: 'Anton', sans-serif; font-size: 1.8rem; letter-spacing: 1px; }
    .sidebar-name span { color: var(--prm); }
    
    .sidebar-nav { flex: 1; overflow-y: auto; padding: 20px 12px; }
    .sidebar-nav::-webkit-scrollbar { width: 4px; }
    .sidebar-nav::-webkit-scrollbar-thumb { background: var(--line-white); }
    
    .sidebar-section {
      padding: 20px 15px 10px;
      font-size: 0.65rem; font-weight: 800; color: var(--text-muted);
      text-transform: uppercase; letter-spacing: 2px;
    }
    
    .nav-item {
      display: flex; align-items: center; gap: 14px;
      padding: 12px 18px;
      font-size: 0.9rem; font-weight: 500;
      color: rgba(255,255,255,0.8);
      text-decoration: none;
      border-radius: 12px;
      margin-bottom: 4px;
      transition: all 0.2s ease;
    }
    
    .nav-item i { font-size: 1.1rem; width: 24px; text-align: center; }
    .nav-item:hover { background: rgba(255,255,255,0.05); color: var(--white); }
    .nav-item.active { background: var(--prm); color: var(--white); box-shadow: 0 4px 15px rgba(232, 57, 44, 0.3); }
    
    .main-area { flex: 1; display: flex; flex-direction: column; background: var(--dark); }
    
    .topbar {
      height: 70px; background: var(--dark-surface);
      border-bottom: 1px solid var(--line-white);
      display: flex; align-items: center; padding: 0 30px;
    }
    
    .page-body { flex: 1; overflow-y: auto; padding: 40px; }
    .page-body::-webkit-scrollbar { width: 6px; }
    .page-body::-webkit-scrollbar-thumb { background: var(--line-white); border-radius: 10px; }
    
    .card { background: var(--dark-card) !important; border: 1px solid var(--line-white) !important; }
    
    .user-avatar-sm { border: 2px solid rgba(255,255,255,0.1); transition: border-color 0.2s ease; overflow: hidden; }
    .user-avatar-sm:hover { border-color: var(--prm); }
    .user-avatar-sm img { width: 100%; height: 100%; object-fit: cover; }
    
    .text-muted { color: var(--text-muted) !important; }
    .breadcrumb-item.active { color: var(--prm) !important; }
  </style>
  {% block extra_styles %}{% endblock %}
  {% block stylesheets %}{% endblock %}
</head>

<body>
<div class="admin-shell">

  {# ══ SIDEBAR ══ #}
  <aside class="sidebar">
    <div class="sidebar-brand">
      <img src="{{ asset('images/logo.png') }}" alt="LAMMA" class="sidebar-logo"/>
      <div class="sidebar-name">LAMMA<span>.</span></div>
    </div>

    <nav class="sidebar-nav">
      <div class="sidebar-section">Core</div>
      <a href="{{ path('app_users_index') }}" class="nav-item {{ app.request.get('_route') starts with 'app_users' ? 'active' : '' }}">
        <i class="fas fa-users"></i>
        <span>Utilisateurs</span>
      </a>

      <div class="sidebar-section">Business</div>
      <a href="{{ path('app_evenement_index') }}" class="nav-item {{ app.request.get('_route') starts with 'app_evenement' ? 'active' : '' }}">
        <i class="fas fa-calendar-alt"></i>
        <span>Événements</span>
      </a>

      <div class="sidebar-section">Lamma Module</div>
      <a href="{{ path('app_admin_dashboard') }}" class="nav-item {{ app.request.get('_route') == 'app_admin_dashboard' ? 'active' : '' }}">
        <i class="fas fa-chart-pie"></i>
        <span>Lamma Stats</span>
      </a>
      <a href="{{ path('app_participation_index') }}" class="nav-item {{ app.request.get('_route') starts with 'app_participation' ? 'active' : '' }}">
        <i class="fas fa-handshake"></i>
        <span>Participations</span>
      </a>
      <a href="{{ path('app_restaurant_index') }}" class="nav-item {{ app.request.get('_route') starts with 'app_restaurant' ? 'active' : '' }}">
        <i class="fas fa-utensils"></i>
        <span>Restaurants</span>
      </a>
      <a href="{{ path('app_menu_index') }}" class="nav-item {{ app.request.get('_route') starts with 'app_menu' ? 'active' : '' }}">
        <i class="fas fa-book-open"></i>
        <span>Catalogue Menus</span>
      </a>
      <a href="{{ path('app_ingredient_index') }}" class="nav-item {{ app.request.get('_route') starts with 'app_ingredient' ? 'active' : '' }}">
        <i class="fas fa-carrot"></i>
        <span>Ingrédients</span>
      </a>
      <a href="{{ path('app_menu_planner_index') }}" class="nav-item {{ app.request.get('_route') starts with 'app_menu_planner' ? 'active' : '' }}">
        <i class="fas fa-calendar-check"></i>
        <span>Menu Planner</span>
      </a>
      <a href="{{ path('app_abonnement_index') }}" class="nav-item {{ app.request.get('_route') starts with 'app_abonnement' ? 'active' : '' }}">
        <i class="fas fa-id-card"></i>
        <span>Abonnements</span>
      </a>
      <div class="sidebar-section">Logistique Boutique</div>
      <a href="{{ path('app_admin_boutique_index') }}" class="nav-item {{ app.request.get('_route') starts with 'app_admin_boutique' ? 'active' : '' }}">
        <i class="fas fa-campground"></i>
        <span>Boutique Camping</span>
      </a>
      <a href="{{ path('app_weather') }}" class="nav-item {{ app.request.get('_route') == 'app_weather' ? 'active' : '' }}">
        <i class="fas fa-cloud-sun"></i>
        <span>Météo Logistique</span>
      </a>
      <a href="{{ path('app_map') }}" class="nav-item {{ app.request.get('_route') == 'app_map' ? 'active' : '' }}">
        <i class="fas fa-map-marked-alt"></i>
        <span>Carte Interactive</span>
      </a>

      <div class="sidebar-section">Communauté</div>
      <a href="{{ path('admin_blog_dashboard') }}" class="nav-item {{ app.request.get('_route') starts with 'admin_blog' ? 'active' : '' }}">
        <i class="fas fa-blog"></i>
        <span>Blog Dashboard</span>
      </a>
      <a href="{{ path('admin_blog_posts') }}" class="nav-item {{ app.request.get('_route') == 'admin_blog_posts' ? 'active' : '' }}">
        <i class="fas fa-file-alt"></i>
        <span>Gérer Articles</span>
      </a>
      <a href="{{ path('admin_blog_comments') }}" class="nav-item {{ app.request.get('_route') == 'admin_blog_comments' ? 'active' : '' }}">
        <i class="fas fa-comments"></i>
        <span>Commentaires</span>
      </a>

      <div class="sidebar-section">Partenaires</div>
      <a href="{{ path('admin_sponsor_dashboard') }}" class="nav-item {{ app.request.get('_route') == 'admin_sponsor_dashboard' ? 'active' : '' }}">
        <i class="fas fa-hand-holding-heart"></i>
        <span>Sponsor Stats</span>
      </a>
      <a href="{{ path('app_sponsor_index') }}" class="nav-item {{ app.request.get('_route') starts with 'app_sponsor' ? 'active' : '' }}">
        <i class="fas fa-briefcase"></i>
        <span>Gérer Sponsors</span>
      </a>
      <a href="{{ path('app_event_sponsor_index') }}" class="nav-item {{ app.request.get('_route') starts with 'app_event_sponsor' ? 'active' : '' }}">
        <i class="fas fa-link"></i>
        <span>Sponsorisations</span>
      </a>
      <a href="{{ path('admin_sponsor_feedback') }}" class="nav-item {{ app.request.get('_route') == 'admin_sponsor_feedback' ? 'active' : '' }}">
        <i class="fas fa-comments"></i>
        <span>Gérer Feedbacks</span>
      </a>
    </nav>

    <div class="sidebar-footer" style="padding: 20px; border-top: 1px solid var(--line-white);">
      <div class="d-flex align-items-center gap-3">
        <div class="user-avatar-sm bg-danger rounded-circle d-grid place-items-center text-white fw-bold" style="width: 42px; height: 42px;">
          {% if app.user and app.user.image %}
            <img src="{{ asset('uploads/images/' ~ app.user.image) }}" alt="{{ app.user.name }}">
          {% else %}
            {{ app.user ? app.user.name|slice(0,1)|upper : 'A' }}
          {% endif %}
        </div>
        <div class="flex-grow-1 min-w-0">
          <div class="text-white small fw-bold text-truncate">{{ app.user ? app.user.name : 'Admin Account' }}</div>
          <div class="text-white-50" style="font-size: 0.75rem; letter-spacing: 0.5px;">ADMINISTRATEUR</div>
        </div>
        <a href="{{ path('app_logout') }}" class="text-danger opacity-75 hover-opacity-100" title="Déconnexion"><i class="fas fa-sign-out-alt"></i></a>
      </div>
    </div>
  </aside>

  {# ══ MAIN ══ #}
  <div class="main-area">
    <div class="topbar">
      <div class="d-flex align-items-center gap-3">
        <h4 class="m-0 text-white" style="font-family:'Anton', sans-serif; letter-spacing:1px; text-transform: uppercase;">{% block page_title %}Dashboard{% endblock %}</h4>
        <span class="text-white-50">/</span>
        <span class="text-white-50 small fw-bold" style="letter-spacing: 0.5px;">{% block breadcrumb %}Aperçu global{% endblock %}</span>
      </div>
      
      <div class="ms-auto d-flex align-items-center gap-4">
        <div class="d-flex align-items-center gap-2 text-muted small bg-dark p-2 px-3 rounded-pill border border-secondary border-opacity-25">
          <i class="far fa-clock text-success"></i>
          {{ "now"|date("D, d M Y") }}
        </div>

        <div class="dropdown">
          <button class="btn btn-link p-0 text-white border-0 shadow-none" type="button" data-bs-toggle="dropdown">
              <div class="user-avatar-sm bg-dark rounded-circle d-grid place-items-center fw-bold border border-white border-opacity-10" style="width: 40px; height: 40px; font-size: 0.85rem;">
                {% if app.user and app.user.image %}
                    <img src="{{ asset('uploads/images/' ~ app.user.image) }}" alt="{{ app.user.name }}">
                {% else %}
                    {{ app.user ? app.user.name|slice(0,1)|upper : 'A' }}
                {% endif %}
              </div>
          </button>
          <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 bg-dark-card mt-2">
              <li><a class="dropdown-item text-white py-2" href="{{ path('app_home') }}"><i class="fas fa-external-link-alt me-2 text-info"></i> Voir le site</a></li>
              <li><hr class="dropdown-divider border-white border-opacity-10"></li>
              <li><a class="dropdown-item text-danger py-2" href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt me-2"></i> Déconnexion</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="page-body">
      {# Flash Messages #}
      {% for label, messages in app.flashes %}
          {% for message in messages %}
              <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px;">
                  <div class="d-flex align-items-center gap-2">
                      <i class="fas fa-{{ label == 'success' ? 'check-circle' : (label == 'error' ? 'exclamation-circle' : 'info-circle') }}"></i>
                      <div>{{ message }}</div>
                  </div>
                  <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
          {% endfor %}
      {% endfor %}

      {% block body %}{% endblock %}
    </div>
  </div>

</div>
<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% block extra_scripts %}{% endblock %}
{% block javascripts %}{% endblock %}
</body>
</html>
