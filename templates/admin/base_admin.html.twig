{% extends 'base.html.twig' %}

{% block body %}
<div id="layoutSidenav">
    <div id="layoutSidenav_nav">
        {% include 'admin/partials/sidebar.html.twig' %}
    </div>
    <div id="layoutSidenav_content">
        {% include 'admin/partials/navbar.html.twig' %}
        <main>
            <div class="container-fluid px-4">
                {% block admin_content %}

                {# ===== DASHBOARD PAR DÉFAUT ===== #}
                <h1 class="mt-4">Dashboard</h1>
                <ol class="breadcrumb mb-4">
                    <li class="breadcrumb-item active">Dashboard</li>
                </ol>

                {# Stats Cards #}
                <div class="row">
                    <div class="col-xl-3 col-md-6">
                        <div class="card bg-primary text-white mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fs-4 fw-bold">{{ totalSponsors ?? 0 }}</div>
                                    <div>Total Sponsors</div>
                                </div>
                                <i class="fas fa-handshake fa-2x opacity-75"></i>
                            </div>
                            <div class="card-footer d-flex align-items-center justify-content-between">
                                <a class="small text-white stretched-link" href="{{ path('app_sponsor_index') }}">Voir détails</a>
                                <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="card bg-success text-white mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fs-4 fw-bold">{{ sponsorsActifs ?? 0 }}</div>
                                    <div>Sponsors Actifs</div>
                                </div>
                                <i class="fas fa-check-circle fa-2x opacity-75"></i>
                            </div>
                            <div class="card-footer d-flex align-items-center justify-content-between">
                                <a class="small text-white stretched-link" href="{{ path('app_sponsor_index') }}">Voir détails</a>
                                <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="card bg-warning text-white mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fs-4 fw-bold">{{ totalAssociations ?? 0 }}</div>
                                    <div>Associations</div>
                                </div>
                                <i class="fas fa-calendar-alt fa-2x opacity-75"></i>
                            </div>
                            <div class="card-footer d-flex align-items-center justify-content-between">
                                <a class="small text-white stretched-link" href="{{ path('app_event_sponsor_index') }}">Voir détails</a>
                                <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="card bg-danger text-white mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fs-4 fw-bold">{{ montantTotal is defined ? montantTotal|number_format(0, '.', ' ') : 0 }} DT</div>
                                    <div>Montant Total</div>
                                </div>
                                <i class="fas fa-coins fa-2x opacity-75"></i>
                            </div>
                            <div class="card-footer d-flex align-items-center justify-content-between">
                                <a class="small text-white stretched-link" href="{{ path('app_event_sponsor_index') }}">Voir détails</a>
                                <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                            </div>
                        </div>
                    </div>
                </div>

                {# Charts Row #}
                <div class="row">
                    {# Bar Chart - Montant par Événement #}
                    <div class="col-xl-8">
                        <div class="card mb-4">
                            <div class="card-header">
                                <i class="fas fa-chart-bar me-1"></i>
                                Montant Total Collecté par Événement (DT)
                            </div>
                            <div class="card-body">
                                <canvas id="myBarChart" width="100%" height="40"></canvas>
                            </div>
                        </div>
                    </div>

                    {# Pie Chart - Montant par Niveau #}
                    <div class="col-xl-4">
                        <div class="card mb-4">
                            <div class="card-header">
                                <i class="fas fa-chart-pie me-1"></i>
                                Répartition par Niveau
                            </div>
                            <div class="card-body">
                                <canvas id="myPieChart" width="100%" height="80"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                {% endblock %}
            </div>
        </main>
        <footer class="py-4 bg-light mt-auto">
            <div class="container-fluid px-4">
                <div class="d-flex align-items-center justify-content-between small">
                    <div class="text-muted">Copyright &copy; LAMMA 2026</div>
                </div>
            </div>
        </footer>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if montantParEvenement is defined %}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.8.0/Chart.min.js" crossorigin="anonymous"></script>
    <script>
        // Bar Chart - Montant par Événement
        var ctxBar = document.getElementById("myBarChart");
        if (ctxBar) {
            var labels = {{ montantParEvenement|keys|json_encode|raw }};
            var data = [{% for val in montantParEvenement %}{{ val }}{% if not loop.last %},{% endif %}{% endfor %}];

            new Chart(ctxBar, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: "Montant (DT)",
                        backgroundColor: [
                            "#4e73df","#1cc88a","#36b9cc","#f6c23e",
                            "#e74a3b","#858796","#5a5c69","#2e59d9"
                        ],
                        borderColor: "rgba(0,0,0,0.1)",
                        data: data,
                    }],
                },
                options: {
                    scales: {
                        xAxes: [{ gridLines: { display: false }, ticks: { maxTicksLimit: 10 } }],
                        yAxes: [{ ticks: { maxTicksLimit: 5 }, gridLines: { color: "rgba(0,0,0,.125)" } }],
                    },
                    legend: { display: false }
                }
            });
        }

        // Pie Chart - Montant par Niveau
        var ctxPie = document.getElementById("myPieChart");
        if (ctxPie) {
            var niveauData = [{% for val in montantParNiveau %}{{ val }}{% if not loop.last %},{% endif %}{% endfor %}];
            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: ["GOLD", "SILVER", "BRONZE", "PARTENAIRE"],
                    datasets: [{
                        data: niveauData,
                        backgroundColor: ['#f6c23e', '#858796', '#cd7f32', '#36b9cc'],
                    }],
                },
                options: { legend: { display: true, position: 'bottom' } }
            });
        }
    </script>
    {% endif %}
{% endblock %}
