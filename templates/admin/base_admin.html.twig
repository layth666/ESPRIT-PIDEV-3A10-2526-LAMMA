{% extends 'base.html.twig' %}

{% block body %}
<div id="layoutSidenav">
    <div id="layoutSidenav_nav">
        {% include 'admin/partials/sidebar.html.twig' %}
    </div>
    <div id="layoutSidenav_content">
        {% include 'admin/partials/navbar.html.twig' %}
        <main>
            <div class="container-fluid px-4">
                {% block admin_content %}

                {# ===== DASHBOARD PAR DÉFAUT ===== #}
                <h1 class="mt-4">Dashboard</h1>
                <ol class="breadcrumb mb-4">
                    <li class="breadcrumb-item active">Dashboard</li>
                </ol>

                {# Stats Cards #}
                <div class="row">
                    <div class="col-xl-3 col-md-6">
                        <div class="card bg-primary text-white mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fs-4 fw-bold">{{ totalSponsors ?? 0 }}</div>
                                    <div>Total Sponsors</div>
                                </div>
                                <i class="fas fa-handshake fa-2x opacity-75"></i>
                            </div>
                            <div class="card-footer d-flex align-items-center justify-content-between">
                                <a class="small text-white stretched-link" href="{{ path('app_sponsor_index') }}">Voir détails</a>
                                <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="card bg-success text-white mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fs-4 fw-bold">{{ sponsorsActifs ?? 0 }}</div>
                                    <div>Sponsors Actifs</div>
                                </div>
                                <i class="fas fa-check-circle fa-2x opacity-75"></i>
                            </div>
                            <div class="card-footer d-flex align-items-center justify-content-between">
                                <a class="small text-white stretched-link" href="{{ path('app_sponsor_index') }}">Voir détails</a>
                                <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="card bg-warning text-white mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fs-4 fw-bold">{{ totalAssociations ?? 0 }}</div>
                                    <div>Associations</div>
                                </div>
                                <i class="fas fa-calendar-alt fa-2x opacity-75"></i>
                            </div>
                            <div class="card-footer d-flex align-items-center justify-content-between">
                                <a class="small text-white stretched-link" href="{{ path('app_event_sponsor_index') }}">Voir détails</a>
                                <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="card bg-danger text-white mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div id="totalAmountValue" class="fs-4 fw-bold" data-base-amount="{{ montantTotal|default(0) }}">
                                        {{ montantTotal is defined ? montantTotal|number_format(0, '.', ' ') : 0 }} TND
                                    </div>
                                    <div id="totalAmountLabel">Montant Total</div>
                                </div>
                                <i class="fas fa-coins fa-2x opacity-75"></i>
                            </div>
                            <div class="card-footer d-flex align-items-center justify-content-between">
                                <a class="small text-white stretched-link" href="{{ path('app_event_sponsor_index') }}">Voir détails</a>
                                <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-xl-4 col-md-6">
                        <div class="card mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fs-4 fw-bold">Convertisseur en temps réel</div>
                                    <div>Choisis une devise pour recalculer les montants</div>
                                </div>
                                <select id="currencySelector" class="form-select w-auto">
                                    <option value="TND">TND</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <div class="card bg-info text-white mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div id="convertedTotalValue" class="fs-4 fw-bold">N/A</div>
                                    <div>Montant Total converti</div>
                                </div>
                                <i class="fas fa-exchange-alt fa-2x opacity-75"></i>
                            </div>
                            <div class="card-footer d-flex align-items-center justify-content-between">
                                <div id="convertedTotalCurrency" class="small text-white">TND</div>
                                <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <div class="card bg-secondary text-white mb-4">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fs-4 fw-bold" id="exchangeRateValue">1 TND = 0</div>
                                    <div>Taux en temps réel</div>
                                </div>
                                <i class="fas fa-chart-line fa-2x opacity-75"></i>
                            </div>
                            <div class="card-footer d-flex align-items-center justify-content-between">
                                <div class="small text-white">Base TND</div>
                                <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                            </div>
                        </div>
                    </div>
                </div>

                {# Charts Row #}
                <div class="row">
                    {# Bar Chart - Montant par Événement #}
                    <div class="col-xl-8">
                        <div class="card mb-4">
                            <div class="card-header">
                                <i class="fas fa-chart-bar me-1"></i>
                                Montant Total Collecté par Événement (DT)
                            </div>
                            <div class="card-body">
                                <canvas id="myBarChart" width="100%" height="40"></canvas>
                            </div>
                        </div>
                    </div>

                    {# Pie Chart - Montant par Niveau #}
                    <div class="col-xl-4">
                        <div class="card mb-4">
                            <div class="card-header">
                                <i class="fas fa-chart-pie me-1"></i>
                                Répartition par Niveau
                            </div>
                            <div class="card-body">
                                <canvas id="myPieChart" width="100%" height="80"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                {% endblock %}
            </div>
        </main>
        <footer class="py-4 bg-light mt-auto">
            <div class="container-fluid px-4">
                <div class="d-flex align-items-center justify-content-between small">
                    <div class="text-muted">Copyright &copy; LAMMA 2026</div>
                </div>
            </div>
        </footer>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            function initSidebarToggle() {
                const sidebarToggle = document.getElementById('sidebarToggle');
                if (!sidebarToggle) {
                    return;
                }

                sidebarToggle.type = 'button';
                sidebarToggle.addEventListener('click', function (event) {
                    event.preventDefault();
                    document.body.classList.toggle('sb-sidenav-toggled');
                    localStorage.setItem('sb|sidebar-toggle', document.body.classList.contains('sb-sidenav-toggled'));
                });

                if (localStorage.getItem('sb|sidebar-toggle') === 'true') {
                    document.body.classList.add('sb-sidenav-toggled');
                }
            }

            document.addEventListener('DOMContentLoaded', initSidebarToggle);
            document.addEventListener('turbo:load', initSidebarToggle);
        })();
    </script>
    {% if montantParEvenement is defined %}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.8.0/Chart.min.js" crossorigin="anonymous"></script>
    <script>
        var rates = {{ rates|json_encode|raw }};
        var baseCurrency = '{{ baseCurrency|default('TND') }}';
        var montantTotalBase = {{ montantTotal|default(0) }};
        var barLabels = {{ montantParEvenement|keys|json_encode|raw }};
        var barDataBase = [{% for val in montantParEvenement %}{{ val }}{% if not loop.last %},{% endif %}{% endfor %}];
        var barChart = null;

        function formatAmount(value) {
            return new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(value);
        }

        function populateCurrencySelector(ratesObj) {
            var selector = document.getElementById('currencySelector');
            if (!selector) {
                return;
            }
            var existingValue = selector.value || baseCurrency;
            selector.innerHTML = '<option value="TND">TND</option>';
            Object.keys(ratesObj).sort().forEach(function(code) {
                if (code === baseCurrency) {
                    return;
                }
                var option = document.createElement('option');
                option.value = code;
                option.textContent = code;
                selector.appendChild(option);
            });
            if (ratesObj[existingValue] || existingValue === baseCurrency) {
                selector.value = existingValue;
            }
        }

        function fetchRates() {
            if (Object.keys(rates).length > 0) {
                populateCurrencySelector(rates);
                return Promise.resolve(rates);
            }

            return fetch('https://open.er-api.com/v6/latest/' + baseCurrency)
                .then(function(response) {
                    if (!response.ok) {
                        throw new Error('Erreur API');
                    }
                    return response.json();
                })
                .then(function(data) {
                    rates = data.rates || {};
                    populateCurrencySelector(rates);
                    return rates;
                })
                .catch(function() {
                    rates = {};
                    populateCurrencySelector(rates);
                    return rates;
                });
        }

        function getRate(currency) {
            if (currency === baseCurrency) {
                return 1;
            }
            return rates[currency] || null;
        }

        function updateTotals(currency) {
            var rate = getRate(currency);
            var totalValue = document.getElementById('totalAmountValue');
            var convertedTotalValue = document.getElementById('convertedTotalValue');
            var convertedTotalCurrency = document.getElementById('convertedTotalCurrency');
            var exchangeRateValue = document.getElementById('exchangeRateValue');
            var totalLabel = document.getElementById('totalAmountLabel');

            if (!rate) {
                convertedTotalValue.textContent = 'N/A';
                exchangeRateValue.textContent = 'Taux indisponible';
                totalValue.textContent = formatAmount(montantTotalBase) + ' ' + baseCurrency;
                totalLabel.textContent = 'Montant Total';
                if (barChart) {
                    barChart.data.datasets[0].data = barDataBase;
                    barChart.data.datasets[0].label = 'Montant (' + baseCurrency + ')';
                    barChart.options.scales.yAxes[0].ticks.callback = function(value) { return formatAmount(value) + ' ' + baseCurrency; };
                    barChart.update();
                }
                return;
            }

            var convertedTotal = montantTotalBase * rate;
            totalValue.textContent = formatAmount(convertedTotal) + ' ' + currency;
            totalLabel.textContent = 'Montant Total (' + currency + ')';
            convertedTotalValue.textContent = formatAmount(convertedTotal);
            convertedTotalCurrency.textContent = currency;
            exchangeRateValue.textContent = '1 ' + baseCurrency + ' = ' + formatAmount(rate) + ' ' + currency;

            if (barChart) {
                barChart.data.datasets[0].data = barDataBase.map(function(value) {
                    return value * rate;
                });
                barChart.data.datasets[0].label = 'Montant (' + currency + ')';
                barChart.options.scales.yAxes[0].ticks.callback = function(value) {
                    return formatAmount(value) + ' ' + currency;
                };
                barChart.update();
            }
        }

        function initCurrencySelector() {
            var selector = document.getElementById('currencySelector');
            if (!selector) {
                return;
            }

            var storedCurrency = localStorage.getItem('dashboardCurrency');
            var defaultCurrency = storedCurrency || 'USD';
            if (defaultCurrency !== baseCurrency && !rates[defaultCurrency]) {
                defaultCurrency = baseCurrency;
            }

            selector.value = defaultCurrency;
            updateTotals(defaultCurrency);

            selector.addEventListener('change', function() {
                var currency = selector.value;
                localStorage.setItem('dashboardCurrency', currency);
                updateTotals(currency);
            });
        }

        function initBarChart() {
            var ctxBar = document.getElementById('myBarChart');
            if (!ctxBar) {
                return;
            }

            barChart = new Chart(ctxBar, {
                type: 'bar',
                data: {
                    labels: barLabels,
                    datasets: [{
                        label: 'Montant (' + baseCurrency + ')',
                        backgroundColor: [
                            '#4e73df','#1cc88a','#36b9cc','#f6c23e',
                            '#e74a3b','#858796','#5a5c69','#2e59d9'
                        ],
                        borderColor: 'rgba(0,0,0,0.1)',
                        data: barDataBase,
                    }],
                },
                options: {
                    scales: {
                        xAxes: [{ gridLines: { display: false }, ticks: { maxTicksLimit: 10 } }],
                        yAxes: [{ ticks: { maxTicksLimit: 5, callback: function(value) { return formatAmount(value) + ' ' + baseCurrency; } }, gridLines: { color: 'rgba(0,0,0,.125)' } }],
                    },
                    legend: { display: false }
                }
            });
        }

        function initPieChart() {
            var ctxPie = document.getElementById('myPieChart');
            if (!ctxPie) {
                return;
            }

            var niveauData = [{% for val in montantParNiveau %}{{ val }}{% if not loop.last %},{% endif %}{% endfor %}];
            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: ['GOLD', 'SILVER', 'BRONZE', 'PARTENAIRE'],
                    datasets: [{
                        data: niveauData,
                        backgroundColor: ['#f6c23e', '#858796', '#cd7f32', '#36b9cc'],
                    }],
                },
                options: { legend: { display: true, position: 'bottom' } }
            });
        }

        function initDashboard() {
            initBarChart();
            initPieChart();
            fetchRates().then(function() {
                initCurrencySelector();
            });
        }

        document.addEventListener('DOMContentLoaded', initDashboard);
        document.addEventListener('turbo:load', initDashboard);
    </script>
    {% endif %}
{% endblock %}
