<script>

// Logic to handle both local and remote images
window.updateApercuImg = function(val) {
    const previewImg = document.getElementById('image-preview');
    const previewContainer = document.getElementById('image-preview-container');
    const urlText = document.getElementById('ai-url-display');

    if (!val || val.trim() === '') {
        if (previewContainer) previewContainer.classList.add('d-none');
        return;
    }

    if (previewContainer) previewContainer.classList.remove('d-none');
    
    let finalUrl = val;
    if (!val.startsWith('http') && !val.startsWith('/')) {
        finalUrl = '/uploads/' + val;
    }
    
    if (previewImg) previewImg.src = finalUrl;
    if (urlText && val.startsWith('http')) {
        urlText.innerText = val;
        urlText.classList.remove('d-none');
    } else if (urlText) {
        urlText.classList.add('d-none');
    }
}

// Global function for Gemini AI Generation
window.generateAIPoster_Safe = function() {
    const btn = document.getElementById('btn-generate-ai');
    const inputImage = document.getElementById('image-input') || document.querySelector('input[name*="[image]"]');
    const inputTitre = document.querySelector('input[name*="[titre]"], #evenement_titre');
    const inputType = document.querySelector('input[name*="[type]"]');
    const inputDesc = document.querySelector('textarea[name*="[description]"]');
    const statusDiv = document.getElementById('ai-status');

    if (!inputImage) {
        alert("Erreur: Champ image non trouvé.");
        return;
    }

    if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Gemini...';
    }
    if (statusDiv) {
        statusDiv.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Gemini prépare votre affiche...';
        statusDiv.classList.remove('d-none');
    }

    // Appel au backend Symfony pour utiliser Gemini en toute sécurité
    fetch('{{ path('app_admin_ai_generate_poster') }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            title: inputTitre ? inputTitre.value : 'Événement',
            type: inputType ? inputType.value : '',
            description: inputDesc ? inputDesc.value : ''
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.image) {
            inputImage.value = data.image; // Gemini renvoie du base64
            window.updateApercuImg(data.image);
            
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: 'Gemini a terminé !',
                    text: 'Affiche exclusive générée avec succès.',
                    timer: 3000
                });
            }
        } else if (data.error) {
            alert("Erreur Gemini: " + data.error);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert("Erreur de connexion au service Gemini.");
    })
    .finally(() => {
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-magic"></i> IA';
        }
        if (statusDiv) statusDiv.classList.add('d-none');
    });
};

// Global function for AI Equipment suggestions
window.suggestAIEquipments = function() {
    const btn = document.getElementById('btn-suggest-eq');
    // Sélecteur robuste qui trouve le champ peu importe l'ID généré par Symfony
    const inputEq = document.getElementById('equipments-input')
                 || document.querySelector('[name*="recommended_equipments"]')
                 || document.querySelector('[id*="recommended_equipments"]');
    const inputTitre = document.querySelector('input[name*="[titre]"], #evenement_titre, [name*="[titre]"]');
    const inputType  = document.querySelector('input[name*="[type]"], [name*="[type]"]');
    const inputDesc  = document.querySelector('textarea[name*="[description]"], [name*="[description]"]');

    if (!inputEq) {
        alert("Erreur technique : champ équipements introuvable.");
        return;
    }

    const title = inputTitre ? inputTitre.value.trim() : '';
    const type  = inputType  ? inputType.value.trim()  : '';
    const desc  = inputDesc  ? inputDesc.value.trim()  : '';

    if (!title && !type && !desc) {
        alert("Veuillez d'abord remplir le titre, le type ou la description de l'événement.");
        return;
    }

    if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Analyse...';
    }

    fetch('{{ path('app_admin_ai_suggest_equipments') }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, type, description: desc })
    })
    .then(response => response.json())
    .then(data => {
        if (data.equipments) {
            inputEq.value = data.equipments;
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: 'Équipements suggérés !',
                    text: data.equipments,
                    timer: 4000,
                    timerProgressBar: true,
                    background: '#212529',
                    color: '#fff'
                });
            }
        } else if (data.error) {
            alert("Erreur Gemini: " + data.error);
        }
    })
    .catch(error => {
        console.error('Erreur suggestion équipements:', error);
        alert("Erreur de connexion au service de suggestion.");
    })
    .finally(() => {
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-magic"></i> Suggérer (IA)';
        }
    });
};


document.addEventListener('DOMContentLoaded', function() {
    console.log("Formulaire pret - IA Initialisée");
    const inputImage = document.getElementById('image-input') || document.querySelector('input[name*="[image]"]');
    if (inputImage) {
        inputImage.addEventListener('input', (e) => window.updateApercuImg(e.target.value));
        if (inputImage.value) window.updateApercuImg(inputImage.value);
    }

    // Auto-equipments logic
    const typeInputSelect = document.querySelector('input[name*="[type]"]');
    const eqInputSelect = document.querySelector('#equipments-input');
    if (typeInputSelect && eqInputSelect) {
        typeInputSelect.addEventListener('input', function(e) {
            const val = e.target.value.toLowerCase();
            if (!eqInputSelect.value) {
                if (val.includes('camping')) eqInputSelect.value = 'tente, sac de couchage';
                if (val.includes('soire')) eqInputSelect.value = 'tenue de soirée';
            }
        });
    }
});
</script>