<form method="post" action="{{ path('app_evenement_delete', {'id': evenement.id_event}) }}" onsubmit="return confirm('Supprimer cet événement ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.id_event) }}">
    <button class="btn btn-danger"><i class="fa fa-trash"></i> Supprimer</button>
</form>