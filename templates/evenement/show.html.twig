{% extends 'base.html.twig' %}

{% block title %}Détails Événement - LAMMA{% endblock %}
{% block page_title %}{{ item.titre }}{% endblock %}
{% block page_subtitle %}Détails et planification de l'événement{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card card-detail overflow-hidden mb-4">
                    {% if item.image %}
                        <img src="{{ item.image }}" class="card-img-top" alt="{{ item.titre }}" style="max-height: 400px; object-fit: cover;">
                    {% endif %}
                    <div class="card-header"><i class="fa fa-info-circle"></i> Informations de l'événement</div>
                    <div class="card-body">
                        <h3>{{ item.titre }} <span class="badge badge-info">{{ item.type }}</span></h3>
                        <p class="text-muted"><i class="fa fa-map-marker"></i> {{ item.lieu ?? 'Lieu non défini' }}</p>
                        <hr>
                        <p>{{ item.description|nl2br }}</p>
                        <hr>
                        <div class="row">
                            <div class="col-md-6">
                                <strong>Début :</strong> {{ item.dateDebut ? item.dateDebut|date('d/m/Y H:i') : 'N/A' }}
                            </div>
                            <div class="col-md-6">
                                <strong>Fin :</strong> {{ item.dateFin ? item.dateFin|date('d/m/Y H:i') : 'N/A' }}
                            </div>
                        </div>
                        {% if item.spotifyUrl %}
                            <div class="mt-3">
                                <strong>Spotify :</strong> <a href="{{ item.spotifyUrl }}" target="_blank">{{ item.spotifyUrl }}</a>
                            </div>
                        {% endif %}
                        <div class="mt-3">
                            <span class="text-muted"><i class="fa fa-eye"></i> {{ item.nbVues }} vues</span>
                        </div>
                        <div class="mt-4 text-center">
                            <a href="{{ path('app_evenement_edit', {id: item.id}) }}" class="btn btn-warning" style="border-radius:25px;padding:10px 30px;">Modifier</a>
                            <a href="{{ path('app_evenement_index') }}" class="btn btn-secondary" style="border-radius:25px;padding:10px 30px;">Retour</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
