{% extends is_granted('ROLE_ADMIN') ? 'admin/base_admin.html.twig' : 'base.html.twig' %}

{% block title %}Participations - LAMMA{% endblock %}
{% block page_title %}Gestion des Inscriptions{% endblock %}

{% block body %}
<section class="crud-section">
    <div class="row align-items-center mb-5">
        <div class="col-md-7">
            <h2 class="fw-bold m-0 heading" style="letter-spacing:1px;">
                <i class="fas fa-handshake text-prm me-2"></i>INSCRIPTIONS MISSIONS
            </h2>
            <p class="text-muted small fw-bold mt-1 opacity-75">Suivi des participants et des statuts de déploiement</p>
        </div>
        <div class="col-md-5 text-md-end">
            <a href="{{ path('app_participation_new') }}" class="btn btn-primary rounded-pill px-4">
                <i class="fas fa-plus-circle me-2"></i>NOUVELLE INSCRIPTION
            </a>
        </div>
    </div>

    {# ====== SEARCH & FILTER BAR ====== #}
    <div class="card border-0 scout-card mb-5" style="background: rgba(0,0,0,0.03); border-radius: 20px; padding: 25px;">
        <div class="row g-3 align-items-center">
            <div class="col-md-auto">
                <span class="text-prm fw-bold" style="font-family:'Anton', sans-serif;"><i class="fas fa-sliders-h me-2"></i>FILTRES</span>
            </div>
            <div class="col-md">
                <div class="input-group overflow-hidden rounded-3 border border-secondary border-opacity-25">
                    <span class="input-group-text bg-transparent border-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" id="searchInput" class="form-control border-0 py-2 bg-transparent" placeholder="Rechercher par événement, type, statut...">
                </div>
            </div>
            <div class="col-md-auto d-flex flex-wrap gap-2">
                <select id="filterStatut" class="form-select border-0 shadow-sm rounded-3 fw-bold" style="font-size: 0.8rem; min-width: 120px;">
                    <option value="ALL">Statut: Tous</option>
                    <option value="EN_ATTENTE">En Attente</option>
                    <option value="CONFIRME">Confirmé</option>
                    <option value="ANNULE">Annulé</option>
                </select>
                <select id="filterType" class="form-select border-0 shadow-sm rounded-3 fw-bold" style="font-size: 0.8rem; min-width: 120px;">
                    <option value="ALL">Type: Tous</option>
                    <option value="SIMPLE">Simple</option>
                    <option value="HEBERGEMENT">Hébergement</option>
                    <option value="GROUPE">Groupe</option>
                </select>
                <select id="sortSelect" class="form-select border-0 shadow-sm rounded-3 fw-bold" style="font-size: 0.8rem; min-width: 150px;">
                    <option value="date_desc">Plus récent first</option>
                    <option value="nom_asc">Nom Événement A-Z</option>
                    <option value="montant_desc">Montant décroissant</option>
                </select>
            </div>
        </div>
    </div>

    {# ====== PARTICIPATION CARDS GRID ====== #}
    <div class="row g-4" id="participationGrid">
        {% for item in items %}
            <div class="col-md-6 col-lg-4 d-flex align-items-stretch participation-card-wrap"
                 data-statut="{{ item.statut }}"
                 data-type="{{ item.type }}"
                 data-nom="{{ eventMap[item.evenementId].titre|default('Événement #' ~ item.evenementId)|lower }}"
                 data-date="{{ item.dateInscription|date('Y-m-d H:i') }}"
                 data-montant="{{ item.montantCalcule|default(0) }}"
                 data-participants="{{ item.totalParticipants|default(0) }}"
                 data-search="{{ eventMap[item.evenementId].titre|default('') }} {{ userMap[item.userId]|default('') }} {{ item.type }} {{ item.statut }} {{ item.montantCalcule }} {{ item.mealOption }} {{ item.totalParticipants }}">
                <div class="card w-100 scout-card border-0 shadow-sm" style="border-radius: 20px;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-4">
                            <h5 class="fw-bold m-0 text-truncate pe-2" style="font-family:'DM Sans', sans-serif;">
                                {{ eventMap[item.evenementId].titre|default('Événement #' ~ item.evenementId) }}
                            </h5>
                            <div class="d-flex flex-column align-items-end">
                                <span class="badge rounded-pill px-3 py-2 fw-bold mb-1" style="font-size: 0.65rem; text-transform: uppercase;
                                    {% if item.statut == 'CONFIRME' %} background: #dcfce7; color: #166534;
                                    {% elseif item.statut == 'ANNULE' %} background: #fee2e2; color: #991b1b;
                                    {% else %} background: #fef3c7; color: #92400e; {% endif %}">
                                    {{ item.statut|replace({'_': ' '}) }}
                                </span>
                                
                                {# SMART AI INSIGHT #}
                                {% if aiInsights[item.evenementId] is defined %}
                                    {% set insight = aiInsights[item.evenementId] %}
                                    <span class="badge bg-{{ insight.popularity.class }} rounded-pill" style="font-size: 0.55rem; padding: 4px 8px;">
                                        <i class="fas fa-magic me-1"></i>{{ insight.popularity.label }}
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                        <div class="details-list small">
                            <div class="d-flex justify-content-between border-bottom border-light border-opacity-10 pb-2 mb-2">
                                <span class="text-muted fw-bold">PARTICIPANT</span>
                                <span class="fw-bold text-main">{{ userMap[item.userId]|default('Utilisateur #' ~ item.userId) }}</span>
                            </div>
                            <div class="d-flex justify-content-between border-bottom border-light border-opacity-10 pb-2 mb-2">
                                <span class="text-muted fw-bold">TYPE</span>
                                <span class="bg-primary bg-opacity-10 px-2 rounded fw-bold text-primary">{{ item.type }}</span>
                            </div>
                            <div class="d-flex justify-content-between border-bottom border-light border-opacity-10 pb-2 mb-2">
                                <span class="text-muted fw-bold">EFFECTIF</span>
                                <span class="fw-bold text-main">{{ item.totalParticipants }} pers.</span>
                            </div>
                            <div class="d-flex justify-content-between border-bottom border-light border-opacity-10 pb-2 mb-2">
                                <span class="text-muted fw-bold">MONTANT</span>
                                <span class="text-success fw-bold">{{ item.montantCalcule }} {{ item.devise }}</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted fw-bold">INSCRIPTION</span>
                                <span class="text-prm fw-bold"><i class="far fa-calendar-alt me-1"></i>{{ item.dateInscription|date('d/m/Y') }}</span>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 p-4 pt-0 d-flex gap-2">
                        <a href="{{ path('app_participation_show', {'id': item.id}) }}" class="btn btn-light flex-grow-1 fw-bold rounded-3" style="font-size: 0.8rem;"><i class="fas fa-info-circle me-2"></i>DÉTAILS</a>
                        
                        {% if is_granted('ROLE_ADMIN') and item.statut == 'EN_ATTENTE' %}
                            <a href="{{ path('app_participation_confirmer', {'id': item.id}) }}" class="btn btn-success border-0 fw-bold rounded-3" title="Confirmer"><i class="fas fa-check"></i></a>
                            <a href="{{ path('app_participation_annuler', {'id': item.id}) }}" class="btn btn-danger border-0 fw-bold rounded-3" title="Annuler"><i class="fas fa-times"></i></a>
                        {% endif %}

                        {% if not is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_participation_badge', {'id': item.id}) }}" class="btn btn-dark fw-bold rounded-3" title="Badge PDF"><i class="fas fa-id-badge"></i></a>
                        {% endif %}

                        {% if is_granted('ROLE_ADMIN') %}
                            <form method="post" action="{{ path('app_participation_delete', {'id': item.id}) }}" onsubmit="return confirm('Supprimer ?');" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                                <button type="submit" class="btn btn-outline-danger border-0 fw-bold rounded-3"><i class="fas fa-trash"></i></button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <i class="fas fa-folder-open fa-4x text-light mb-4"></i>
                <h4 class="text-muted">Aucune inscription trouvée</h4>
            </div>
        {% endfor %}
    </div>
</section>

<script>
(function() {
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        const filterStatut = document.getElementById('filterStatut');
        const filterType = document.getElementById('filterType');
        const sortSelect = document.getElementById('sortSelect');
        const grid = document.getElementById('participationGrid');
        const cards = Array.from(document.querySelectorAll('.participation-card-wrap'));

        function filterAndSort() {
            const search = searchInput.value.toLowerCase().trim();
            const statut = filterStatut.value;
            const type = filterType.value;
            const sort = sortSelect.value;

            cards.forEach(function(card) {
                const cardSearch = (card.getAttribute('data-search') || '').toLowerCase();
                const cardStatut = card.getAttribute('data-statut') || '';
                const cardType = card.getAttribute('data-type') || '';

                const matchSearch = !search || cardSearch.includes(search);
                const matchStatut = statut === 'ALL' || cardStatut === statut;
                const matchType = type === 'ALL' || cardType === type;

                card.style.display = (matchSearch && matchStatut && matchType) ? '' : 'none';
            });

            const visibleCards = cards.filter(c => c.style.display !== 'none');
            visibleCards.sort((a, b) => {
                switch(sort) {
                    case 'date_desc': return b.getAttribute('data-date').localeCompare(a.getAttribute('data-date'));
                    case 'nom_asc': return a.getAttribute('data-nom').localeCompare(b.getAttribute('data-nom'));
                    case 'montant_desc': return parseFloat(b.getAttribute('data-montant')) - parseFloat(a.getAttribute('data-montant'));
                    default: return 0;
                }
            });
            visibleCards.forEach(c => grid.appendChild(c));
        }

        if (searchInput) searchInput.addEventListener('input', filterAndSort);
        if (filterStatut) filterStatut.addEventListener('change', filterAndSort);
        if (filterType) filterType.addEventListener('change', filterAndSort);
        if (sortSelect) sortSelect.addEventListener('change', filterAndSort);
        filterAndSort();
    });
})();
</script>
{% endblock %}

