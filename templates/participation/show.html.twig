{% extends 'base.html.twig' %}

{% block title %}Détails Inscription - LAMMA{% endblock %}
{% block page_title %}Participation {% endblock %}

{% block body %}
<section class="crud-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card card-detail" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 15px; backdrop-filter: blur(10px); color: #fff; box-shadow: 0 8px 32px rgba(0,0,0,0.3);">
                    
                    {# ===== HEADER ===== #}
                    <div class="card-header d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.2); border-bottom: 1px solid rgba(255,255,255,0.1); padding: 20px 25px; border-radius: 15px 15px 0 0;">
                        <span style="font-family: 'Anton', sans-serif; font-size: 1.1rem; letter-spacing: 1px;">
                            <i class="fa fa-id-badge" style="color: #3b82f6;"></i> Dossier de Participation #{{ item.id }}
                        </span>
                        <span class="badge" style="
                            {% if item.statut == 'CONFIRME' %}
                                background: linear-gradient(135deg, #10b981, #059669);
                            {% elseif item.statut == 'ANNULE' %}
                                background: linear-gradient(135deg, #ef4444, #dc2626);
                            {% else %}
                                background: linear-gradient(135deg, #f59e0b, #d97706);
                            {% endif %}
                            color: white; padding: 6px 18px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px;">
                            {{ item.statut|replace({'_': ' '}) }}
                        </span>
                    </div>

                    {# ===== BODY ===== #}
                    <div class="card-body" style="padding: 30px;">
                        <div class="row">
                            {# Left Column: General Info #}
                            <div class="col-md-6">
                                <h5 class="mb-3" style="color: #3b82f6; font-family: 'Anton', sans-serif; letter-spacing: 1px; font-size: 0.95rem;">
                                    <i class="fa fa-info-circle"></i> INFORMATIONS GÉNÉRALES
                                </h5>
                                <div style="background: rgba(0,0,0,0.15); border-radius: 10px; padding: 18px; margin-bottom: 15px;">
                                    <p style="margin-bottom: 10px;"><strong style="color: #94a3b8;">Événement :</strong> 
                                        <span style="color: #10b981; font-weight: bold;">
                                            {% if event is defined and event %}
                                                {{ event.titre }}
                                            {% else %}
                                                Événement #{{ item.evenementId }}
                                            {% endif %}
                                        </span>
                                    </p>
                                    <p style="margin-bottom: 10px;"><strong style="color: #94a3b8;">Date Inscription :</strong> {{ item.dateInscription|date('d/m/Y H:i') }}</p>
                                    <p style="margin-bottom: 10px;"><strong style="color: #94a3b8;">Type :</strong> 
                                        <span class="badge" style="background: rgba(59,130,246,0.2); color: #60a5fa; padding: 3px 10px; border-radius: 10px;">{{ item.type }}</span>
                                    </p>
                                    <p style="margin-bottom: 0;"><strong style="color: #94a3b8;">Contexte :</strong> {{ item.contexteSocial ?? 'Non spécifié' }}</p>
                                </div>
                            </div>

                            {# Right Column: Logistics #}
                            <div class="col-md-6">
                                <h5 class="mb-3" style="color: #3b82f6; font-family: 'Anton', sans-serif; letter-spacing: 1px; font-size: 0.95rem;">
                                    <i class="fa fa-truck"></i> LOGISTIQUE ET REPAS
                                </h5>
                                <div style="background: rgba(0,0,0,0.15); border-radius: 10px; padding: 18px; margin-bottom: 15px;">
                                    <p style="margin-bottom: 10px;"><strong style="color: #94a3b8;">Hébergement :</strong> {{ item.hebergementNuits }} nuit(s)</p>
                                    <p style="margin-bottom: 10px;">
                                        <strong style="color: #94a3b8;">Adultes :</strong> {{ item.nbAdultes }} 
                                        &nbsp;|&nbsp; 
                                        <strong style="color: #94a3b8;">Enfants :</strong> {{ item.nbEnfants }}
                                    </p>
                                    <p style="margin-bottom: 10px;"><strong style="color: #94a3b8;">Chiens :</strong> {{ item.nbChiens }}</p>
                                    <p style="margin-bottom: 10px;"><strong style="color: #94a3b8;">Option Repas :</strong> 
                                        <span class="badge" style="background: rgba(245,158,11,0.2); color: #fbbf24; padding: 3px 10px; border-radius: 10px;">{{ item.mealOption ?? 'Non défini' }}</span>
                                    </p>
                                    <p style="margin-bottom: 0;"><strong style="color: #94a3b8;">Montant :</strong> 
                                        <span style="color: #10b981; font-weight: bold; font-size: 1.1rem;">{{ item.montantCalcule }} {{ item.devise }}</span>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <hr style="border-color: rgba(255,255,255,0.1); margin: 10px 0 20px;">

                        {# Extra Info #}
                        <div class="row">
                            <div class="col-12">
                                <div style="background: rgba(0,0,0,0.15); border-radius: 10px; padding: 18px;">
                                    <h6 style="color: #3b82f6; font-weight: bold; margin-bottom: 10px;"><i class="fa fa-heartbeat"></i> Besoins Spéciaux</h6>
                                    <p style="color: #cbd5e1; margin-bottom: 15px;">{{ item.besoinsSpeciaux ?? 'Aucun besoin spécial mentionné.' }}</p>
                                    <h6 style="color: #3b82f6; font-weight: bold; margin-bottom: 10px;"><i class="fa fa-comment"></i> Commentaire</h6>
                                    <p style="color: #cbd5e1; margin-bottom: 0;">{{ item.commentaire ?? 'Pas de commentaire.' }}</p>
                                </div>
                            </div>
                        </div>

                        {# ===== ACTION BUTTONS ===== #}
                        <div class="mt-4 text-center" style="display: flex; flex-wrap: wrap; justify-content: center; gap: 12px;">
                            {% if is_granted('ROLE_ADMIN') %}
                                {% if item.statut != 'CONFIRME' %}
                                    <a href="{{ path('app_participation_confirmer', {id: item.id}) }}" class="btn" style="background: linear-gradient(135deg, #10b981, #059669); color: white; border-radius: 25px; padding: 10px 30px; border: none; font-weight: bold; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);">
                                        <i class="fa fa-check"></i> Valider
                                    </a>
                                {% endif %}
                                {% if item.statut != 'ANNULE' %}
                                    <a href="{{ path('app_participation_annuler', {id: item.id}) }}" class="btn" style="background: linear-gradient(135deg, #ef4444, #dc2626); color: white; border-radius: 25px; padding: 10px 30px; border: none; font-weight: bold; box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);">
                                        <i class="fa fa-times"></i> Annuler
                                    </a>
                                {% endif %}
                                
                                <a href="{{ path('app_participation_edit', {id: item.id}) }}" class="btn" style="background: linear-gradient(135deg, #f59e0b, #d97706); color: white; border-radius: 25px; padding: 10px 30px; border: none; font-weight: bold; box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);">
                                    <i class="fa fa-pencil-alt"></i> Modifier
                                </a>
                            {% else %}
                                <a href="{{ path('app_participation_edit', {id: item.id}) }}" class="btn" style="background: linear-gradient(135deg, #f59e0b, #d97706); color: white; border-radius: 25px; padding: 10px 30px; border: none; font-weight: bold; box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);">
                                    <i class="fa fa-pencil-alt"></i> Modifier
                                </a>
                                
                                {# 🔥 Download Badge Button (User Only) #}
                                <a href="{{ path('app_participation_badge', {id: item.id}) }}" class="btn" style="background: linear-gradient(135deg, #00ff8a, #6c5ce7); color: white; border-radius: 25px; padding: 10px 30px; border: none; font-weight: bold; box-shadow: 0 4px 15px rgba(108, 92, 231, 0.3); transition: transform 0.2s ease;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                                    <i class="fa fa-download"></i> TÉLÉCHARGER BADGE PDF
                                </a>
                            {% endif %}

                            <a href="{{ path('app_participation_index') }}" class="btn" style="background: rgba(255,255,255,0.1); color: #fff; border-radius: 25px; padding: 10px 30px; border: 1px solid rgba(255,255,255,0.2); font-weight: bold;">
                                <i class="fa fa-arrow-left"></i> Retour
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
